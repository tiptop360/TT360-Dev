# ─────────────────────────────────────────────
# TipTop360 Optimizer — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git (already in .gitignore)
# ─────────────────────────────────────────────

# REQUIRED — Shopify store URL (without https://, must end in .myshopify.com)
SHOPIFY_STORE=tiptop360.myshopify.com

# REQUIRED — Shopify Admin API Access Token
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
# Required scopes: read_themes, write_themes, read_products, write_products,
#                  read_content, write_content
# Token is shown ONCE after install — copy immediately
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# REQUIRED for AI meta descriptions — Anthropic API key
# Get from: console.anthropic.com → API Keys → Create Key
# (Without this, all other fixes still work; only meta descriptions are skipped)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Anthropic model (default: claude-haiku-4-5-20251001)
# Haiku is fast + cheap — recommended for meta descriptions
# Upgrade to claude-sonnet-4-6 if you want more nuanced copy
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OPTIONAL — Your store's WhatsApp number (digits only, with country code, no + or spaces)
WHATSAPP_NUMBER=971585156033

# OPTIONAL — Brand name (used in schema markup)
STORE_NAME=TipTop360

# OPTIONAL — Store URL (used in schema markup)
STORE_URL=https://tiptop360.com

# OPTIONAL — Theme release pipeline defaults
# Live theme ID in Shopify
SHOPIFY_LIVE_THEME_ID=000000000000

# Staging theme ID in Shopify (duplicate of live used for preview/testing)
SHOPIFY_STAGING_THEME_ID=000000000000

# Optional sandbox theme ID for risky experiments
SHOPIFY_SANDBOX_THEME_ID=

# OPTIONAL — GitHub repo slug used in release notes
GITHUB_REPO=owner/repo

# OPTIONAL — Release operator name for manifests/checklists
RELEASE_OPERATOR=Your Name

# ─────────────────────────────────────────────
# META BUSINESS / WHATSAPP CLOUD API
# ─────────────────────────────────────────────
# Get these from Meta Business Manager → Apps → Your App

# Meta App credentials
META_APP_ID=
META_APP_SECRET=

# Custom string you choose — must match what you enter in Meta webhook config
META_VERIFY_TOKEN=tt360_webhook_verify

# System User Access Token (from Meta Business Manager → System Users → Generate Token)
# Scopes needed: whatsapp_business_messaging, whatsapp_business_management
WHATSAPP_ACCESS_TOKEN=

# From: Meta Business Manager → WhatsApp → Phone Numbers → select number → Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=

# From: Meta Business Manager → WhatsApp → Business Account ID
WHATSAPP_BUSINESS_ACCOUNT_ID=

# From: Meta Events Manager → your pixel → Settings → Pixel ID
META_PIXEL_ID=

# Set to "true" to send a WhatsApp welcome message on every new opt-in
WHATSAPP_SEND_WELCOME=false

# ─────────────────────────────────────────────
# KLAVIYO
# ─────────────────────────────────────────────
# Get from: Klaviyo → Settings → Account → API Keys

# Private key (server-side, never expose in frontend)
KLAVIYO_PRIVATE_API_KEY=

# Public / site key (safe to use in Liquid/JS)
KLAVIYO_PUBLIC_API_KEY=

# List ID for WhatsApp subscribers (created by setup-flows.js — fill in after running it)
KLAVIYO_WHATSAPP_LIST_ID=

# For Playwright browser automation (browser-setup.js / setup-all.js)
# Your Klaviyo login email and password
KLAVIYO_EMAIL=
KLAVIYO_PASSWORD=

# Alternative: paste your Klaviyo session cookie (avoids storing password)
# Get from browser DevTools → Application → Cookies → klaviyo.com → sessionid
KLAVIYO_SESSION_COOKIE=

# ─────────────────────────────────────────────
# WEBHOOK SERVER
# ─────────────────────────────────────────────
# Port for the local webhook server
WEBHOOK_PORT=3001

# Public URL of your deployed webhook server (no trailing slash)
# e.g. https://tt360-webhook.railway.app
WEBHOOK_BASE_URL=https://your-webhook-domain.com

# API key for securing the /send, /shopify, and /klaviyo webhook endpoints
WEBHOOK_API_KEY=change_this_to_a_random_secret
