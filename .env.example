# ─────────────────────────────────────────────
# TipTop360 Optimizer — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git (already in .gitignore)
# ─────────────────────────────────────────────

# REQUIRED — Shopify store URL (without https://, must end in .myshopify.com)
SHOPIFY_STORE=tiptop360.myshopify.com

# REQUIRED — Shopify Admin API Access Token
# Get from: Shopify Admin → Settings → Apps and sales channels → Develop apps
# Required scopes: read_themes, write_themes, read_products, write_products,
#                  read_content, write_content
# Token is shown ONCE after install — copy immediately
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# REQUIRED for AI meta descriptions — Anthropic API key
# Get from: console.anthropic.com → API Keys → Create Key
# (Without this, all other fixes still work; only meta descriptions are skipped)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# OPTIONAL — Anthropic model (default: claude-haiku-4-5-20251001)
# Haiku is fast + cheap — recommended for meta descriptions
# Upgrade to claude-sonnet-4-6 if you want more nuanced copy
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OPTIONAL — Your store's WhatsApp number (digits only, with country code, no + or spaces)
WHATSAPP_NUMBER=971585156033

# OPTIONAL — Brand name (used in schema markup)
STORE_NAME=TipTop360

# OPTIONAL — Store URL (used in schema markup)
STORE_URL=https://tiptop360.com
