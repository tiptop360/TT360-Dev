<!doctype html>
<html class="no-js" lang="{{ shop.locale }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
    <meta name="theme-color" content="{{ settings.color_header_bg }}">
    <meta name="format-detection" content="telephone=no">

    {% if template.name contains 'search'
      or template.name contains 'cart'
      or template.name contains 'customers'
      or request.path contains '/account'
      or request.path contains '/orders'
    %}
      <meta name="robots" content="noindex, nofollow">
    {% else %}
      <meta name="robots" content="index, follow">
    {% endif %}

    {%- assign current_url = request.path | append: request.query_string | downcase -%}
    {%- if current_url contains 'sort_by='
      or current_url contains 'filter='
      or current_url contains 'variant='
      or current_url contains 'oseid='
      or current_url contains 'preview_theme_id='
      or current_url contains 'preview_script_id='
      or current_url contains 'ls='
      or current_url contains 'utm_'
    %}
      <meta name="robots" content="noindex, follow">
    {%- endif -%}

    <title>
      {{ page_title }}
      {% if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif %}
      {% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}
      {% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>

    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- else -%}
      <meta name="description" content="{{ settings.meta_description | escape }}">
    {%- endif -%}

    <link rel="canonical" href="{{ canonical_url }}">
    <meta name="google-site-verification" content="Sjb9sxHlGboqXJEYuNtrwWaD3UWXMR5EaECeet2FKdo">
    <meta name="google-site-verification" content="BfJnjXpeVlW79p2dU6dQcQ6sD_f8sTAAEnBN5YAW0Ck">

    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com">
    <link rel="dns-prefetch" href="https://fonts.shopifycdn.com">

    {% if template.name == 'product' %}
      {% assign hero = product.selected_or_first_available_variant.featured_image | default: product.featured_image %}
      {% if hero %}
        <link rel="preload" as="image" href="{{ hero | image_url: width: 1200 }}"
          imagesrcset="{{ hero | image_url: width: 600 }} 600w, {{ hero | image_url: width: 900 }} 900w, {{ hero | image_url: width: 1200 }} 1200w"
          imagesizes="(max-width: 768px) 90vw, 600px">
      {% endif %}
    {% endif %}

    {%- render 'header-css' -%}

    {{ 'lazysizes.min.js' | asset_url | preload_tag: as: 'script' }}
    {{ 'vendor.s.min.js' | asset_url | preload_tag: as: 'script' }}
    {{ 'swiper-bundle.min.js' | asset_url | preload_tag: as: 'script' }}
    {{ 'global.s.min.js' | asset_url | preload_tag: as: 'script' }}

    {%- unless settings.font_family.system? -%}
      <link rel="preload" as="font" href="{{ settings.font_family | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {{ content_for_header }}

    {%- if settings.favicon != blank -%}
      <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
    {%- endif -%}

    {%- render 'social-meta-tags' -%}

    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous" defer="defer"></script>

    <script src="{{ 'lazysizes.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'vendor.s.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'global.s.min.js' | asset_url }}" defer="defer"></script>

    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "q3nwktubfr");
    </script>

    <script async src="https://www.googletagmanager.com/gtag/js?id=GT-NC6ZVVHK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'GT-NC6ZVVHK');
      gtag('config', 'G-HJ94RQ6GL5');
      gtag('config', 'AW-17211943737');
    </script>

    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-MQKGVTCH');</script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Organization",
            "@id": "https://tiptop360.com/#organization",
            "name": "TipTop360",
            "legalName": "Sylo Commerce FZ-LLC",
            "url": "https://tiptop360.com/",
            "logo": "https://tiptop360.com/cdn/shop/files/Logo.png?v=1760682550&width=200",
            "sameAs": [
              "https://www.facebook.com/TipTop360-online-61574240081708/",
              "https://www.instagram.com/tiptop360_online/",
              "https://www.tiktok.com/@tiptop360_online"
            ],
            "contactPoint": [{
              "@type": "ContactPoint",
              "telephone": "+971585156033",
              "contactType": "customer service",
              "areaServed": "AE",
              "availableLanguage": ["English"]
            }],
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "RAK Free Zone",
              "addressCountry": "AE"
            }
          },
          {
            "@type": "WebSite",
            "@id": "https://tiptop360.com/#website",
            "url": "https://tiptop360.com/",
            "name": "TipTop360 - Smart Lifestyle, Kids & Fitness Products in UAE",
            "description": "TipTop360 offers curated lifestyle, fitness, and kids' products with fast UAE delivery.",
            "publisher": { "@id": "https://tiptop360.com/#organization" },
            "potentialAction": {
              "@type": "SearchAction",
              "target": "https://tiptop360.com/search?q={search_term_string}",
              "query-input": "required name=search_term_string"
            }
          },
          {
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "How long does shipping take?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Orders are processed within 1–3 business days. Delivery is usually 2–5 business days in the UAE."
                }
              },
              {
                "@type": "Question",
                "name": "Can I return an item?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Yes. Items may be returned within 14 days if unused and in original packaging."
                }
              }
            ]
          }
        ]
      }
    </script>
  </head>

  <body class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }} body-theme {% if settings.productpage contains 'product-' %} product-hide-breadcrumb {% endif %}">
    
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MQKGVTCH" height="0" width="0" style="display:none;visibility:hidden" loading="lazy"></iframe></noscript>

    {%- render 'loading' -%}
    {%- sections 'header-group' -%}

    <div class="page-container page-element is-moved-by-drawer">
      {%- render 'breadcrumb' -%}

      <main class="main-content" id="MainContent" role="main">
        {% if settings.enable_animationscroll %}
          <div id="js-scroll">
            <div data-scroll-section>{%- render 'slideshow' -%}</div>
            {{ content_for_layout }}
          </div>
        {% else %}
          {%- render 'slideshow' -%}
          {{ content_for_layout }}
        {% endif %}
      </main>

      {%- sections 'footer-group' -%}
      {%- liquid
        section 'pnewsletter'
        section 'product-suggest'
        section 'cookie-policy'
        section 'custom-color'
      -%}
    </div>

    {%- liquid
      render 'back-to-top'
      render 'menu-mobile'
      render 'bottom-contents'
      render 'quickview'
      render 'popup-compare'
      render 'header-js'
    -%}

    <script>
      setInterval(function () {
        const miniCart = document.querySelector('.js-mini-cart');
        const chatBtn = document.getElementById('carthike-chat-button-container');
        if (miniCart?.classList.contains('active')) {
          chatBtn?.style.setProperty('display', 'none');
        } else {
          chatBtn?.style.removeProperty('display');
        }
      }, 500);
    </script>

    {{ 'tiny-img-link-preloader.s.min.js' | asset_url | script_tag }}
</body>
</html>