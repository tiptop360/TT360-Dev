</head>
<body class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }} body-theme {% if settings.productpage == 'product-2' or settings.productpage == 'product-6' or settings.productpage == 'product-7' %} product-hide-breadcrumb {% endif %}">
  <!-- Google Tag Manager (noscript) -->
<!-- End Google Tag Manager (noscript) -->
  <!-- Loading Indicator -->
  <div style="display:none"> {%- render 'loading' -%} </div>

  <!-- Header Sections -->
  <div style="display:none"> {%- sections 'header-group' -%} </div>

  <!-- Main page container -->
  <div class="page-container page-element is-moved-by-drawer">
    <div style="display:none"> {%- render 'breadcrumb' -%} </div>

    <!-- Main Content Area -->
    <main class="main-content" id="MainContent" role="main">
      {% if settings.enable_animationscroll %}
        <div id="js-scroll">
          <div data-scroll-section>
            {%- render 'slideshow' -%}
          </div>
          {{ content_for_layout }}
        </div>
      {% else %}
        {%- render 'slideshow' -%}
        {{ content_for_layout }}
      {% endif %}
    </main>

    <!-- Footer Sections -->
    {%- sections 'footer-group' -%}
    {%- liquid
      section 'pnewsletter'
      section 'product-suggest'
      section 'cookie-policy'
      section 'custom-color'
    -%}
  </div>

  <!-- Extra UI Components -->
  {%- liquid
    render 'back-to-top'
    render 'menu-mobile'
    render 'bottom-contents'
    render 'quickview'
    render 'popup-compare'
    render 'header-js'
  -%}

  <!-- Custom JS for Cart Visibility and Chat Toggle -->
  <script>
    setInterval(function() {
        if (document.querySelector('.js-mini-cart')?.classList.contains('active')) {
            document.getElementById('carthike-chat-button-container')?.style.setProperty('display', 'none');
        } else {
            document.getElementById('carthike-chat-button-container')?.style.removeProperty('display');
        }
    }, 500);
  </script>

  <!-- Lazy image preloader script (if used in theme) -->
  {{ 'tiny-img-link-preloader.s.min.js' | asset_url | script_tag }}

</body>
</html>
