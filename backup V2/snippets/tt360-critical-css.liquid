{%- comment -%}
  TipTop360 — Critical CSS
  Inlined in <head> for zero-render-block above-the-fold paint.
  Render: {%- render 'tt360-critical-css' -%}  (inside <head>, before any <link> stylesheets)
{%- endcomment -%}
<style id="tt360-critical">
/* ── RESET ──────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box}
html{-webkit-text-size-adjust:100%}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:16px;line-height:1.5;color:#1a1a1a;background:#fff}
img,video{max-width:100%;height:auto;display:block}
a{color:inherit;text-decoration:none}
button{cursor:pointer;border:none;background:none;padding:0}
ul,ol{list-style:none;margin:0;padding:0}
h1,h2,h3,h4,h5,h6{margin:0;font-weight:700;line-height:1.2}

/* ── BRAND TOKENS ────────────────────────────────────────── */
:root{
  --color-navy:#12395e;
  --color-mint:#54e8cc;
  --color-coral:#f9655d;
  --color-white:#ffffff;
  --color-gray-100:#f5f5f5;
  --color-gray-200:#e5e5e5;
  --color-gray-700:#444444;
  --radius-sm:4px;
  --radius-md:8px;
  --radius-lg:16px;
  --shadow-sm:0 1px 3px rgba(0,0,0,.08);
  --shadow-md:0 4px 16px rgba(0,0,0,.12);
  --transition:150ms ease;
  --font-body:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
  --font-heading:inherit;
  --max-width:1280px;
  --gutter:1rem;
}

/* ── LAYOUT SKELETON ─────────────────────────────────────── */
#page-container{display:flex;flex-direction:column;min-height:100vh}
main[role="main"]{flex:1}
.container{max-width:var(--max-width);margin-inline:auto;padding-inline:var(--gutter)}

/* ── HEADER ABOVE-FOLD ───────────────────────────────────── */
.site-header{
  position:sticky;top:0;z-index:100;
  background:var(--color-navy);
  color:var(--color-white);
  box-shadow:var(--shadow-sm);
  contain:layout style;
}
.site-header__inner{
  display:flex;align-items:center;justify-content:space-between;
  max-width:var(--max-width);margin-inline:auto;
  padding-block:.75rem;padding-inline:var(--gutter);
  min-height:60px;
}
.site-header__logo img{width:auto;max-width:200px;height:auto;max-height:56px;object-fit:contain;display:block}
.site-header__nav{display:none}
@media(min-width:1024px){.site-header__nav{display:flex;gap:1.5rem;align-items:center}}
.site-header__nav a{color:var(--color-white);font-size:.9rem;font-weight:500;transition:opacity var(--transition)}
.site-header__nav a:hover{opacity:.75}
.site-header__icons{display:flex;gap:.75rem;align-items:center}
.site-header__icons button,.site-header__icons a{color:var(--color-white);display:flex;align-items:center;padding:.25rem}

/* ── HERO / SLIDESHOW SKELETON ───────────────────────────── */
.slideshow-wrapper{
  position:relative;overflow:hidden;
  background:var(--color-gray-100);
  aspect-ratio:16/7;
  contain:layout;
}
@media(max-width:767px){.slideshow-wrapper{aspect-ratio:4/3}}
.slideshow-wrapper .slide{position:absolute;inset:0}
.slideshow-wrapper img{width:100%;height:100%;object-fit:cover}

/* ── PRODUCT CARD SKELETON ───────────────────────────────── */
.product-card{
  display:flex;flex-direction:column;
  border-radius:var(--radius-md);
  overflow:hidden;
  background:var(--color-white);
  box-shadow:var(--shadow-sm);
  transition:box-shadow var(--transition),transform var(--transition);
  contain:layout;
}
.product-card:hover{box-shadow:var(--shadow-md);transform:translateY(-2px)}
.product-card__image-wrap{
  position:relative;overflow:hidden;
  background:var(--color-gray-100);
  aspect-ratio:1/1;
}
.product-card__image-wrap img{
  width:100%;height:100%;object-fit:cover;
  transition:transform .3s ease;
}
.product-card:hover .product-card__image-wrap img{transform:scale(1.04)}
.product-card__info{padding:.875rem;display:flex;flex-direction:column;gap:.375rem;flex:1}
.product-card__title{font-size:.9rem;font-weight:600;color:var(--color-navy);line-height:1.3}
.product-card__price{font-size:1rem;font-weight:700;color:var(--color-coral)}
.product-card__badge{
  position:absolute;top:.5rem;left:.5rem;z-index:1;
  background:var(--color-coral);color:#fff;
  font-size:.7rem;font-weight:700;
  padding:.2rem .45rem;border-radius:var(--radius-sm);
  text-transform:uppercase;letter-spacing:.04em;
}

/* ── GRID ────────────────────────────────────────────────── */
.product-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:.875rem;
  padding-inline:var(--gutter);
}
@media(min-width:600px){.product-grid{grid-template-columns:repeat(3,1fr)}}
@media(min-width:900px){.product-grid{grid-template-columns:repeat(4,1fr);gap:1.25rem}}
@media(min-width:1200px){.product-grid{grid-template-columns:repeat(5,1fr)}}

/* ── BUTTONS ─────────────────────────────────────────────── */
.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:.5rem;
  padding:.6rem 1.25rem;border-radius:var(--radius-sm);
  font-size:.9rem;font-weight:600;line-height:1;
  transition:background var(--transition),opacity var(--transition),transform var(--transition);
  cursor:pointer;border:2px solid transparent;
  white-space:nowrap;
}
.btn-primary{background:var(--color-coral);color:#fff;border-color:var(--color-coral)}
.btn-primary:hover{opacity:.88}
.btn-secondary{background:transparent;color:var(--color-navy);border-color:var(--color-navy)}
.btn-secondary:hover{background:var(--color-navy);color:#fff}
.btn-mint{background:var(--color-mint);color:var(--color-navy);border-color:var(--color-mint)}
.btn-mint:hover{filter:brightness(.92)}
.btn:active{transform:scale(.97)}

/* ── LAZY IMAGE PLACEHOLDER ──────────────────────────────── */
.tt360-img[data-lazy-pending]{opacity:0;transition:opacity .3s ease}
.tt360-img[data-lazy-loaded]{opacity:1}
.tt360-img-placeholder{
  background:linear-gradient(90deg,var(--color-gray-100) 25%,var(--color-gray-200) 50%,var(--color-gray-100) 75%);
  background-size:200% 100%;
  animation:tt360-shimmer 1.4s infinite;
}
@keyframes tt360-shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* ── UTILITY ─────────────────────────────────────────────── */
.visually-hidden{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
.skip-link{position:absolute;left:-9999px;top:auto}
.skip-link:focus{left:1rem;top:1rem;z-index:9999;background:#fff;padding:.5rem 1rem;border-radius:4px;font-weight:600}
.contain-layout{contain:layout}
.contain-strict{contain:strict}
</style>
