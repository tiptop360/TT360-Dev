{%- comment -%} ── META: title + description + OG + Twitter ── {%- endcomment -%}
<script>
(function(){
  var T='UAE\'s #1 Kids Products | Next Day Delivery | TipTop360';
  var D='Shop UAE\'s most-loved kids products — U-shaped toothbrush, STEM robots & bubble machines. Dubai Municipality approved. Free delivery 100+ AED. Cash on delivery.';
  var IMG='{{ hero_img | image_url: width: 1200 }}';
  var URL='https://tiptop360.com/';

  // Title
  document.title = T;

  // Meta description
  var m=document.querySelector('meta[name="description"]');
  if(m){m.setAttribute('content',D);}
  else{var n=document.createElement('meta');n.name='description';n.content=D;document.head.appendChild(n);}

  // OG tags
  var og={
    'og:title':T,'og:description':D,'og:image':IMG,
    'og:url':URL,'og:type':'website','og:site_name':'TipTop360'
  };
  Object.keys(og).forEach(function(p){
    var el=document.querySelector('meta[property="'+p+'"]');
    if(el){el.setAttribute('content',og[p]);}
    else{var n=document.createElement('meta');n.setAttribute('property',p);n.setAttribute('content',og[p]);document.head.appendChild(n);}
  });

  // Twitter card
  var tc={
    'twitter:card':'summary_large_image','twitter:title':T,
    'twitter:description':D,'twitter:image':IMG
  };
  Object.keys(tc).forEach(function(n){
    var el=document.querySelector('meta[name="'+n+'"]');
    if(el){el.setAttribute('content',tc[n]);}
    else{var e=document.createElement('meta');e.name=n;e.content=tc[n];document.head.appendChild(e);}
  });

  // Canonical
  var cl=document.querySelector('link[rel="canonical"]');
  if(cl){cl.href=URL;}
  else{var lk=document.createElement('link');lk.rel='canonical';lk.href=URL;document.head.appendChild(lk);}
})();
</script>

