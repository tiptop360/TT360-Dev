<script>
(function(){
'use strict';
// ── VARIANT MAPS ──
var TBM={'Orange/2-6':43758443135091,'Orange/7-12':43953839898739,'Pink/2-6':43952313139315,'Pink/7-12':43953839931507,'Blue/2-6':43952313172083,'Blue/7-12':43953839964275};
var BNM={'Orange/2-6':44150252273779,'Orange/7-12':44150252306547,'Pink/2-6':44150252339315,'Pink/7-12':44150252372083,'Blue/2-6':44150252404851,'Blue/7-12':44150252437619};
window.t360TbV=43758443135091;
window.t360BnV=44150252273779;

window.t360Sel=function(gid,btn){
  var btns=document.querySelectorAll('#'+gid+' .t360-vbtn');
  for(var i=0;i<btns.length;i++){btns[i].classList.remove('active');btns[i].setAttribute('aria-pressed','false');}
  btn.classList.add('active');btn.setAttribute('aria-pressed','true');
};
window.t360GetVid=function(gid){
  var a=document.querySelector('#'+gid+' .t360-vbtn.active');
  return a?parseInt(a.dataset.vid,10):null;
};
window.t360UpdateTb=function(){
  var c=document.querySelector('#t360-tbColor .t360-vbtn.active');
  var a=document.querySelector('#t360-tbAge .t360-vbtn.active');
  window.t360TbV=TBM[(c?c.dataset.color:'Orange')+'/'+(a?a.dataset.age:'2-6')]||43758443135091;
};
window.t360UpdateBn=function(){
  var c=document.querySelector('#t360-bnColor .t360-vbtn.active');
  var a=document.querySelector('#t360-bnAge .t360-vbtn.active');
  window.t360BnV=BNM[(c?c.dataset.color:'Orange')+'/'+(a?a.dataset.age:'2-6')]||44150252273779;
};

// ── ADD TO CART ──
window.t360ATC=function(vid,bid){
  var btn=document.getElementById(bid);
  if(!btn||btn.classList.contains('loading'))return;
  var orig=btn.textContent;
  btn.classList.add('loading');btn.textContent='Adding…';
  fetch('/cart/add.js',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({id:vid,quantity:1})
  })
  .then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
  .then(function(){
    btn.classList.remove('loading');btn.classList.add('done');btn.textContent='✓ Added!';
    t360RefreshDrawer(true);t360SyncCount();
    setTimeout(function(){btn.classList.remove('done');btn.textContent=orig;},2500);
  })
  .catch(function(){
    btn.classList.remove('loading');btn.textContent='Try again';
    t360Toast('Error adding item. Please try again.');
    setTimeout(function(){btn.textContent=orig;},2200);
  });
};

// ── SHUFFLE ──
function shuffle(arr){var a=arr.slice();for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;}return a;}

// ── UPSELL BUILDER ──
function buildUpsell(cartVids){
  if(!window.t360HpProducts)return '';
  var d=window.t360HpProducts;
  var mAvail=d.main.filter(function(p){return cartVids.indexOf(p.vid)===-1;});
  var sAvail=d.small.filter(function(p){return cartVids.indexOf(p.vid)===-1;});
  var mPick=shuffle(mAvail).slice(0,2);
  var sCount=Math.min(3,5-mPick.length);
  var sPick=shuffle(sAvail).slice(0,sCount);
  var chosen=mPick.concat(sPick).slice(0,5);
  if(!chosen.length)return '';
  var h='<div class="t360-ups-sect"><div class="t360-ups-hd">You might also like</div>';
  chosen.forEach(function(p){
    h+='<div class="t360-ups-item">';
    h+='<a href="'+p.url+'" class="t360-ups-img-wrap"><img src="'+p.img+'" alt="" width="56" height="56" loading="lazy" onerror="this.style.opacity=\'0.15\'"></a>';
    h+='<div class="t360-ups-info"><a href="'+p.url+'" class="t360-ups-name">'+p.title+'</a>';
    h+='<div class="t360-ups-price">'+p.price+' AED</div></div>';
    h+='<button class="t360-ups-btn" onclick="t360HpUpsellAdd('+p.vid+',this)">+ Add</button>';
    h+='</div>';
  });
  return h+'</div>';
}
window.t360HpUpsellAdd=function(vid,btn){
  if(btn.classList.contains('loading'))return;
  var orig=btn.textContent;
  btn.classList.add('loading');btn.textContent='…';
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify({id:vid,quantity:1})})
  .then(function(r){return r.json();}).then(function(){
    btn.classList.remove('loading');btn.classList.add('done');btn.textContent='✓';
    t360RefreshDrawer(false);t360SyncCount();
    setTimeout(function(){btn.classList.remove('done');btn.textContent=orig;},2500);
  }).catch(function(){
    btn.classList.remove('loading');btn.textContent='Retry';
    setTimeout(function(){btn.textContent=orig;},2000);
  });
};

// ── CART DRAWER ──
window.t360OpenCart=function(){
  document.getElementById('tt360-cart-overlay').classList.add('open');
  document.getElementById('tt360-cart-drawer').classList.add('open');
  document.body.style.overflow='hidden';
  document.getElementById('tt360-cart-drawer').focus();
};
window.t360CloseCart=function(){
  document.getElementById('tt360-cart-overlay').classList.remove('open');
  document.getElementById('tt360-cart-drawer').classList.remove('open');
  document.body.style.overflow='';
};
window.t360RefreshDrawer=function(open){
  fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}})
  .then(function(r){return r.json();})
  .then(function(c){t360RenderDrawer(c);if(open)t360OpenCart();});
};
window.t360RenderDrawer=function(cart){
  var el=document.getElementById('t360-drawer-items');
  var ft=document.getElementById('t360-drawer-foot');
  var sb=document.getElementById('t360-subtotal');
  if(!cart.items||!cart.items.length){
    el.innerHTML='<div class="t360-drawer-empty">Your cart is empty</div>';
    if(ft)ft.style.display='none';return;
  }
  if(ft)ft.style.display='block';
  var h='';
  var cartVids=[];
  cart.items.forEach(function(it){
    cartVids.push(it.variant_id);
    h+='<div class="t360-cart-item">';
    h+='<img src="'+it.image+'" alt="'+it.product_title+'" width="68" height="68" loading="lazy">';
    h+='<div class="t360-ci-info"><div class="t360-ci-name">'+it.product_title+'</div>';
    if(it.variant_title&&it.variant_title!=='Default Title')h+='<div class="t360-ci-variant">'+it.variant_title+'</div>';
    h+='<div class="t360-ci-row"><span class="t360-ci-price">'+Math.round(it.final_line_price/100)+' AED</span>';
    h+='<div class="t360-qty-wrap">';
    h+='<button class="t360-qty-btn" onclick="t360Qty(\''+it.key+'\','+(it.quantity-1)+')" aria-label="Decrease quantity">&#8722;</button>';
    h+='<span class="t360-qty-val" aria-label="Quantity">'+it.quantity+'</span>';
    h+='<button class="t360-qty-btn" onclick="t360Qty(\''+it.key+'\','+(it.quantity+1)+')" aria-label="Increase quantity">+</button>';
    h+='</div></div>';
    h+='<button class="t360-ci-remove" onclick="t360Qty(\''+it.key+'\',0)">Remove</button>';
    h+='</div></div>';
  });
  h+=buildUpsell(cartVids);
  el.innerHTML=h;
  if(sb)sb.textContent=Math.round(cart.total_price/100)+' AED';
};
window.t360Qty=function(key,qty){
  fetch('/cart/change.js',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({id:key,quantity:qty})
  })
  .then(function(r){return r.json();})
  .then(function(c){t360RenderDrawer(c);t360SyncCount(c.item_count);});
};

// ── HEADER COUNT SYNC ──
window.t360SyncCount=function(n){
  if(n!==undefined){_setCount(n);return;}
  fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}})
  .then(function(r){return r.json();}).then(function(c){_setCount(c.item_count);});
};
function _setCount(n){
  var sels=['[data-cart-count]','[data-cart-item-count]','.cart-count','.header__cart-count','#CartCount','.cart__count','.site-header__cart-count','.cart-icon__bubble','.cart-count-bubble'];
  sels.forEach(function(s){document.querySelectorAll(s).forEach(function(e){e.textContent=n;e.style.display=n>0?'':'none';});});
  document.dispatchEvent(new CustomEvent('cart:updated',{detail:{cartCount:n}}));
}

// ── TOAST ──
window.t360Toast=function(msg){
  var t=document.getElementById('tt360-toast');
  if(!t)return;
  t.textContent=msg||'✓ Added to cart!';
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},2400);
};

// ── EMAIL SUBSCRIBE ──
window.t360Sub=function(){
  var inp=document.getElementById('t360-email');
  var v=(inp?inp.value:'').trim();
  if(!v||v.indexOf('@')<0){t360Toast('Please enter a valid email');return;}
  fetch('/contact',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'form_type=customer&utf8=✓&contact[email]='+encodeURIComponent(v)+'&contact[tags]=newsletter,homepage-cta'
  }).then(function(){
    t360Toast('✓ Check your inbox for your 10% code!');
    if(inp)inp.value='';
  }).catch(function(){t360Toast('✓ You\'re subscribed!');if(inp)inp.value='';});
};

// ── ESC CLOSE ──
document.addEventListener('keydown',function(e){if(e.key==='Escape')t360CloseCart();});

// Sync count on load
t360SyncCount();

})();
</script>
