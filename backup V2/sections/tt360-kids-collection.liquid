<script>
(function(){
'use strict';
var FREE=20000;
function fmt(c){return 'AED '+Math.round(c/100);}
function toast(msg){var t=document.getElementById('t3c-toast');if(!t)return;t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2400);}
function setCount(n){
  var b=document.getElementById('t3c-cnt');if(b)b.textContent=n;
  ['[data-cart-count]','[data-cart-item-count]','.cart-count','#CartCount','.cart__count','.site-header__cart-count','.cart-icon__bubble','.cart-count-bubble'].forEach(function(s){document.querySelectorAll(s).forEach(function(e){e.textContent=n;e.style.display=n>0?'':'none';});});
  document.dispatchEvent(new CustomEvent('cart:updated',{detail:{cartCount:n}}));
}
function shipBar(total){
  var bar=document.getElementById('t3c-ship');
  var txt=document.getElementById('t3c-ship-txt');
  var fill=document.getElementById('t3c-ship-fill');
  if(!bar)return;
  if(total>=FREE){bar.classList.add('done');txt.innerHTML='<strong>Free delivery unlocked!</strong> 🎉';fill.style.width='100%';}
  else{var rem=Math.round((FREE-total)/100);bar.classList.remove('done');txt.innerHTML='Add <strong>AED '+rem+'</strong> more for free delivery';fill.style.width=Math.min(Math.round(total/FREE*100),99)+'%';}
}
function renderCart(cart){
  var body=document.getElementById('t3c-drbody');
  var foot=document.getElementById('t3c-drfoot');
  var tot=document.getElementById('t3c-total');
  var co=document.getElementById('t3c-co');
  if(!body)return;
  setCount(cart.item_count);
  shipBar(cart.total_price);
  if(!cart.items||!cart.items.length){body.innerHTML='<p class="t3c-drempty">Your cart is empty</p>';if(foot)foot.style.display='none';return;}
  if(foot)foot.style.display='block';
  if(tot)tot.textContent=fmt(cart.total_price);
  if(co)co.innerHTML='🔒 Checkout &mdash; '+fmt(cart.total_price);
  var h='';
  cart.items.forEach(function(it){
    h+='<div class="t3c-dritem"><img src="'+it.image+'" alt="'+it.product_title+'" width="64" height="64" loading="lazy">';
    h+='<div class="t3c-drinfo"><p class="t3c-driname">'+it.product_title+'</p>';
    if(it.variant_title&&it.variant_title!=='Default Title')h+='<p class="t3c-drivar">'+it.variant_title+'</p>';
    h+='<div class="t3c-drirow"><span class="t3c-drip">'+fmt(it.final_line_price)+'</span>';
    h+='<div class="t3c-drqty">';
    h+='<button class="t3c-drqb'+(it.quantity===1?' danger':'')+'" onclick="t3cQty(\''+it.key+'\','+(it.quantity-1)+')">'+(it.quantity===1?'🗑':'−')+'</button>';
    h+='<span class="t3c-drqn">'+it.quantity+'</span>';
    h+='<button class="t3c-drqb" onclick="t3cQty(\''+it.key+'\','+(it.quantity+1)+')">+</button>';
    h+='</div></div></div></div>';
  });
  body.innerHTML=h;
}
function fetchCart(){return fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}}).then(function(r){return r.json();}).then(function(c){renderCart(c);return c;});}
window.t3cOpenCart=function(){document.getElementById('t3c-ov').classList.add('open');document.getElementById('t3c-dr').classList.add('open');document.body.style.overflow='hidden';fetchCart();};
window.t3cCloseCart=function(){document.getElementById('t3c-ov').classList.remove('open');document.getElementById('t3c-dr').classList.remove('open');document.body.style.overflow='';};
window.t3cQty=function(key,qty){fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify({id:key,quantity:qty})}).then(function(r){return r.json();}).then(renderCart);};
window.t3cATC=function(vid,btn){
  if(!btn||btn.classList.contains('loading'))return;
  var orig=btn.textContent;
  btn.classList.add('loading');btn.textContent='Adding…';
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify({id:vid,quantity:1})})
  .then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
  .then(function(){btn.classList.remove('loading');btn.classList.add('done');btn.textContent='✓ Added!';fetchCart().then(function(){t3cOpenCart();});setTimeout(function(){btn.classList.remove('done');btn.textContent=orig;},2500);})
  .catch(function(){btn.classList.remove('loading');btn.textContent='Try again';toast('Error adding item. Please try again.');setTimeout(function(){btn.textContent=orig;},2200);});
};
(function(){
  var dr=document.getElementById('t3c-dr');if(!dr)return;
  var sY=0,sT=0;
  dr.addEventListener('touchstart',function(e){sY=e.touches[0].clientY;sT=Date.now();},{passive:true});
  dr.addEventListener('touchend',function(e){var dy=e.changedTouches[0].clientY-sY;var dt=Date.now()-sT;if(dy>80||(dy>40&&dt<250))t3cCloseCart();},{passive:true});
})();
document.addEventListener('keydown',function(e){if(e.key==='Escape')t3cCloseCart();});
fetchCart();
})();
</script>

