        "ai_gen_block_15e7c06_pAUKHM": {
          "type": "ai_gen_block_15e7c06",
          "name": "Title and text",
          "settings": {
            "heading": "Automatic Toothbrush for Convenience",
            "text": "<p>An automatic toothbrush is really great for families who're always on the go. These things make sure your teeth get cleaned properly without you having to put in a lot of work. The good things about toothbrushes are:<br/><br/>* They save you time when you brush your teeth<br/><br/>* They clean your teeth evenly<br/><br/>* They are easy for kids to use<br/>toothbrushes are perfect for helping children learn to take care of their teeth by themselves. They make it easy for kids to brush their teeth and automatic toothbrushes are a help, to families.</p><p></p>",
            "desktop_width_percent": 100,
            "text_alignment": "left",
            "spacing": 15,
            "padding_top": 40,
            "padding_bottom": 40,
            "padding_horizontal": 20,
