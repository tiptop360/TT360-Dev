{% doc %}
  @prompt
    heanding 2 sige with link  , side left and right 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-two-column__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-two-column__left-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.left_width }}%;
    background-color: {{ block.settings.left_bg_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-two-column__right-{{ ai_gen_id }} {
    flex: 0 0 calc({{ 100 | minus: block.settings.left_width }}% - {{ block.settings.gap }}px);
    background-color: {{ block.settings.right_bg_color }};
    padding: {{ block.settings.padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-two-column__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-two-column__content-{{ ai_gen_id }} h2,
  .ai-two-column__content-{{ ai_gen_id }} h3,
  .ai-two-column__content-{{ ai_gen_id }} h4 {
    margin-top: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-two-column__container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-two-column__left-{{ ai_gen_id }},
    .ai-two-column__right-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }
  }
{% endstyle %}

<div class="ai-two-column-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-column__container-{{ ai_gen_id }}">
    <div class="ai-two-column__left-{{ ai_gen_id }}">
      <div class="ai-two-column__content-{{ ai_gen_id }}">
        {{ block.settings.left_content }}
      </div>
    </div>
    <div class="ai-two-column__right-{{ ai_gen_id }}">
      <div class="ai-two-column__content-{{ ai_gen_id }}">
        {{ block.settings.right_content }}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Two column layout",
  "settings": [
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Content",
      "default": "<p>Add your left side content here</p>"
    },
    {
      "type": "color",
      "id": "left_bg_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "header",
      "content": "Right side"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Content",
      "default": "<p>Add your right side content here</p>"
    },
    {
      "type": "color",
      "id": "right_bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "left_width",
      "label": "Left column width",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Desktop gap",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Mobile gap",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "options": [
        {
          "value": "column",
          "label": "Stack (left on top)"
        },
        {
          "value": "column-reverse",
          "label": "Stack (right on top)"
        }
      ],
      "default": "column"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#202025"
    }
  ],
  "presets": [
    {
      "name": "Two column layout"
    }
  ]
}
{% endschema %}
