{% doc %}
  @prompt
    create the exact Product image Slideshow as on the home page but for video , make it centered 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
    margin: 0 auto;
  }

  .ai-video-slideshow-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-video-slideshow-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease;
  }

  .ai-video-slideshow-slide-{{ ai_gen_id }} {
    min-width: 100%;
    position: relative;
  }

  .ai-video-slideshow-slide-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-video-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-video-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-video-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-video-slideshow-controls-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding: 0 {{ block.settings.control_spacing }}px;
    pointer-events: none;
    z-index: 2;
  }

  .ai-video-slideshow-btn-{{ ai_gen_id }} {
    width: {{ block.settings.control_size }}px;
    height: {{ block.settings.control_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.control_bg_color }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: auto;
    transition: all 0.3s ease;
    opacity: {{ block.settings.control_opacity }};
  }

  .ai-video-slideshow-btn-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .ai-video-slideshow-btn-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.control_size }}px * 0.5);
    height: calc({{ block.settings.control_size }}px * 0.5);
    fill: {{ block.settings.control_icon_color }};
  }

  .ai-video-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_spacing }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .ai-video-slideshow-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .ai-video-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  .ai-video-slideshow-play-pause-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.play_button_spacing }}px;
    right: {{ block.settings.play_button_spacing }}px;
    width: {{ block.settings.play_button_size }}px;
    height: {{ block.settings.play_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.play_button_bg }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 3;
    transition: all 0.3s ease;
    opacity: {{ block.settings.play_button_opacity }};
  }

  .ai-video-slideshow-play-pause-{{ ai_gen_id }}:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .ai-video-slideshow-play-pause-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.play_button_size }}px * 0.5);
    height: calc({{ block.settings.play_button_size }}px * 0.5);
    fill: {{ block.settings.play_button_icon_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-slideshow-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-video-slideshow-controls-{{ ai_gen_id }} {
      padding: 0 10px;
    }

    .ai-video-slideshow-btn-{{ ai_gen_id }} {
      width: calc({{ block.settings.control_size }}px * 0.8);
      height: calc({{ block.settings.control_size }}px * 0.8);
    }

    .ai-video-slideshow-play-pause-{{ ai_gen_id }} {
      width: calc({{ block.settings.play_button_size }}px * 0.8);
      height: calc({{ block.settings.play_button_size }}px * 0.8);
    }
  }
{% endstyle %}

<video-slideshow-{{ ai_gen_id }}
  class="ai-video-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-slideshow-wrapper-{{ ai_gen_id }}">
    <div class="ai-video-slideshow-track-{{ ai_gen_id }}">
      {% liquid
        assign has_videos = false
        for i in (1..5)
          assign video_key = 'video_' | append: i
          if block.settings[video_key] != blank
            assign has_videos = true
            break
          endif
        endfor
      %}

      {% if has_videos %}
        {% for i in (1..5) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign video = block.settings[video_key]
          %}

          {% if video != blank %}
            <div class="ai-video-slideshow-slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}">
              <video
                {% if block.settings.loop_videos %}loop{% endif %}
                {% if block.settings.mute_videos %}muted{% endif %}
                playsinline
                preload="metadata"
              >
                {% for source in video.sources %}
                  <source src="{{ source.url }}" type="{{ source.mime_type }}">
                {% endfor %}
              </video>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-video-slideshow-slide-{{ ai_gen_id }}">
          <div class="ai-video-slideshow-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-video-slideshow-empty-state-{{ ai_gen_id }}">
              Next, add videos to the slideshow
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if has_videos %}
      {% if block.settings.show_controls %}
        <div class="ai-video-slideshow-controls-{{ ai_gen_id }}">
          <button
            class="ai-video-slideshow-btn-{{ ai_gen_id }} ai-video-slideshow-prev-{{ ai_gen_id }}"
            aria-label="Previous video"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
            </svg>
          </button>
          <button
            class="ai-video-slideshow-btn-{{ ai_gen_id }} ai-video-slideshow-next-{{ ai_gen_id }}"
            aria-label="Next video"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
            </svg>
          </button>
        </div>
      {% endif %}

      {% if block.settings.show_dots %}
        <div class="ai-video-slideshow-dots-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% liquid
              assign video_key = 'video_' | append: i
              assign video = block.settings[video_key]
            %}
            {% if video != blank %}
              <button
                class="ai-video-slideshow-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                data-slide="{{ forloop.index0 }}"
                aria-label="Go to video {{ forloop.index }}"
              ></button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if block.settings.show_play_pause %}
        <button
          class="ai-video-slideshow-play-pause-{{ ai_gen_id }}"
          aria-label="Play/Pause video"
        >
          <svg class="ai-video-play-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg class="ai-video-pause-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
          </svg>
        </button>
      {% endif %}
    {% endif %}
  </div>
</video-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
        this.isPlaying = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-video-slideshow-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-video-slideshow-slide-{{ ai_gen_id }}');
        this.videos = this.querySelectorAll('.ai-video-slideshow-slide-{{ ai_gen_id }} video');
        this.prevBtn = this.querySelector('.ai-video-slideshow-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-video-slideshow-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-video-slideshow-dot-{{ ai_gen_id }}');
        this.playPauseBtn = this.querySelector('.ai-video-slideshow-play-pause-{{ ai_gen_id }}');
        this.playIcon = this.querySelector('.ai-video-play-icon-{{ ai_gen_id }}');
        this.pauseIcon = this.querySelector('.ai-video-pause-icon-{{ ai_gen_id }}');

        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        this.setupEventListeners();

        if (this.autoplay && this.videos.length > 0) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.goToPrevSlide());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.goToNextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        if (this.playPauseBtn) {
          this.playPauseBtn.addEventListener('click', () => this.togglePlayPause());
        }

        this.videos.forEach((video) => {
          video.addEventListener('ended', () => {
            if (this.autoplay) {
              this.goToNextSlide();
            }
          });
        });
      }

      goToSlide(index) {
        this.pauseAllVideos();
        this.currentSlide = index;
        this.updateSlidePosition();
        this.updateDots();

        if (this.isPlaying) {
          this.playCurrentVideo();
        }
      }

      goToNextSlide() {
        const nextSlide = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextSlide);
      }

      goToPrevSlide() {
        const prevSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevSlide);
      }

      updateSlidePosition() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;
      }

      updateDots() {
        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      togglePlayPause() {
        if (this.isPlaying) {
          this.pauseCurrentVideo();
          this.stopAutoplay();
          this.isPlaying = false;
          if (this.playIcon && this.pauseIcon) {
            this.playIcon.style.display = 'block';
            this.pauseIcon.style.display = 'none';
          }
        } else {
          this.playCurrentVideo();
          if (this.autoplay) {
            this.startAutoplay();
          }
          this.isPlaying = true;
          if (this.playIcon && this.pauseIcon) {
            this.playIcon.style.display = 'none';
            this.pauseIcon.style.display = 'block';
          }
        }
      }

      playCurrentVideo() {
        const currentVideo = this.videos[this.currentSlide];
        if (currentVideo) {
          currentVideo.play();
        }
      }

      pauseCurrentVideo() {
        const currentVideo = this.videos[this.currentSlide];
        if (currentVideo) {
          currentVideo.pause();
        }
      }

      pauseAllVideos() {
        this.videos.forEach((video) => {
          video.pause();
          video.currentTime = 0;
        });
      }

      startAutoplay() {
        this.stopAutoplay();
        this.playCurrentVideo();
        this.isPlaying = true;

        if (this.playIcon && this.pauseIcon) {
          this.playIcon.style.display = 'none';
          this.pauseIcon.style.display = 'block';
        }

        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
        this.pauseAllVideos();
      }
    }

    customElements.define('video-slideshow-{{ ai_gen_id }}', VideoSlideshow{{ ai_gen_id }});
  })();
</script>

