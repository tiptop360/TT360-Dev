{% doc %}
  @prompt
    Magnetic Gym Bag UAE | Hands-Free Workout Bag – TipTop360
    
    A smart magnetic gym bag designed to stick securely to metal gym machines, keeping your essentials like phone, keys, and towel within easy reach during workouts. The bag is compact, durable, and water-resistant, making it perfect for the gym, outdoor workouts, or travel.
    
    ✔ Strong built-in magnets keep the bag off dirty floors
    ✔ Spacious design for daily gym essentials
    ✔ Lightweight and easy to carry
    ✔ Fast UAE delivery with Cash on Delivery available
    
    Ideal for anyone who wants a cleaner, more organized workout experience.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-description-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-product-description__header-{{ ai_gen_id }} {
    margin-bottom: 24px;
  }

  .ai-product-description__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
    line-height: 1.3;
  }

  .ai-product-description__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    line-height: 1.6;
  }

  .ai-product-description__features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
  }

  .ai-product-description__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-description__feature-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-product-description__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-product-description__feature-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-product-description__highlights-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_bg_color }};
    padding: 20px;
    border-radius: {{ block.settings.highlight_border_radius }}px;
    margin-bottom: 24px;
  }

  .ai-product-description__highlights-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.highlight_title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
  }

  .ai-product-description__highlights-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
  }

  .ai-product-description__highlight-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: {{ block.settings.feature_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-description__highlight-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.icon_color }};
  }

  .ai-product-description__footer-{{ ai_gen_id }} {
    text-align: center;
    padding-top: 16px;
  }

  .ai-product-description__footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.footer_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-product-description-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-product-description__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-product-description__highlights-list-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-product-description-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-description__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-product-description__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <div class="ai-product-description__subtitle-{{ ai_gen_id }}">
        {{ block.settings.subtitle }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_highlights %}
    <div class="ai-product-description__highlights-{{ ai_gen_id }}">
      {% if block.settings.highlights_title != blank %}
        <h3 class="ai-product-description__highlights-title-{{ ai_gen_id }}">{{ block.settings.highlights_title }}</h3>
      {% endif %}
      <ul class="ai-product-description__highlights-list-{{ ai_gen_id }}">
        {% if block.settings.highlight_1 != blank %}
          <li class="ai-product-description__highlight-item-{{ ai_gen_id }}">
            <svg class="ai-product-description__highlight-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.highlight_1 }}</span>
          </li>
        {% endif %}
        {% if block.settings.highlight_2 != blank %}
          <li class="ai-product-description__highlight-item-{{ ai_gen_id }}">
            <svg class="ai-product-description__highlight-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.highlight_2 }}</span>
          </li>
        {% endif %}
        {% if block.settings.highlight_3 != blank %}
          <li class="ai-product-description__highlight-item-{{ ai_gen_id }}">
            <svg class="ai-product-description__highlight-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.highlight_3 }}</span>
          </li>
        {% endif %}
        {% if block.settings.highlight_4 != blank %}
          <li class="ai-product-description__highlight-item-{{ ai_gen_id }}">
            <svg class="ai-product-description__highlight-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.highlight_4 }}</span>
          </li>
        {% endif %}
      </ul>
    </div>
  {% endif %}

  <ul class="ai-product-description__features-{{ ai_gen_id }}">
    {% if block.settings.feature_1 != blank %}
      <li class="ai-product-description__feature-{{ ai_gen_id }}">
        <svg class="ai-product-description__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
          <path d="M2 17l10 5 10-5"></path>
          <path d="M2 12l10 5 10-5"></path>
        </svg>
        <p class="ai-product-description__feature-text-{{ ai_gen_id }}">{{ block.settings.feature_1 }}</p>
      </li>
    {% endif %}
    
    {% if block.settings.feature_2 != blank %}
      <li class="ai-product-description__feature-{{ ai_gen_id }}">
        <svg class="ai-product-description__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <p class="ai-product-description__feature-text-{{ ai_gen_id }}">{{ block.settings.feature_2 }}</p>
      </li>
    {% endif %}
    
    {% if block.settings.feature_3 != blank %}
      <li class="ai-product-description__feature-{{ ai_gen_id }}">
        <svg class="ai-product-description__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
          <line x1="12" y1="22.08" x2="12" y2="12"></line>
        </svg>
        <p class="ai-product-description__feature-text-{{ ai_gen_id }}">{{ block.settings.feature_3 }}</p>
      </li>
    {% endif %}
    
    {% if block.settings.feature_4 != blank %}
      <li class="ai-product-description__feature-{{ ai_gen_id }}">
        <svg class="ai-product-description__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
          <line x1="7" y1="7" x2="7.01" y2="7"></line>
        </svg>
        <p class="ai-product-description__feature-text-{{ ai_gen_id }}">{{ block.settings.feature_4 }}</p>
      </li>
    {% endif %}
  </ul>

  {% if block.settings.footer_text != blank %}
    <div class="ai-product-description__footer-{{ ai_gen_id }}">
      <p class="ai-product-description__footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</p>
    </div>
  {% endif %}
</div>

