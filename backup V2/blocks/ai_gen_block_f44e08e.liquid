{% doc %}
  @prompt
    A full banner optimized for mobile and web cominiing my products in a very compelling way condisdering my color identify , remove the image
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-product-banner__container-{{ ai_gen_id }} {
    max-width: 1300px;
    margin: 0 auto;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-product-banner__content-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    z-index: 2;
    position: relative;
  }

  .ai-product-banner__badge-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 20px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  .ai-product-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .ai-product-banner__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.8;
    margin: 0 0 32px;
  }

  .ai-product-banner__features-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }

  .ai-product-banner__feature-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  .ai-product-banner__feature-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: {{ block.settings.badge_bg_color }};
  }

  .ai-product-banner__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: 17px 32px;
    border-radius: 28px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
  }

  .ai-product-banner__cta-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-product-banner__accent-circle-{{ ai_gen_id }} {
    position: absolute;
    border-radius: 50%;
    background: {{ block.settings.accent_color }};
    opacity: 0.1;
    z-index: 0;
  }

  .ai-product-banner__accent-circle--1-{{ ai_gen_id }} {
    width: 300px;
    height: 300px;
    top: -100px;
    right: -100px;
  }

  .ai-product-banner__accent-circle--2-{{ ai_gen_id }} {
    width: 400px;
    height: 400px;
    bottom: -150px;
    left: -150px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-product-banner__container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
    }

    .ai-product-banner__features-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.5 }}px;
    }

    .ai-product-banner__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-product-banner__cta-{{ ai_gen_id }} {
      width: 100%;
      justify-content: center;
    }
  }
{% endstyle %}

<div class="ai-product-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-banner__accent-circle-{{ ai_gen_id }} ai-product-banner__accent-circle--1-{{ ai_gen_id }}"></div>
  <div class="ai-product-banner__accent-circle-{{ ai_gen_id }} ai-product-banner__accent-circle--2-{{ ai_gen_id }}"></div>

  <div class="ai-product-banner__container-{{ ai_gen_id }}">
    <div class="ai-product-banner__content-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <div class="ai-product-banner__badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="ai-product-banner__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-product-banner__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </div>
      {% endif %}

      {% if block.settings.show_features %}
        <ul class="ai-product-banner__features-{{ ai_gen_id }}">
          {% if block.settings.feature_1 != blank %}
            <li class="ai-product-banner__feature-{{ ai_gen_id }}">
              <svg class="ai-product-banner__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_1 }}</span>
            </li>
          {% endif %}
          {% if block.settings.feature_2 != blank %}
            <li class="ai-product-banner__feature-{{ ai_gen_id }}">
              <svg class="ai-product-banner__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_2 }}</span>
            </li>
          {% endif %}
          {% if block.settings.feature_3 != blank %}
            <li class="ai-product-banner__feature-{{ ai_gen_id }}">
              <svg class="ai-product-banner__feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.feature_3 }}</span>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-product-banner__cta-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product banner",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "label": "Vertical padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 30
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "New Arrival"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Our Best Products"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 44
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Experience quality and innovation with our carefully curated collection designed for families in the UAE.</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 14
    },
    {
      "type": "header",
      "content": "Features"
    },
    {
      "type": "checkbox",
      "id": "show_features",
      "label": "Show features",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "Premium quality materials"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Fast delivery across UAE"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Safe for kids and families"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#202025"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#54e8cc"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#54e8cc"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover",
      "default": "#12395e"
    }
  ],
  "presets": [
    {
      "name": "Product banner"
    }
  ]
}
{% endschema %}