{% doc %}
  @prompt
    2 ICON BOX AND URL LINK AND icon was abouts us and features 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-icon-box-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-icon-box-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-icon-box-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    text-align: {{ block.settings.alignment }};
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .ai-icon-box-item-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.hover_background_color }};
    border-color: {{ block.settings.hover_border_color }};
    transform: translateY(-{{ block.settings.hover_lift }}px);
  }

  .ai-icon-box-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-icon-box-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
    transition: fill 0.3s ease;
  }

  .ai-icon-box-item-{{ ai_gen_id }}:hover .ai-icon-box-icon-{{ ai_gen_id }} svg {
    fill: {{ block.settings.hover_icon_color }};
  }

  .ai-icon-box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    transition: color 0.3s ease;
  }

  .ai-icon-box-item-{{ ai_gen_id }}:hover .ai-icon-box-title-{{ ai_gen_id }} {
    color: {{ block.settings.hover_title_color }};
  }

  .ai-icon-box-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
    transition: color 0.3s ease;
  }

  .ai-icon-box-item-{{ ai_gen_id }}:hover .ai-icon-box-description-{{ ai_gen_id }} {
    color: {{ block.settings.hover_description_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-icon-box-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<icon-boxes-{{ ai_gen_id }}
  class="ai-icon-box-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-icon-box-wrapper-{{ ai_gen_id }}">
    <a
      href="{{ block.settings.box_1_url }}"
      class="ai-icon-box-item-{{ ai_gen_id }}"
    >
      <div class="ai-icon-box-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      {% if block.settings.box_1_title != blank %}
        <h3 class="ai-icon-box-title-{{ ai_gen_id }}">{{ block.settings.box_1_title }}</h3>
      {% endif %}
      {% if block.settings.box_1_description != blank %}
        <div class="ai-icon-box-description-{{ ai_gen_id }}">{{ block.settings.box_1_description }}</div>
      {% endif %}
    </a>

    <a
      href="{{ block.settings.box_2_url }}"
      class="ai-icon-box-item-{{ ai_gen_id }}"
    >
      <div class="ai-icon-box-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
        </svg>
      </div>
      {% if block.settings.box_2_title != blank %}
        <h3 class="ai-icon-box-title-{{ ai_gen_id }}">{{ block.settings.box_2_title }}</h3>
      {% endif %}
      {% if block.settings.box_2_description != blank %}
        <div class="ai-icon-box-description-{{ ai_gen_id }}">{{ block.settings.box_2_description }}</div>
      {% endif %}
    </a>
  </div>
</icon-boxes-{{ ai_gen_id }}>

<script>
  (function() {
    class IconBoxes{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('.ai-icon-box-item-{{ ai_gen_id }}');
        this.setupAccessibility();
      }

      setupAccessibility() {
        this.links.forEach((link) => {
          link.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              link.click();
            }
          });
        });
      }
    }

    customElements.define('icon-boxes-{{ ai_gen_id }}', IconBoxes{{ ai_gen_id }});
  })();
</script>

