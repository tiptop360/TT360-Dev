{% doc %}
  @prompt
    2 box title ane text link in the box and blod the words 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-two-boxes__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-two-boxes__box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-two-boxes__title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
  }

  .ai-two-boxes__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-two-boxes__link-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: {{ block.settings.link_weight }};
    transition: color 0.3s ease;
  }

  .ai-two-boxes__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-two-boxes__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<div class="ai-two-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-boxes__container-{{ ai_gen_id }}">
    <div class="ai-two-boxes__box-{{ ai_gen_id }}">
      {% if block.settings.box_1_title != blank %}
        <h3 class="ai-two-boxes__title-{{ ai_gen_id }}">{{ block.settings.box_1_title }}</h3>
      {% endif %}
      {% if block.settings.box_1_text != blank %}
        <div class="ai-two-boxes__text-{{ ai_gen_id }}">{{ block.settings.box_1_text }}</div>
      {% endif %}
      {% if block.settings.box_1_link_text != blank %}
        <a href="{{ block.settings.box_1_link_url }}" class="ai-two-boxes__link-{{ ai_gen_id }}">
          {{ block.settings.box_1_link_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-two-boxes__box-{{ ai_gen_id }}">
      {% if block.settings.box_2_title != blank %}
        <h3 class="ai-two-boxes__title-{{ ai_gen_id }}">{{ block.settings.box_2_title }}</h3>
      {% endif %}
      {% if block.settings.box_2_text != blank %}
        <div class="ai-two-boxes__text-{{ ai_gen_id }}">{{ block.settings.box_2_text }}</div>
      {% endif %}
      {% if block.settings.box_2_link_text != blank %}
        <a href="{{ block.settings.box_2_link_url }}" class="ai-two-boxes__link-{{ ai_gen_id }}">
          {{ block.settings.box_2_link_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

