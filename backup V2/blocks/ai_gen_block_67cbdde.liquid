{% doc %}
  @prompt
    export default function MagneticGymBagHero() {
      return (
        <section className="min-h-screen bg-gradient-to-r from-black via-slate-950 to-red-950 text-white flex items-center px-6 md:px-16">
          <div className="max-w-3xl space-y-8">
            <div className="inline-flex items-center rounded-full bg-white/10 px-5 py-2 text-sm font-semibold tracking-wide text-gray-200">
              🏋️ BEST GYM ACCESSORY UAE 2026
            </div>
    
            <div className="space-y-2 uppercase font-extrabold leading-none">
              <h1 className="text-5xl md:text-7xl text-gray-100">The Magnetic</h1>
              <h2 className="text-5xl md:text-7xl text-red-500">Gym Bag</h2>
              <h3 className="text-5xl md:text-7xl text-gray-100">Built for UAE Fitness</h3>
            </div>
    
            <p className="max-w-2xl text-lg md:text-2xl leading-relaxed text-gray-300">
              Attaches to any metal gym equipment — squat racks, benches, lockers,
              machines. Keep your phone, keys, and water bottle within arm’s reach,
              off the floor, every rep.
            </p>
    
            <div className="flex flex-wrap items-center gap-6 pt-4">
              <button className="rounded-2xl bg-red-500 px-8 py-5 text-lg font-bold shadow-2xl shadow-red-500/30 transition hover:scale-105">
                Shop the Gym Bag →
              </button>
    
              <button className="border-b border-gray-500 pb-2 text-lg font-semibold text-gray-300 transition hover:text-white">
                See all features ↓
              </button>
            </div>
          </div>
        </section>
      );
    }
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-magnetic-gym-hero-{{ ai_gen_id }} {
    display: block;
    min-height: 100vh;
    background: linear-gradient(to right, #000000, #0f172a, #450a0a);
    color: #ffffff;
    padding: 60px 24px;
    width: 100%;
  }

  .ai-magnetic-gym-hero__container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    min-height: calc(100vh - 120px);
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-magnetic-gym-hero__content-{{ ai_gen_id }} {
    max-width: 768px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .ai-magnetic-gym-hero__badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 20px;
    border-radius: 9999px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .ai-magnetic-gym-hero__headings-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-transform: uppercase;
    font-weight: 800;
    line-height: 1;
  }

  .ai-magnetic-gym-hero__heading-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_1_color }};
    margin: 0;
  }

  .ai-magnetic-gym-hero__heading-2-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_2_color }};
    margin: 0;
  }

  .ai-magnetic-gym-hero__heading-3-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_3_color }};
    margin: 0;
  }

  .ai-magnetic-gym-hero__description-{{ ai_gen_id }} {
    max-width: 672px;
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.description_color }};
  }

  .ai-magnetic-gym-hero__buttons-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
    padding-top: 16px;
  }

  .ai-magnetic-gym-hero__button-primary-{{ ai_gen_id }} {
    padding: 20px 32px;
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 700;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease;
    box-shadow: 0 20px 25px -5px rgba(239, 68, 68, 0.3);
  }

  .ai-magnetic-gym-hero__button-primary-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-magnetic-gym-hero__button-secondary-{{ ai_gen_id }} {
    padding-bottom: 8px;
    border: none;
    border-bottom: 1px solid {{ block.settings.secondary_button_border }};
    background: transparent;
    color: {{ block.settings.secondary_button_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: color 0.2s ease;
  }

  .ai-magnetic-gym-hero__button-secondary-{{ ai_gen_id }}:hover {
    color: #ffffff;
  }

  @media screen and (max-width: 768px) {
    .ai-magnetic-gym-hero-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-magnetic-gym-hero__container-{{ ai_gen_id }} {
      min-height: calc(100vh - 80px);
    }

    .ai-magnetic-gym-hero__heading-1-{{ ai_gen_id }},
    .ai-magnetic-gym-hero__heading-2-{{ ai_gen_id }},
    .ai-magnetic-gym-hero__heading-3-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-magnetic-gym-hero__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-magnetic-gym-hero__buttons-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<div class="ai-magnetic-gym-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-magnetic-gym-hero__container-{{ ai_gen_id }}">
    <div class="ai-magnetic-gym-hero__content-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <div class="ai-magnetic-gym-hero__badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      <div class="ai-magnetic-gym-hero__headings-{{ ai_gen_id }}">
        {% if block.settings.heading_1 != blank %}
          <h1 class="ai-magnetic-gym-hero__heading-1-{{ ai_gen_id }}">
            {{ block.settings.heading_1 }}
          </h1>
        {% endif %}

        {% if block.settings.heading_2 != blank %}
          <h2 class="ai-magnetic-gym-hero__heading-2-{{ ai_gen_id }}">
            {{ block.settings.heading_2 }}
          </h2>
        {% endif %}

        {% if block.settings.heading_3 != blank %}
          <h3 class="ai-magnetic-gym-hero__heading-3-{{ ai_gen_id }}">
            {{ block.settings.heading_3 }}
          </h3>
        {% endif %}
      </div>

      {% if block.settings.description != blank %}
        <p class="ai-magnetic-gym-hero__description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </p>
      {% endif %}

      <div class="ai-magnetic-gym-hero__buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_label != blank %}
          <a
            href="{{ block.settings.primary_button_link }}"
            class="ai-magnetic-gym-hero__button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.primary_button_label }}
          </a>
        {% endif %}

        {% if block.settings.secondary_button_label != blank %}
          <a
            href="{{ block.settings.secondary_button_link }}"
            class="ai-magnetic-gym-hero__button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.secondary_button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

