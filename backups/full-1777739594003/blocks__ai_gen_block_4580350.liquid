{% doc %}
  @prompt
    two box title and text point sectio will be in 
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-box-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-two-box-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.gap_between_boxes }}px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-two-box-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background_color }};
    padding: {{ block.settings.box_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-two-box-title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-two-box-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-two-box-text-{{ ai_gen_id }} ul {
    list-style: {{ block.settings.list_style }};
    padding-left: 20px;
    margin: 0;
  }

  .ai-two-box-text-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  @media screen and (max-width: 768px) {
    .ai-two-box-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-two-box-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-two-box-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ai-two-box-section-{{ ai_gen_id }} class="ai-two-box-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-box-container-{{ ai_gen_id }}">
    <div class="ai-two-box-item-{{ ai_gen_id }}">
      {% if block.settings.box_1_title != blank %}
        <h3 class="ai-two-box-title-{{ ai_gen_id }}">{{ block.settings.box_1_title }}</h3>
      {% endif %}
      {% if block.settings.box_1_text != blank %}
        <div class="ai-two-box-text-{{ ai_gen_id }}">
          {{ block.settings.box_1_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-two-box-item-{{ ai_gen_id }}">
      {% if block.settings.box_2_title != blank %}
        <h3 class="ai-two-box-title-{{ ai_gen_id }}">{{ block.settings.box_2_title }}</h3>
      {% endif %}
      {% if block.settings.box_2_text != blank %}
        <div class="ai-two-box-text-{{ ai_gen_id }}">
          {{ block.settings.box_2_text }}
        </div>
      {% endif %}
    </div>
  </div>
</ai-two-box-section-{{ ai_gen_id }}>

<script>
  (function() {
    class AiTwoBoxSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('ai-two-box-section-{{ ai_gen_id }}', AiTwoBoxSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
