{% doc %}
  @prompt
    image slider and in image url link opction will 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-image-slider__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.slider_height }}px;
  }

  .ai-image-slider__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-image-slider__slide-{{ ai_gen_id }} {
    min-width: 100%;
    height: 100%;
    position: relative;
    flex-shrink: 0;
  }

  .ai-image-slider__slide-{{ ai_gen_id }} a {
    display: block;
    width: 100%;
    height: 100%;
  }

  .ai-image-slider__slide-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-slider__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-slider__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-slider__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-slider__nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: {{ block.settings.nav_size }}px;
    height: {{ block.settings.nav_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s ease;
    opacity: {{ block.settings.nav_opacity }};
  }

  .ai-image-slider__nav-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-image-slider__nav--prev-{{ ai_gen_id }} {
    left: {{ block.settings.nav_offset }}px;
  }

  .ai-image-slider__nav--next-{{ ai_gen_id }} {
    right: {{ block.settings.nav_offset }}px;
  }

  .ai-image-slider__nav-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_size }}px * 0.5);
    height: calc({{ block.settings.nav_size }}px * 0.5);
  }

  .ai-image-slider__dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.dots_offset }}px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .ai-image-slider__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.5;
  }

  .ai-image-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-slider__container-{{ ai_gen_id }} {
      height: {{ block.settings.slider_height_mobile }}px;
    }

    .ai-image-slider__nav-{{ ai_gen_id }} {
      width: calc({{ block.settings.nav_size }}px * 0.8);
      height: calc({{ block.settings.nav_size }}px * 0.8);
    }

    .ai-image-slider__nav--prev-{{ ai_gen_id }} {
      left: calc({{ block.settings.nav_offset }}px * 0.5);
    }

    .ai-image-slider__nav--next-{{ ai_gen_id }} {
      right: calc({{ block.settings.nav_offset }}px * 0.5);
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }}
  class="ai-image-slider-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-slider__container-{{ ai_gen_id }}">
    <div class="ai-image-slider__slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign url_key = 'url_' | append: i
          assign image = block.settings[image_key]
          assign url = block.settings[url_key]
        %}

        {% if image != blank %}
          <div class="ai-image-slider__slide-{{ ai_gen_id }}" data-slide="{{ i }}">
            {% if url != blank %}
              <a href="{{ url }}">
                <img
                  src="{{ image | image_url: width: 2000 }}"
                  alt="{{ image.alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                >
              </a>
            {% else %}
              <img
                src="{{ image | image_url: width: 2000 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ image.width }}"
                height="{{ image.height }}"
              >
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}

      {% assign has_images = false %}
      {% for i in (1..5) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign image = block.settings[image_key]
        %}
        {% if image != blank %}
          {% assign has_images = true %}
          {% break %}
        {% endif %}
      {% endfor %}

      {% unless has_images %}
        <div class="ai-image-slider__slide-{{ ai_gen_id }}">
          <div class="ai-image-slider__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-slider__empty-state-{{ ai_gen_id }}">
              Add images to create your slider
            </div>
          </div>
        </div>
      {% endunless %}
    </div>

    {% if block.settings.show_arrows and has_images %}
      <button
        class="ai-image-slider__nav-{{ ai_gen_id }} ai-image-slider__nav--prev-{{ ai_gen_id }}"
        aria-label="Previous slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button
        class="ai-image-slider__nav-{{ ai_gen_id }} ai-image-slider__nav--next-{{ ai_gen_id }}"
        aria-label="Next slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots and has_images %}
      <div class="ai-image-slider__dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign image = block.settings[image_key]
          %}
          {% if image != blank %}
            <button
              class="ai-image-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide="{{ i }}"
              aria-label="Go to slide {{ i }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-image-slider__slides-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-image-slider__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-image-slider__nav--prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-image-slider__nav--next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-image-slider__dot-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        if (this.slides.length === 0) return;

        this.setupEventListeners();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            this.goToPrevSlide();
            this.resetAutoplay();
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            this.goToNextSlide();
            this.resetAutoplay();
          });
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            this.goToSlide(index);
            this.resetAutoplay();
          });
        });

        let touchStartX = 0;
        let touchEndX = 0;

        this.slidesContainer.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        });

        this.slidesContainer.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          this.handleSwipe(touchStartX, touchEndX);
        });
      }

      handleSwipe(startX, endX) {
        const swipeThreshold = 50;
        const diff = startX - endX;

        if (Math.abs(diff) > swipeThreshold) {
          if (diff > 0) {
            this.goToNextSlide();
          } else {
            this.goToPrevSlide();
          }
          this.resetAutoplay();
        }
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlider();
      }

      goToNextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlider();
      }

      goToPrevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlider();
      }

      updateSlider() {
        const offset = -this.currentSlide * 100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      resetAutoplay() {
        if (this.autoplay) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
  })();
</script>

