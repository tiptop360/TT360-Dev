    },
    {
      "type": "color",
      "id": "button_1_hover_bg_color",
      "label": "Hover background color",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_1_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
