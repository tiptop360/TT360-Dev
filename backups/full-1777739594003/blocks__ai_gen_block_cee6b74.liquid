{% doc %}
  @prompt
    click button 2 side url link with 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-button-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dual-button-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-dual-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
    text-transform: {{ block.settings.button_text_transform }};
  }

  .ai-dual-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_1_bg_color }};
    color: {{ block.settings.button_1_text_color }};
    border-color: {{ block.settings.button_1_bg_color }};
  }

  .ai-dual-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_1_hover_bg_color }};
    color: {{ block.settings.button_1_hover_text_color }};
    border-color: {{ block.settings.button_1_hover_bg_color }};
  }

  .ai-dual-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_2_bg_color }};
    color: {{ block.settings.button_2_text_color }};
    border-color: {{ block.settings.button_2_border_color }};
  }

  .ai-dual-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_2_hover_bg_color }};
    color: {{ block.settings.button_2_hover_text_color }};
    border-color: {{ block.settings.button_2_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-button-wrapper-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
    }

    {% if block.settings.mobile_layout == 'column' %}
      .ai-dual-button-{{ ai_gen_id }} {
        width: 100%;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-dual-button-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-button-wrapper-{{ ai_gen_id }}">
    {% if block.settings.button_1_text != blank %}
      <a
        href="{{ block.settings.button_1_link }}"
        class="ai-dual-button-{{ ai_gen_id }} ai-dual-button-primary-{{ ai_gen_id }}"
      >
        {{ block.settings.button_1_text }}
      </a>
    {% endif %}

    {% if block.settings.button_2_text != blank %}
      <a
        href="{{ block.settings.button_2_link }}"
        class="ai-dual-button-{{ ai_gen_id }} ai-dual-button-secondary-{{ ai_gen_id }}"
      >
        {{ block.settings.button_2_text }}
      </a>
    {% endif %}
  </div>
</div>

