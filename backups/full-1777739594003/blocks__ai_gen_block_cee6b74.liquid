      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_2_hover_bg_color",
      "label": "Hover background color",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_2_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
