{% doc %}
  @prompt
    Animated smoke particles — soft radial clouds drifting upward in purple and blue hues
    Floating bubbles — iridescent spheres with radial gradients in purple, cyan, pink, green, and amber that rise, drift, and fade naturally
    Gradient headline — a shimmer animation cycling across the product name
    CTA buttons — primary gradient button with glow + ghost secondary
    Stats row — key specs (500+ bubbles/min, 8hrs runtime, RGB LEDs) with subtle dividers
    Fully mobile responsive — font sizes scale with clamp() and the layout stacks cleanly on small screens
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-smoke-bubble-hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background: linear-gradient(135deg, {{ block.settings.bg_color_start }}, {{ block.settings.bg_color_end }});
    padding: clamp(60px, 10vw, 120px) 20px;
    overflow: hidden;
    display: block;
  }

  .ai-smoke-bubble-hero__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .ai-smoke-bubble-hero__canvas-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .ai-smoke-bubble-hero__headline-{{ ai_gen_id }} {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 700;
    margin: 0 0 clamp(1rem, 2vw, 1.5rem);
    background: linear-gradient(90deg, 
      {{ block.settings.gradient_color_1 }} 0%, 
      {{ block.settings.gradient_color_2 }} 25%, 
      {{ block.settings.gradient_color_3 }} 50%, 
      {{ block.settings.gradient_color_2 }} 75%, 
      {{ block.settings.gradient_color_1 }} 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: ai-smoke-bubble-shimmer-{{ ai_gen_id }} 3s linear infinite;
  }

  @keyframes ai-smoke-bubble-shimmer-{{ ai_gen_id }} {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  .ai-smoke-bubble-hero__description-{{ ai_gen_id }} {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: {{ block.settings.description_color }};
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-smoke-bubble-hero__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .ai-smoke-bubble-hero__btn-primary-{{ ai_gen_id }} {
    padding: clamp(12px, 2vw, 16px) clamp(24px, 4vw, 40px);
    background: linear-gradient(135deg, {{ block.settings.btn_primary_start }}, {{ block.settings.btn_primary_end }});
    color: {{ block.settings.btn_primary_color }};
    border: none;
    border-radius: {{ block.settings.btn_border_radius }}px;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 0 20px rgba(138, 43, 226, 0.4);
    display: inline-block;
  }

  .ai-smoke-bubble-hero__btn-primary-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(138, 43, 226, 0.6);
  }

  .ai-smoke-bubble-hero__btn-secondary-{{ ai_gen_id }} {
    padding: clamp(12px, 2vw, 16px) clamp(24px, 4vw, 40px);
    background: transparent;
    color: {{ block.settings.btn_secondary_color }};
    border: 2px solid {{ block.settings.btn_secondary_border }};
    border-radius: {{ block.settings.btn_border_radius }}px;
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-smoke-bubble-hero__btn-secondary-{{ ai_gen_id }}:hover {
    background: {{ block.settings.btn_secondary_border }};
    color: {{ block.settings.bg_color_start }};
  }

  .ai-smoke-bubble-hero__stats-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    flex-wrap: wrap;
  }

  .ai-smoke-bubble-hero__stat-{{ ai_gen_id }} {
    position: relative;
    padding: 0 clamp(1rem, 2vw, 1.5rem);
  }

  .ai-smoke-bubble-hero__stat-{{ ai_gen_id }}:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
    height: 60%;
    background: {{ block.settings.stat_divider_color }};
    opacity: 0.3;
  }

  .ai-smoke-bubble-hero__stat-value-{{ ai_gen_id }} {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: {{ block.settings.stat_value_color }};
    display: block;
    margin-bottom: 0.25rem;
  }

  .ai-smoke-bubble-hero__stat-label-{{ ai_gen_id }} {
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    color: {{ block.settings.stat_label_color }};
    opacity: 0.8;
  }

  @media screen and (max-width: 768px) {
    .ai-smoke-bubble-hero__stat-{{ ai_gen_id }}:not(:last-child)::after {
      display: none;
    }
  }
{% endstyle %}

<smoke-bubble-hero-{{ ai_gen_id }} class="ai-smoke-bubble-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <canvas class="ai-smoke-bubble-hero__canvas-{{ ai_gen_id }}"></canvas>
  
  <div class="ai-smoke-bubble-hero__container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-smoke-bubble-hero__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <p class="ai-smoke-bubble-hero__description-{{ ai_gen_id }}">{{ block.settings.description }}</p>
    {% endif %}

    <div class="ai-smoke-bubble-hero__buttons-{{ ai_gen_id }}">
      {% if block.settings.btn_primary_label != blank %}
        <a href="{{ block.settings.btn_primary_link }}" class="ai-smoke-bubble-hero__btn-primary-{{ ai_gen_id }}">
          {{ block.settings.btn_primary_label }}
        </a>
      {% endif %}

      {% if block.settings.btn_secondary_label != blank %}
        <a href="{{ block.settings.btn_secondary_link }}" class="ai-smoke-bubble-hero__btn-secondary-{{ ai_gen_id }}">
          {{ block.settings.btn_secondary_label }}
        </a>
      {% endif %}
    </div>

    {% if block.settings.show_stats %}
      <div class="ai-smoke-bubble-hero__stats-{{ ai_gen_id }}">
        <div class="ai-smoke-bubble-hero__stat-{{ ai_gen_id }}">
          <span class="ai-smoke-bubble-hero__stat-value-{{ ai_gen_id }}">{{ block.settings.stat_1_value }}</span>
          <span class="ai-smoke-bubble-hero__stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</span>
        </div>
        <div class="ai-smoke-bubble-hero__stat-{{ ai_gen_id }}">
          <span class="ai-smoke-bubble-hero__stat-value-{{ ai_gen_id }}">{{ block.settings.stat_2_value }}</span>
          <span class="ai-smoke-bubble-hero__stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</span>
        </div>
        <div class="ai-smoke-bubble-hero__stat-{{ ai_gen_id }}">
          <span class="ai-smoke-bubble-hero__stat-value-{{ ai_gen_id }}">{{ block.settings.stat_3_value }}</span>
          <span class="ai-smoke-bubble-hero__stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</span>
        </div>
      </div>
    {% endif %}
  </div>
</smoke-bubble-hero-{{ ai_gen_id }}>

<script>
(function() {
  class SmokeBubbleHero{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.canvas = this.querySelector('.ai-smoke-bubble-hero__canvas-{{ ai_gen_id }}');
      this.ctx = this.canvas.getContext('2d');
      this.particles = [];
      this.bubbles = [];
      this.animationId = null;
    }

    connectedCallback() {
      this.setupCanvas();
      this.createParticles();
      this.createBubbles();
      this.animate();
      window.addEventListener('resize', this.handleResize.bind(this));
    }

    disconnectedCallback() {
      if (this.animationId) {
        cancelAnimationFrame(this.animationId);
      }
      window.removeEventListener('resize', this.handleResize.bind(this));
    }

    handleResize() {
      this.setupCanvas();
    }

    setupCanvas() {
      this.canvas.width = this.canvas.offsetWidth;
      this.canvas.height = this.canvas.offsetHeight;
    }

    createParticles() {
      const particleCount = 15;
      for (let i = 0; i < particleCount; i++) {
        this.particles.push({
          x: Math.random() * this.canvas.width,
          y: this.canvas.height + Math.random() * 200,
          radius: Math.random() * 60 + 40,
          speedY: Math.random() * 0.5 + 0.3,
          speedX: (Math.random() - 0.5) * 0.3,
          opacity: Math.random() * 0.3 + 0.1,
          color: Math.random() > 0.5 ? '138, 43, 226' : '75, 0, 130'
        });
      }
    }

    createBubbles() {
      const bubbleCount = 20;
      const colors = [
        { r: 138, g: 43, b: 226 },
        { r: 0, g: 255, b: 255 },
        { r: 255, g: 20, b: 147 },
        { r: 50, g: 205, b: 50 },
        { r: 255, g: 191, b: 0 }
      ];

      for (let i = 0; i < bubbleCount; i++) {
        const color = colors[Math.floor(Math.random() * colors.length)];
        this.bubbles.push({
          x: Math.random() * this.canvas.width,
          y: this.canvas.height + Math.random() * 100,
          radius: Math.random() * 15 + 8,
          speedY: Math.random() * 1 + 0.5,
          speedX: (Math.random() - 0.5) * 0.5,
          opacity: 1,
          color: color,
          life: 1
        });
      }
    }

    drawParticle(particle) {
      const gradient = this.ctx.createRadialGradient(
        particle.x, particle.y, 0,
        particle.x, particle.y, particle.radius
      );
      gradient.addColorStop(0, `rgba(${particle.color}, ${particle.opacity})`);
      gradient.addColorStop(0.5, `rgba(${particle.color}, ${particle.opacity * 0.5})`);
      gradient.addColorStop(1, `rgba(${particle.color}, 0)`);

      this.ctx.fillStyle = gradient;
      this.ctx.beginPath();
      this.ctx.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
      this.ctx.fill();
    }

    drawBubble(bubble) {
      const gradient = this.ctx.createRadialGradient(
        bubble.x - bubble.radius * 0.3,
        bubble.y - bubble.radius * 0.3,
        0,
        bubble.x,
        bubble.y,
        bubble.radius
      );

      gradient.addColorStop(0, `rgba(255, 255, 255, ${bubble.opacity * 0.8})`);
      gradient.addColorStop(0.3, `rgba(${bubble.color.r}, ${bubble.color.g}, ${bubble.color.b}, ${bubble.opacity * 0.6})`);
      gradient.addColorStop(0.7, `rgba(${bubble.color.r}, ${bubble.color.g}, ${bubble.color.b}, ${bubble.opacity * 0.3})`);
      gradient.addColorStop(1, `rgba(${bubble.color.r}, ${bubble.color.g}, ${bubble.color.b}, 0)`);

      this.ctx.fillStyle = gradient;
      this.ctx.beginPath();
      this.ctx.arc(bubble.x, bubble.y, bubble.radius, 0, Math.PI * 2);
      this.ctx.fill();

      this.ctx.strokeStyle = `rgba(255, 255, 255, ${bubble.opacity * 0.5})`;
      this.ctx.lineWidth = 2;
      this.ctx.stroke();
    }

    animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);

      this.particles.forEach((particle, index) => {
        particle.y -= particle.speedY;
        particle.x += particle.speedX;

        if (particle.y + particle.radius < 0) {
          particle.y = this.canvas.height + particle.radius;
          particle.x = Math.random() * this.canvas.width;
        }

        if (particle.x < -particle.radius) {
          particle.x = this.canvas.width + particle.radius;
        } else if (particle.x > this.canvas.width + particle.radius) {
          particle.x = -particle.radius;
        }

        this.drawParticle(particle);
      });

      this.bubbles.forEach((bubble, index) => {
        bubble.y -= bubble.speedY;
        bubble.x += bubble.speedX;
        bubble.life -= 0.003;
        bubble.opacity = bubble.life;

        if (bubble.life <= 0 || bubble.y + bubble.radius < 0) {
          bubble.y = this.canvas.height + Math.random() * 50;
          bubble.x = Math.random() * this.canvas.width;
          bubble.life = 1;
          bubble.opacity = 1;
        }

        if (bubble.x < -bubble.radius) {
          bubble.x = this.canvas.width + bubble.radius;
        } else if (bubble.x > this.canvas.width + bubble.radius) {
          bubble.x = -bubble.radius;
        }

        this.drawBubble(bubble);
      });

      this.animationId = requestAnimationFrame(this.animate.bind(this));
    }
  }

  customElements.define('smoke-bubble-hero-{{ ai_gen_id }}', SmokeBubbleHero{{ ai_gen_id }});
})();
</script>

