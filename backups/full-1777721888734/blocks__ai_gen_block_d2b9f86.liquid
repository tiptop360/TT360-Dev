{% doc %}
  @prompt
    4  box title and text 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-four-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-four-boxes__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
  }

  .ai-four-boxes__box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background }};
    padding: {{ block.settings.box_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    transition: transform 0.3s ease;
  }

  {% if block.settings.enable_hover %}
    .ai-four-boxes__box-{{ ai_gen_id }}:hover {
      transform: translateY(-5px);
    }
  {% endif %}

  .ai-four-boxes__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    font-weight: 500;
  }

  .ai-four-boxes__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-four-boxes__container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-four-boxes__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-four-boxes__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-four-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-four-boxes__container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign title_key = 'box_' | append: i | append: '_title'
        assign text_key = 'box_' | append: i | append: '_text'
        assign box_title = block.settings[title_key]
        assign box_text = block.settings[text_key]
      %}
      
      <div class="ai-four-boxes__box-{{ ai_gen_id }}">
        {% if box_title != blank %}
          <h3 class="ai-four-boxes__title-{{ ai_gen_id }}">{{ box_title }}</h3>
        {% endif %}
        {% if box_text != blank %}
          <div class="ai-four-boxes__text-{{ ai_gen_id }}">{{ box_text }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

