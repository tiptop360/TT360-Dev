{% doc %}
  @prompt
    A heading with an animated glowing effect, The header should include animation xmas style like snow flaes falling and some christmas ambient 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-xmas-heading-{{ ai_gen_id }} {
    position: relative;
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-xmas-heading__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
  }

  .ai-xmas-heading__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    display: inline-block;
    text-transform: {{ block.settings.text_transform }};
    font-weight: {{ block.settings.font_weight }};
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
  }

  .ai-xmas-heading__subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin-top: 12px;
  }

  .ai-xmas-heading__snowflakes-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .ai-xmas-heading__snowflake-{{ ai_gen_id }} {
    position: absolute;
    top: -10px;
    color: {{ block.settings.snowflake_color }};
    font-size: 14px;
    opacity: 0.8;
    user-select: none;
  }

  @keyframes ai-xmas-snowfall-{{ ai_gen_id }} {
    0% {
      transform: translateY(0) rotate(0deg);
      opacity: 0;
    }
    10% {
      opacity: 0.8;
    }
    90% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(100vh) rotate(360deg);
      opacity: 0;
    }
  }

  .ai-xmas-heading__ornament-{{ ai_gen_id }} {
    position: absolute;
    font-size: 24px;
    opacity: 0.6;
    z-index: 1;
  }

  .ai-xmas-heading__ornament-left-{{ ai_gen_id }} {
    left: 5%;
    top: 50%;
    transform: translateY(-50%);
  }

  .ai-xmas-heading__ornament-right-{{ ai_gen_id }} {
    right: 5%;
    top: 50%;
    transform: translateY(-50%);
  }

  @keyframes ai-xmas-swing-{{ ai_gen_id }} {
    0%, 100% {
      transform: translateY(-50%) rotate(-5deg);
    }
    50% {
      transform: translateY(-50%) rotate(5deg);
    }
  }

  .ai-xmas-heading__ornament-{{ ai_gen_id }} {
    animation: ai-xmas-swing-{{ ai_gen_id }} 3s ease-in-out infinite;
  }

  @media screen and (max-width: 749px) {
    .ai-xmas-heading__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-xmas-heading__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.8 }}px;
    }

    .ai-xmas-heading__ornament-{{ ai_gen_id }} {
      font-size: 18px;
    }
  }
{% endstyle %}

<div class="ai-xmas-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-xmas-heading__snowflakes-{{ ai_gen_id }}"></div>

  {% if block.settings.show_ornaments %}
    <div class="ai-xmas-heading__ornament-{{ ai_gen_id }} ai-xmas-heading__ornament-left-{{ ai_gen_id }}">
      🎄
    </div>
    <div class="ai-xmas-heading__ornament-{{ ai_gen_id }} ai-xmas-heading__ornament-right-{{ ai_gen_id }}">
      🎄
    </div>
  {% endif %}

  <div class="ai-xmas-heading__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-xmas-heading__text-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% else %}
      <h2 class="ai-xmas-heading__text-{{ ai_gen_id }}">
        Merry Christmas
      </h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <div class="ai-xmas-heading__subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </div>
    {% endif %}
  </div>
</div>

<script>
  (function() {
    class XmasHeading{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.snowflakeCount = {{ block.settings.snowflake_count }};
        this.snowflakes = ['❄', '❅', '❆'];
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-xmas-heading__snowflakes-{{ ai_gen_id }}');
        if (this.container) {
          this.createSnowflakes();
        }
      }

      createSnowflakes() {
        for (let i = 0; i < this.snowflakeCount; i++) {
          setTimeout(() => {
            this.createSnowflake();
          }, i * {{ block.settings.snowflake_delay }});
        }

        setInterval(() => {
          this.createSnowflake();
        }, {{ block.settings.snowflake_interval }});
      }

      createSnowflake() {
        const snowflake = document.createElement('div');
        snowflake.className = 'ai-xmas-heading__snowflake-{{ ai_gen_id }}';
        snowflake.textContent = this.snowflakes[Math.floor(Math.random() * this.snowflakes.length)];
        snowflake.style.left = Math.random() * 100 + '%';
        snowflake.style.fontSize = (Math.random() * 10 + 10) + 'px';
        
        const duration = Math.random() * 3 + {{ block.settings.snowflake_speed }};
        const delay = Math.random() * 2;
        
        snowflake.style.animation = `ai-xmas-snowfall-{{ ai_gen_id }} ${duration}s linear ${delay}s infinite`;
        
        this.container.appendChild(snowflake);

        setTimeout(() => {
          if (this.container.children.length > this.snowflakeCount * 2) {
            this.container.removeChild(this.container.firstChild);
          }
        }, (duration + delay) * 1000);
      }
    }

    customElements.define('xmas-heading-{{ ai_gen_id }}', XmasHeading{{ ai_gen_id }});
  })();
</script>

<xmas-heading-{{ ai_gen_id }}>
  <style>
    xmas-heading-{{ ai_gen_id }} {
      display: block;
    }
  </style>
</xmas-heading-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Christmas heading",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "default": "Merry Christmas"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 60
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#d4af37"
    },
    {
      "type": "header",
      "content": "Subtext"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Subtext size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#165b33"
    },
    {
      "type": "header",
      "content": "Snowflakes"
    },
    {
      "type": "color",
      "id": "snowflake_color",
      "label": "Snowflake color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "snowflake_count",
      "min": 10,
      "max": 50,
      "step": 5,
      "label": "Initial count",
      "default": 30
    },
    {
      "type": "range",
      "id": "snowflake_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Fall speed",
      "default": 5
    },
    {
      "type": "range",
      "id": "snowflake_delay",
      "min": 50,
      "max": 200,
      "step": 10,
      "unit": "ms",
      "label": "Delay between",
      "default": 100
    },
    {
      "type": "range",
      "id": "snowflake_interval",
      "min": 500,
      "max": 3000,
      "step": 100,
      "unit": "ms",
