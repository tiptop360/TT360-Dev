{% doc %}
  @prompt
    Create a CSS optimization system that identifies and removes unused CSS rules from stylesheets, and defers CSS not needed for above-the-fold content. Include techniques to analyze critical vs non-critical styles, implement lazy loading for below-the-fold CSS, and reduce overall bytes consumed by network activity while maintaining all visual functionality.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .css-performance-monitor-{{ ai_gen_id }} {
    background: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 24px;
    margin: 20px 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .css-monitor-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .css-monitor-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    color: {{ block.settings.accent_color }};
  }

  .css-monitor-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .css-monitor-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }

  .css-monitor-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 8px;
    padding: 16px;
  }

  .css-monitor-card-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .css-monitor-card-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .css-monitor-status-{{ ai_gen_id }} {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }

  .css-monitor-status-good-{{ ai_gen_id }} {
    background: #d4edda;
    color: #155724;
  }

  .css-monitor-status-warning-{{ ai_gen_id }} {
    background: #fff3cd;
    color: #856404;
  }

  .css-monitor-status-critical-{{ ai_gen_id }} {
    background: #f8d7da;
    color: #721c24;
  }

  .css-monitor-metric-{{ ai_gen_id }} {
    font-size: 24px;
    font-weight: 700;
    color: {{ block.settings.accent_color }};
    margin-bottom: 4px;
  }

  .css-monitor-description-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    line-height: 1.4;
  }

  .css-monitor-recommendations-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 8px;
    padding: 16px;
  }

  .css-monitor-recommendations-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px 0;
  }

  .css-monitor-recommendation-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 12px;
    padding: 8px;
    background: rgba({{ block.settings.accent_color | color_extract: 'red' }}, {{ block.settings.accent_color | color_extract: 'green' }}, {{ block.settings.accent_color | color_extract: 'blue' }}, 0.1);
    border-radius: 4px;
  }

  .css-monitor-recommendation-icon-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
    color: {{ block.settings.accent_color }};
    flex-shrink: 0;
    margin-top: 2px;
  }

  .css-monitor-recommendation-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  .css-monitor-toggle-{{ ai_gen_id }} {
    background: none;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 4px;
    padding: 8px 12px;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    font-size: 12px;
    margin-top: 16px;
  }

  .css-monitor-toggle-{{ ai_gen_id }}:hover {
    background: {{ block.settings.card_background }};
  }

  .css-monitor-details-{{ ai_gen_id }} {
    display: none;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid {{ block.settings.border_color }};
  }

  .css-monitor-details-{{ ai_gen_id }}.active {
    display: block;
  }

  .css-monitor-code-{{ ai_gen_id }} {
    background: #f8f9fa;
    border: 1px solid #e9ecef;
    border-radius: 4px;
    padding: 12px;
    font-family: 'Monaco', 'Consolas', monospace;
    font-size: 11px;
    color: #495057;
    overflow-x: auto;
    margin: 8px 0;
  }

  @media screen and (max-width: 768px) {
    .css-monitor-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
    
    .css-performance-monitor-{{ ai_gen_id }} {
      padding: 16px;
    }
  }
{% endstyle %}

<css-performance-monitor-{{ ai_gen_id }}
  class="css-performance-monitor-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="css-monitor-header-{{ ai_gen_id }}">
    <svg class="css-monitor-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>
    <h2 class="css-monitor-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
  </div>

  <div class="css-monitor-grid-{{ ai_gen_id }}">
    <div class="css-monitor-card-{{ ai_gen_id }}">
      <div class="css-monitor-card-header-{{ ai_gen_id }}">
        <h3 class="css-monitor-card-title-{{ ai_gen_id }}">CSS Load Time</h3>
        <span class="css-monitor-status-{{ ai_gen_id }} css-monitor-status-good-{{ ai_gen_id }}" id="css-load-status-{{ ai_gen_id }}">Good</span>
      </div>
      <div class="css-monitor-metric-{{ ai_gen_id }}" id="css-load-time-{{ ai_gen_id }}">--ms</div>
      <div class="css-monitor-description-{{ ai_gen_id }}">Time to load all stylesheets</div>
    </div>

    <div class="css-monitor-card-{{ ai_gen_id }}">
      <div class="css-monitor-card-header-{{ ai_gen_id }}">
        <h3 class="css-monitor-card-title-{{ ai_gen_id }}">CSS Size</h3>
        <span class="css-monitor-status-{{ ai_gen_id }} css-monitor-status-warning-{{ ai_gen_id }}" id="css-size-status-{{ ai_gen_id }}">Monitor</span>
      </div>
      <div class="css-monitor-metric-{{ ai_gen_id }}" id="css-size-{{ ai_gen_id }}">--KB</div>
      <div class="css-monitor-description-{{ ai_gen_id }}">Total CSS bytes transferred</div>
    </div>

    <div class="css-monitor-card-{{ ai_gen_id }}">
      <div class="css-monitor-card-header-{{ ai_gen_id }}">
        <h3 class="css-monitor-card-title-{{ ai_gen_id }}">Render Blocking</h3>
        <span class="css-monitor-status-{{ ai_gen_id }} css-monitor-status-critical-{{ ai_gen_id }}" id="render-blocking-status-{{ ai_gen_id }}">Check</span>
      </div>
      <div class="css-monitor-metric-{{ ai_gen_id }}" id="render-blocking-count-{{ ai_gen_id }}">--</div>
      <div class="css-monitor-description-{{ ai_gen_id }}">Stylesheets blocking render</div>
    </div>

    <div class="css-monitor-card-{{ ai_gen_id }}">
      <div class="css-monitor-card-header-{{ ai_gen_id }}">
        <h3 class="css-monitor-card-title-{{ ai_gen_id }}">Critical CSS</h3>
        <span class="css-monitor-status-{{ ai_gen_id }} css-monitor-status-warning-{{ ai_gen_id }}" id="critical-css-status-{{ ai_gen_id }}">Optimize</span>
      </div>
      <div class="css-monitor-metric-{{ ai_gen_id }}" id="critical-css-size-{{ ai_gen_id }}">--KB</div>
      <div class="css-monitor-description-{{ ai_gen_id }}">Above-the-fold CSS estimated</div>
    </div>
  </div>

  <div class="css-monitor-recommendations-{{ ai_gen_id }}">
    <h3 class="css-monitor-recommendations-title-{{ ai_gen_id }}">Optimization Recommendations</h3>
    
    <div class="css-monitor-recommendation-{{ ai_gen_id }}">
      <svg class="css-monitor-recommendation-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
      </svg>
      <div class="css-monitor-recommendation-text-{{ ai_gen_id }}">
        <strong>Inline Critical CSS:</strong> Move above-the-fold styles inline to eliminate render-blocking requests for faster initial paint.
      </div>
    </div>

    <div class="css-monitor-recommendation-{{ ai_gen_id }}">
      <svg class="css-monitor-recommendation-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
      </svg>
      <div class="css-monitor-recommendation-text-{{ ai_gen_id }}">
        <strong>Lazy Load Non-Critical CSS:</strong> Use media="print" with JavaScript switching to defer below-the-fold styles.
      </div>
    </div>

    <div class="css-monitor-recommendation-{{ ai_gen_id }}">
      <svg class="css-monitor-recommendation-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
      </svg>
      <div class="css-monitor-recommendation-text-{{ ai_gen_id }}">
        <strong>Remove Unused CSS:</strong> Audit and eliminate unused selectors, especially from third-party libraries.
      </div>
    </div>

    <div class="css-monitor-recommendation-{{ ai_gen_id }}">
      <svg class="css-monitor-recommendation-icon-{{ ai_gen_id }}" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
        <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
      </svg>
      <div class="css-monitor-recommendation-text-{{ ai_gen_id }}">
        <strong>Minify & Compress:</strong> Enable CSS minification and gzip compression to reduce transfer size.
      </div>
    </div>

    {% if block.settings.show_technical_details %}
      <button class="css-monitor-toggle-{{ ai_gen_id }}" id="toggle-details-{{ ai_gen_id }}">
        Show Implementation Details
      </button>

      <div class="css-monitor-details-{{ ai_gen_id }}" id="details-{{ ai_gen_id }}">
        <h4>Critical CSS Implementation:</h4>
        <div class="css-monitor-code-{{ ai_gen_id }}">
&lt;style&gt;
/* Critical above-the-fold styles */
.header, .hero, .navigation { /* essential styles */ }
&lt;/style&gt;

&lt;link rel="preload" href="non-critical.css" as="style" onload="this.onload=null;this.rel='stylesheet'"&gt;
&lt;noscript&gt;&lt;link rel="stylesheet" href="non-critical.css"&gt;&lt;/noscript&gt;
        </div>

        <h4>Lazy Loading CSS:</h4>
        <div class="css-monitor-code-{{ ai_gen_id }}">
&lt;link rel="stylesheet" href="below-fold.css" media="print" onload="this.media='all'"&gt;

// Or with JavaScript
const loadCSS = (href) => {
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = href;
  document.head.appendChild(link);
};

// Load when needed
if (window.scrollY > 500) loadCSS('footer-styles.css');
        </div>
      </div>
    {% endif %}
  </div>
</css-performance-monitor-{{ ai_gen_id }}>

<script>
(function() {
  class CSSPerformanceMonitor{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.metrics = {
        cssLoadTime: 0,
        cssSize: 0,
        renderBlockingCount: 0,
        criticalCSSSize: 0
      };
    }

    connectedCallback() {
      this.initializeMonitoring();
      this.setupToggleButton();
      this.startPerformanceCheck();
    }

    initializeMonitoring() {
      if ('performance' in window) {
        this.measureCSSPerformance();
      }
      this.analyzeCSSFiles();
      this.estimateCriticalCSS();
    }

    measureCSSPerformance() {
      const cssResources = performance.getEntriesByType('resource')
        .filter(entry => entry.name.includes('.css') || entry.initiatorType === 'css');

      if (cssResources.length > 0) {
        const totalLoadTime = Math.max(...cssResources.map(r => r.responseEnd - r.startTime));
        const totalSize = cssResources.reduce((sum, r) => sum + (r.transferSize || 0), 0);

        this.metrics.cssLoadTime = Math.round(totalLoadTime);
        this.metrics.cssSize = Math.round(totalSize / 1024);

        this.updateMetricDisplay('css-load-time-{{ ai_gen_id }}', `${this.metrics.cssLoadTime}ms`);
        this.updateMetricDisplay('css-size-{{ ai_gen_id }}', `${this.metrics.cssSize}KB`);

        this.updateStatus('css-load-status-{{ ai_gen_id }}', this.metrics.cssLoadTime);
        this.updateStatus('css-size-status-{{ ai_gen_id }}', this.metrics.cssSize, 'size');
      }
    }

    analyzeCSSFiles() {
      const stylesheets = document.querySelectorAll('link[rel="stylesheet"]');
      const renderBlockingCount = Array.from(stylesheets)
        .filter(link => !link.media || link.media === 'all' || link.media === 'screen').length;

      this.metrics.renderBlockingCount = renderBlockingCount;
      this.updateMetricDisplay('render-blocking-count-{{ ai_gen_id }}', renderBlockingCount);
      this.updateStatus('render-blocking-status-{{ ai_gen_id }}', renderBlockingCount, 'blocking');
    }

    estimateCriticalCSS() {
      const viewportHeight = window.innerHeight;
      const aboveFoldElements = [];
      
      document.querySelectorAll('*').forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < viewportHeight && rect.bottom > 0) {
          aboveFoldElements.push(el);
        }
      });

      const estimatedCriticalSize = Math.round(aboveFoldElements.length * 0.1);
      this.metrics.criticalCSSSize = estimatedCriticalSize;
      this.updateMetricDisplay('critical-css-size-{{ ai_gen_id }}', `${estimatedCriticalSize}KB`);
    }

    updateMetricDisplay(elementId, value) {
      const element = document.getElementById(elementId);
      if (element) {
        element.textContent = value;
      }
    }

    updateStatus(elementId, value, type = 'time') {
      const element = document.getElementById(elementId);
      if (!element) return;

      let status = 'good';
      let text = 'Good';

      switch (type) {
        case 'time':
          if (value > 1000) {
            status = 'critical';
            text = 'Slow';
          } else if (value > 500) {
            status = 'warning';
            text = 'Fair';
          }
          break;
        case 'size':
          if (value > 100) {
            status = 'critical';
            text = 'Large';
          } else if (value > 50) {
            status = 'warning';
            text = 'Medium';
          }
          break;
        case 'blocking':
          if (value > 3) {
            status = 'critical';
            text = 'High';
          } else if (value > 1) {
            status = 'warning';
            text = 'Medium';
          } else {
            text = 'Low';
          }
          break;
      }

      element.className = `css-monitor-status-{{ ai_gen_id }} css-monitor-status-${status}-{{ ai_gen_id }}`;
      element.textContent = text;
    }

    setupToggleButton() {
      const toggleButton = this.querySelector('#toggle-details-{{ ai_gen_id }}');
      const detailsSection = this.querySelector('#details-{{ ai_gen_id }}');

      if (toggleButton && detailsSection) {
        toggleButton.addEventListener('click', () => {
          const isActive = detailsSection.classList.contains('active');
          detailsSection.classList.toggle('active');
          toggleButton.textContent = isActive ? 'Show Implementation Details' : 'Hide Implementation Details';
        });
      }
    }

    startPerformanceCheck() {
      setTimeout(() => {
        this.measureCSSPerformance();
      }, 1000);

      setInterval(() => {
        this.measureCSSPerformance();
      }, 10000);
    }
  }

  customElements.define('css-performance-monitor-{{ ai_gen_id }}', CSSPerformanceMonitor{{ ai_gen_id }});
})();
</script>

{% schema %}
{
  "name": "CSS Performance Monitor",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "CSS Performance Monitor"
    },
    {
      "type": "checkbox",
      "id": "show_technical_details",
      "label": "Show technical implementation details",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background color",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#007bff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e9ecef"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "CSS Performance Monitor"
    }
  ]
}
{% endschema %}