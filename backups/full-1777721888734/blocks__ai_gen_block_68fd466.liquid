{% doc %}
  @prompt
    title and description and 4 box no icon in that 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-boxes-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-feature-boxes__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-feature-boxes__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-feature-boxes__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px 0;
    font-weight: 500;
  }

  .ai-feature-boxes__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  .ai-feature-boxes__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.box_spacing }}px;
  }

  .ai-feature-boxes__box-{{ ai_gen_id }} {
    background-color: {{ block.settings.box_background }};
    padding: {{ block.settings.box_padding }}px;
    border-radius: {{ block.settings.box_border_radius }}px;
    border: {{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color }};
    text-align: {{ block.settings.box_text_alignment }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-feature-boxes__box-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .ai-feature-boxes__box-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_title_size }}px;
    color: {{ block.settings.box_title_color }};
    margin: 0 0 12px 0;
    font-weight: 500;
  }

  .ai-feature-boxes__box-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.box_text_size }}px;
    color: {{ block.settings.box_text_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 768px) {
    .ai-feature-boxes__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-feature-boxes__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-feature-boxes__box-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.box_title_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-feature-boxes-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-boxes__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.description != blank %}
      <div class="ai-feature-boxes__header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-feature-boxes__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.description != blank %}
          <div class="ai-feature-boxes__description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-feature-boxes__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign box_title_key = 'box_' | append: i | append: '_title'
          assign box_text_key = 'box_' | append: i | append: '_text'
          assign box_title = block.settings[box_title_key]
          assign box_text = block.settings[box_text_key]
        %}

        <div class="ai-feature-boxes__box-{{ ai_gen_id }}">
          {% if box_title != blank %}
            <h3 class="ai-feature-boxes__box-title-{{ ai_gen_id }}">{{ box_title }}</h3>
          {% endif %}
          {% if box_text != blank %}
            <div class="ai-feature-boxes__box-text-{{ ai_gen_id }}">
              {{ box_text }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

