{% comment %}
File: sections/screenfree-banner-uae-2026.liquid
{% endcomment %}

<section class="screenfree-banner-uae-2026"
  style="
    background: url({{ section.settings.banner_image | image_url: width: 2000 }}) center/cover no-repeat;
  "
>
  <div class="banner-overlay"></div>

  <div class="banner-content">
    <h2>{{ section.settings.heading }}</h2>
  </div>
</section>

<style>
.screenfree-banner-uae-2026 {
  height: 420px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  text-align: center;
}

.screenfree-banner-uae-2026 .banner-overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, {{ section.settings.overlay_opacity }});
  top: 0;
  left: 0;
}

.screenfree-banner-uae-2026 .banner-content {
  position: relative;
  z-index: 2;
  padding: 0 20px;
}

.screenfree-banner-uae-2026 h1 {
  color: {{ section.settings.heading_color }};
  font-size: 40px;
  max-width: 900px;
  margin: auto;
}

@media(max-width:768px){
  .screenfree-banner-uae-2026 {
    height: 300px;
  }

  .screenfree-banner-uae-2026 h1 {
    font-size: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Screen-Free Banner UAE",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Banner Heading",
      "default": "Best Screen-Free Gifts for Kids in UAE (2026 Parent Guide)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Darkness",
      "min": 0,
      "max": 0.9,
      "step": 0.1,
      "default": 0.6
    }
  ],
  "presets": [
    {
      "name": "Screen-Free Banner UAE"
    }
  ]
}
{% endschema %}