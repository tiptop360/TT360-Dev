{% doc %}
  @prompt
    The original had a generic H1 buried under navigation noise. The new hero leads with a sharp headline, a clear value proposition, star rating social proof, and a direct CTA button. Visitors know within 3 seconds what this is and why to buy it.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-conversion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-conversion__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.element_spacing }}px;
    align-items: {{ block.settings.text_alignment }};
  }

  .ai-hero-conversion__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-hero-conversion__value-prop-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_prop_size }}px;
    color: {{ block.settings.value_prop_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-hero-conversion__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-hero-conversion__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-hero-conversion__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-hero-conversion__rating-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_text_size }}px;
    color: {{ block.settings.rating_text_color }};
    font-weight: 500;
  }

  .ai-hero-conversion__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-hero-conversion__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-hero-conversion-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.6 }}px {{ block.settings.padding_horizontal | times: 0.6 }}px;
    }

    .ai-hero-conversion__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
    }

    .ai-hero-conversion__value-prop-{{ ai_gen_id }} {
      font-size: {{ block.settings.value_prop_size | times: 0.9 }}px;
    }

    .ai-hero-conversion__rating-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 8px;
    }
  }
{% endstyle %}

<conversion-hero-{{ ai_gen_id }}
  class="ai-hero-conversion-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-conversion__container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-conversion__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.value_proposition != blank %}
      <div class="ai-hero-conversion__value-prop-{{ ai_gen_id }}">
        {{ block.settings.value_proposition }}
      </div>
    {% endif %}

    {% if block.settings.show_rating %}
      <div class="ai-hero-conversion__rating-{{ ai_gen_id }}">
        <div class="ai-hero-conversion__stars-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            <svg
              class="ai-hero-conversion__star-{{ ai_gen_id }}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          {% endfor %}
        </div>
        {% if block.settings.rating_text != blank %}
          <span class="ai-hero-conversion__rating-text-{{ ai_gen_id }}">
            {{ block.settings.rating_text }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-hero-conversion__cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</conversion-hero-{{ ai_gen_id }}>

<script>
  (function() {
    class ConversionHero{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const ctaButton = this.querySelector('.ai-hero-conversion__cta-{{ ai_gen_id }}');
        if (ctaButton && !ctaButton.getAttribute('aria-label')) {
          ctaButton.setAttribute('aria-label', ctaButton.textContent.trim());
        }
      }
    }

    customElements.define('conversion-hero-{{ ai_gen_id }}', ConversionHero{{ ai_gen_id }});
  })();
</script>

