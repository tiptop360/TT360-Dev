{% schema %}
{
  "name": "Kids Brushing Routine",
  "settings": [
    {
      "type": "text",
      "id": "section_padding",
      "label": "Section Padding (example: 60px 20px)",
      "default": "60px 20px"
    }
  ],
  "blocks": [
    {
      "type": "routine",
      "name": "Brushing Routine",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Simple 5-Minute Brushing Routine"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Steps (one per line)",
          "default": "Apply kid-friendly foam toothpaste\nUse a properly sized toothbrush\nBrush left to right gently\nRinse and reward consistency"
        }
      ]
    },
    {
      "type": "toothbrush",
      "name": "Toothbrush Guide",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Choosing the Right Kids Toothbrush in UAE"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Checklist (one per line)",
          "default": "Age-appropriate size\nSoft bristles\nEasy grip\nFun design to increase engagement"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Kids U-Shaped Electric Toothbrush UAE"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    },
    {
      "type": "checklist",
      "name": "Parent Checklist",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Parent Checklist"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Checklist items (one per line)",
          "default": "Toothbrush replaced every 2–3 months\nBrushing twice daily\nSupervision under age 6\nPositive reinforcement"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kids Brushing Routine",
      "blocks": [
        { "type": "routine" },
        { "type": "toothbrush" },
        { "type": "checklist" }
      ]
    }
  ]
}
{% endschema %}

<style>
.kids-brush-section {
  padding: {{ section.settings.section_padding }};
  background: #f4f9ff;
}
.kids-container {
  max-width: 1100px;
  margin: auto;
}
.kids-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(280px,1fr));
  gap: 25px;
}
.kids-card {
  background: #fff;
  padding: 25px;
  border-radius: 14px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}
.kids-card h2 {
  color: #12395e;
  font-size: 22px;
  margin-bottom: 15px;
}
.kids-card li {
  margin-bottom: 8px;
}
.kids-link {
  display: inline-block;
  margin-top: 15px;
  padding: 10px 18px;
  background: #12395e;
  color: #fff;
  text-decoration: none;
  border-radius: 8px;
}
</style>

<section class="kids-brush-section">
  <div class="kids-container">
    <div class="kids-grid">

      {% for block in section.blocks %}
        <div class="kids-card" {{ block.shopify_attributes }}>
          
          <h2>{{ block.settings.heading }}</h2>

          {% assign lines = block.settings.items | newline_to_br | split: '<br />' %}

          {% if block.type == 'routine' %}
            <ol>
              {% for line in lines %}
                <li>{{ line }}</li>
              {% endfor %}
            </ol>
          {% else %}
            <ul>
              {% for line in lines %}
                <li>✔ {{ line }}</li>
              {% endfor %}
            </ul>
          {% endif %}

          {% if block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="kids-link">
              {{ block.settings.button_text }}
            </a>
          {% endif %}

        </div>
      {% endfor %}

    </div>
  </div>
</section>