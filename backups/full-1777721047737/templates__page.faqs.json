          "type": "faq",
          "settings": {
            "faq_title": "Do you deliver across the UAE?",
            "faq_des": "<p>Yes. We deliver to all Emirates including Dubai, Abu Dhabi, Sharjah, Ras Al Khaimah, Ajman, Umm Al Quwain, and Fujairah.<\/p>"
          }
        },
        "template--16736981942590__9ad78513-f48a-4eed-affd-30f6d370be1c-1666772143a4c26d1e-1": {
          "type": "faq",
          "settings": {
            "faq_title": "How long does delivery take?",
            "faq_des": "<p>Orders are typically delivered within 1–4 business days depending on the Emirate.<\/p>"
          }
        },
        "template--16736981942590__9ad78513-f48a-4eed-affd-30f6d370be1c-1666772143a4c26d1e-2": {
          "type": "faq",
          "settings": {
            "faq_title": "Do you offer same-day delivery?",
            "faq_des": "<p>Same-day delivery may be available in selected locations or during special promotions.<br\/><br\/><\/p>"
          }
        }
      },
