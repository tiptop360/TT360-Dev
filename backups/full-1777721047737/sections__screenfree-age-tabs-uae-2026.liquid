{% comment %}
Updated: sections/screenfree-age-tabs-uae-2026.liquid
Supports single + multiple product layouts
{% endcomment %}

<section class="screenfree-age-tabs-uae-2026">
  <div class="page-width">
    
    <h2 class="section-title">{{ section.settings.heading }}</h2>

    <!-- TAB BUTTONS -->
    <div class="tabs-nav">
      {% for block in section.blocks %}
        <button 
          class="tab-btn {% if forloop.first %}active{% endif %}" 
          data-tab="tab-{{ block.id }}"
        >
          {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    <!-- TAB CONTENT -->
    {% for block in section.blocks %}
      {% assign product_count = block.settings.products.count %}
      
      <div 
        id="tab-{{ block.id }}" 
        class="tab-content {% if forloop.first %}active{% endif %}"
      >

        <div class="product-grid {% if product_count == 1 %}single-product{% endif %}">
          
          {% for product in block.settings.products %}
            <div class="product-card">
              
              <a href="{{ product.url }}">
                <img 
                  src="{{ product.featured_image | image_url: width: 800 }}" 
                  alt="{{ product.title }}"
                  loading="lazy"
                >
              </a>

              <div class="product-content">
                <h4>{{ product.title }}</h4>
                
                <div class="price">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="compare-price">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>

                <a href="{{ product.url }}" class="product-btn">
                  View Product
                </a>
              </div>

            </div>
          {% endfor %}

        </div>
      </div>
    {% endfor %}

  </div>
</section>

<style>
.screenfree-age-tabs-uae-2026 {
  padding: 80px 0;
}

.screenfree-age-tabs-uae-2026 .section-title {
  text-align: center;
  font-size: 32px;
  margin-bottom: 40px;
}

/* Tabs */
.tabs-nav {
  display: flex;
  justify-content: center;
  gap: 15px;
  flex-wrap: wrap;
  margin-bottom: 40px;
}

.tab-btn {
  padding: 10px 25px;
  border-radius: 30px;
  border: none;
  background: #f4f4f4;
  cursor: pointer;
  font-weight: 600;
  transition: 0.3s;
}

.tab-btn.active {
  background: #ff6a00;
  color: #fff;
}

/* Content */
.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}

/* Grid */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(260px,1fr));
  gap: 30px;
}

/* Single Product Layout */
.product-grid.single-product {
  grid-template-columns: 1fr;
  max-width: 420px;
  margin: 0 auto;
}

/* Card */
.product-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 25px rgba(0,0,0,0.05);
  transition: 0.3s;
  text-align: center;
}

.product-card:hover {
  transform: translateY(-6px);
}

.product-card img {
  width: 100%;
  height: 260px;
  object-fit: cover;
}

.product-content {
  padding: 20px;
}

.product-content h4 {
  margin-bottom: 10px;
}

.price {
  font-weight: 600;
  margin-bottom: 12px;
}

.compare-price {
  text-decoration: line-through;
  opacity: 0.6;
  margin-left: 6px;
  font-size: 14px;
}

.product-btn {
  display: inline-block;
  padding: 10px 20px;
  background: #111;
  color: #fff;
  border-radius: 25px;
  text-decoration: none;
  font-size: 14px;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const buttons = document.querySelectorAll(".screenfree-age-tabs-uae-2026 .tab-btn");
  const contents = document.querySelectorAll(".screenfree-age-tabs-uae-2026 .tab-content");

  buttons.forEach(btn => {
    btn.addEventListener("click", function() {
      const target = this.getAttribute("data-tab");

      buttons.forEach(b => b.classList.remove("active"));
      contents.forEach(c => c.classList.remove("active"));

      this.classList.add("active");
      document.getElementById(target).classList.add("active");
    });
  });
});
</script>

{% schema %}
{
  "name": "Screen-Free Age Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Best Screen-Free Gifts by Age"
    }
  ],
  "blocks": [
    {
      "type": "age_tab",
      "name": "Age Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Ages 3–5"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Select Products"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Screen-Free Age Tabs"
    }
  ]
}
{% endschema %}