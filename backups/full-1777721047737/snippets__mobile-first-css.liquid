{%- comment -%} TipTop360 — Mobile UX overhaul + desktop swiper sizing {%- endcomment -%}
<style>
/* =========================================
   DESKTOP — swiper image sizing
   ========================================= */
@media (min-width: 990px) {
  section[class*="product-list"] .swiper-slide,
  .product-list-swiper .swiper-slide,
  [class*="product-list-swiper"] .swiper-slide {
    max-width: 280px !important;
  }
  section[class*="product-list"] .swiper-slide img,
  .product-list-swiper .swiper-slide img {
    max-width: 100% !important;
    max-height: 280px !important;
    height: auto !important;
    object-fit: cover !important;
  }
}
@media (min-width: 750px) and (max-width: 989px) {
  section[class*="product-list"] .swiper-slide {
    max-width: 240px !important;
  }
  section[class*="product-list"] .swiper-slide img {
    max-width: 100% !important;
    max-height: 240px !important;
    height: auto !important;
  }
}

/* =========================================
   MOBILE UX OVERHAUL (≤768px)
   ========================================= */
@media (max-width: 768px) {
  
  /* === KILL HORIZONTAL SCROLL (safe, targeted) === */
  html, body {
    overflow-x: clip !important;
    max-width: 100vw !important;
  }
  /* Target overflow-prone elements (not universal *) */
  .container, .wrapper, section, header, footer, main {
    max-width: 100% !important;
  }
  /* Images can never overflow */
  img, video, iframe { max-width: 100% !important; height: auto !important; }
  /* Tables get horizontal scroll instead of breaking layout */
  table { display: block !important; overflow-x: auto !important; -webkit-overflow-scrolling: touch !important; max-width: 100% !important; }
  
  /* === TYPOGRAPHY (readable) === */
  body, p, li { font-size: 16px !important; line-height: 1.6 !important; }
  
  /* Headings */
  .product-single__title, h1.product__title, h1 { font-size: 24px !important; line-height: 1.25 !important; font-weight: 700 !important; }
  h2 { font-size: 22px !important; line-height: 1.3 !important; }
  h3 { font-size: 19px !important; line-height: 1.3 !important; }
  
  /* Bump tiny text (no <14px on body content) */
  [style*="font-size: 10px"], [style*="font-size:10px"],
  [style*="font-size: 11px"], [style*="font-size:11px"] { font-size: 13px !important; }
  [style*="font-size: 12px"], [style*="font-size:12px"] { font-size: 14px !important; }
  
  /* === PRODUCT PAGE CRITICAL === */
  .product-single__price { font-size: 24px !important; font-weight: 700 !important; }
  .product-form__cart-submit {
    font-size: 17px !important;
    min-height: 56px !important;
    font-weight: 700 !important;
    border-radius: 10px !important;
    letter-spacing: 0.02em !important;
  }
  
  /* === PRODUCT CARDS (collection + home) === */
  .product-card__title { font-size: 14px !important; line-height: 1.35 !important; min-height: 38px !important; }
  .product-card__price { font-size: 16px !important; font-weight: 700 !important; }
  .product-card__rating { font-size: 12px !important; }
  
  /* === CRO BLOCKS === */
  .cro-rating-badge { font-size: 15px !important; }
  .cro-trust-band { font-size: 13px !important; padding: 12px !important; gap: 8px !important; }
  .cro-trust-band > div { gap: 6px !important; }
  .cro-risk-reversal { font-size: 13px !important; padding: 14px !important; }
  .cro-comparison { padding: 14px 8px !important; margin: 24px -4px !important; border-radius: 8px !important; }
  .cro-comparison h3 { font-size: 18px !important; text-align: center !important; }
  .cro-comparison table { min-width: 360px !important; font-size: 12px !important; }
  .cro-comparison th, .cro-comparison td { padding: 8px 5px !important; }
  .cro-fbt { padding: 14px !important; margin: 24px -4px !important; border-radius: 8px !important; }
  .cro-fbt h3 { font-size: 18px !important; text-align: center !important; }
  .cro-fbt > div:nth-child(2) > div { min-width: 80px !important; max-width: 110px !important; }
  
  /* === TAP TARGETS (Apple HIG: 44px+, ours: 48px) === */
  button, a.btn, .btn, [role="button"], input[type="submit"] {
    min-height: 48px !important;
  }
  
  /* === FORMS — prevent iOS zoom-on-focus === */
  input[type="text"],
  input[type="email"],
  input[type="tel"],
  input[type="number"],
  input[type="search"],
  input[type="password"],
  select,
  textarea {
    font-size: 16px !important;
    padding: 12px !important;
    border-radius: 8px !important;
  }
  
  /* === SWIPER ON MOBILE === */
  section[class*="product-list"] .swiper-slide,
  .product-list-swiper .swiper-slide {
    max-width: 70vw !important;
  }
  section[class*="product-list"] .swiper-slide img {
    max-width: 100% !important;
    height: auto !important;
  }
  
  /* === IMAGES — sharper on mobile === */
  .product-single__photos img { border-radius: 8px !important; }
  
  /* === SAFE EDGE SPACING === */
  .container, .wrapper { padding-left: 16px !important; padding-right: 16px !important; }
  
  /* === REDUCE EXCESSIVE PADDING === */
  section { padding-top: 24px !important; padding-bottom: 24px !important; }
  
  /* === STICKY ATC IMPROVEMENTS === */
  .sticky-atc, [class*="sticky"][class*="cart"] {
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
    background: rgba(255,255,255,0.95) !important;
    box-shadow: 0 -2px 12px rgba(0,0,0,0.08) !important;
  }
  
  /* === BETTER VARIANT SELECTOR === */
  .variant-selector, [class*="variant-input"] {
    margin-bottom: 12px !important;
  }
  
  /* === REVIEW WIDGET === */
  .jdgm-rev, [class*="judge-me"] { font-size: 14px !important; }
}

/* =========================================
   SMALL PHONES (≤380px iPhone SE)
   ========================================= */
@media (max-width: 380px) {
  body, p, li { font-size: 15px !important; }
  .product-single__title, h1.product__title { font-size: 22px !important; }
  .cro-comparison table { min-width: 320px !important; font-size: 11px !important; }
  .cro-comparison th, .cro-comparison td { padding: 6px 4px !important; }
  .product-form__cart-submit { font-size: 16px !important; }
}

/* =========================================
   ACCESSIBILITY — focus rings on mobile
   ========================================= */
@media (max-width: 768px) {
  button:focus-visible, a:focus-visible, input:focus-visible {
    outline: 2px solid #12395e !important;
    outline-offset: 2px !important;
  }
}
</style>
