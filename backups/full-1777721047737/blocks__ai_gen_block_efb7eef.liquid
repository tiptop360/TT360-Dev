{% doc %}
  @prompt
    Layout — strict two-column split: copy on the left, full-bleed product image on the right, so the eye travels naturally left-to-right.
    Floating badges — two anchored callout cards over the image ("30 sec" and "360°") reinforce the product's core claims without cluttering the copy area.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-split-layout-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-split-layout__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: {{ block.settings.min_height }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-split-layout__copy-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.copy_padding }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-split-layout__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-split-layout__subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.4;
  }

  .ai-split-layout__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.button_spacing }}px 0;
  }

  .ai-split-layout__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_v }}px {{ block.settings.button_padding_h }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_weight }};
    transition: all 0.3s ease;
    text-align: center;
  }

  .ai-split-layout__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
  }

  .ai-split-layout__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-split-layout__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-split-layout__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-split-layout__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-split-layout__badge-{{ ai_gen_id }} {
    position: absolute;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding }}px {{ block.settings.badge_padding | times: 1.5 }}px;
    border-radius: {{ block.settings.badge_radius }}px;
    font-size: {{ block.settings.badge_text_size }}px;
    font-weight: {{ block.settings.badge_weight }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 2;
  }

  .ai-split-layout__badge-1-{{ ai_gen_id }} {
    top: {{ block.settings.badge_1_top }}%;
    left: {{ block.settings.badge_1_left }}%;
  }

  .ai-split-layout__badge-2-{{ ai_gen_id }} {
    top: {{ block.settings.badge_2_top }}%;
    left: {{ block.settings.badge_2_left }}%;
  }

  @media screen and (max-width: 749px) {
    .ai-split-layout__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .ai-split-layout__copy-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_copy_order }};
      padding: {{ block.settings.copy_padding | times: 0.6 }}px;
    }

    .ai-split-layout__image-wrapper-{{ ai_gen_id }} {
      order: {{ block.settings.mobile_image_order }};
      min-height: {{ block.settings.mobile_image_height }}px;
    }

    .ai-split-layout__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-split-layout__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-split-layout__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-split-layout__badge-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_text_size | times: 0.8 }}px;
      padding: {{ block.settings.badge_padding | times: 0.8 }}px {{ block.settings.badge_padding | times: 1.2 }}px;
    }
  }
{% endstyle %}

<div class="ai-split-layout-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-split-layout__container-{{ ai_gen_id }}">
    <div class="ai-split-layout__copy-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-split-layout__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <div class="ai-split-layout__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</div>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-split-layout__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-split-layout__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-split-layout__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img
          src="{{ block.settings.product_image | image_url: width: 1200 }}"
          alt="{{ block.settings.product_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
          class="ai-split-layout__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-split-layout__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if block.settings.badge_1_enable and block.settings.badge_1_text != blank %}
        <div class="ai-split-layout__badge-{{ ai_gen_id }} ai-split-layout__badge-1-{{ ai_gen_id }}">
          {{ block.settings.badge_1_text }}
        </div>
      {% endif %}

      {% if block.settings.badge_2_enable and block.settings.badge_2_text != blank %}
        <div class="ai-split-layout__badge-{{ ai_gen_id }} ai-split-layout__badge-2-{{ ai_gen_id }}">
          {{ block.settings.badge_2_text }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

