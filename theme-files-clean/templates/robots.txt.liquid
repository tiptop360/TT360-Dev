# robots.txt — TipTop360 (Shopify) | SEO + AI-friendly + Secure (2026)
# Goal: maximize crawl efficiency for products/collections/content, protect private flows,
# avoid crawl waste from tracking/duplicates, and keep trust pages crawlable.

User-agent: *

# -------------------------------
# 1) PRIVATE / SENSITIVE PATHS
# -------------------------------
Disallow: /admin
Disallow: /checkout
Disallow: /checkout/
Disallow: /checkouts
Disallow: /checkouts/
Disallow: /cart
Disallow: /carts
Disallow: /orders
Disallow: /account
Disallow: /apps

# Shopify / security endpoints (safe to block)
Disallow: /a/downloads/-/*
Disallow: /sf_private_access_tokens
Disallow: /.well-known/shopify/monorail
Disallow: /cdn/wpm/*.js

# -------------------------------
# 2) LOW-VALUE / DUPLICATE URLS
# (Block tracking + preview URLs only.)
# Do NOT block ?page=, ?variant=, ?sort_by= or ?filter.* here: those are
# handled by <meta robots="noindex,follow"> + Shopify's auto-canonical in
# theme.liquid. Blocking them in robots.txt would stop Googlebot from
# crawling the page, so it could never SEE the noindex — the classic cause
# of "Indexed, though blocked by robots.txt" in Search Console.
# -------------------------------
Disallow: /*?*utm_*
Disallow: /*&utm_*
Disallow: /*?*fbclid=*
Disallow: /*?*gclid=*
Disallow: /*?*gbraid=*
Disallow: /*?*wbraid=*
Disallow: /*?*oseid=*
Disallow: /*?*ls=*
Disallow: /*preview_theme_id=*
Disallow: /*preview_script_id=*

# -------------------------------
# 3) PAGES NOT WORTH INDEXING
# -------------------------------
Disallow: /search
Disallow: /recommendations
Disallow: /recommendations/products

# -------------------------------
# 4) TRUST PAGES (IMPORTANT FOR AI)
# -------------------------------
Allow: /policies
Allow: */policies/

# -------------------------------
# 5) IMPORTANT MACHINE-READABLE FILES
# -------------------------------
Allow: /sitemap.xml
Allow: /robots.txt
Allow: /llms.txt

Sitemap: https://tiptop360.com/sitemap.xml


