<div class="modal fade" id="jsSoldout" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-dialog--soldout modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">{%- render 'icon-close' -%}</button>
      </div>
      <div class="modal-body">
        <div class="row justify-content-center js-soldout-content">
          {%- form 'contact', class: 'col-10', id:'contact_form-soldout' -%}
          {{ form.errors | default_errors }}
          <p class="js-notify-text">{{ 'products.product.soldout_messenger' | t }}<span> {% if product.selected_or_first_available_variant.available %}{{ product.title }} - {{  product.selected_or_first_available_variant.title }} {% else %} {{product.title}} {% endif %}</span></p>
          <div>
          <input class="hide" type="text" id="ContactFormMessenger" name="contact[messenger]" value="{{ 'products.product.soldout_messenger' | t }}">
          <input class="hide" type="text" class="wait_list_product" id="ContactProduct" name="contact[product]" value="{{ product.title }} - {{  product.selected_or_first_available_variant.title }}">
          <input class="hide" type="text" class="wait_list_product" id="ContactProductVariant" name="contact[variant_url]" value="">

            <div class="form-group mb-3">
            <input class="form-control" type="email" id="ContactFormEmail" name="contact[email]" placeholder="{{ 'contact.form.email' | t }}" autocorrect="off" autocapitalize="off" value="{%- if form.email -%}{{ form.email }}{%- elsif customer -%}{{ customer.email }}{%- endif -%}">
            <label for="ContactFormEmail" class="">{{ 'contact.form.email' | t }}</label>
          </div>
          <input type="submit" class="btn btn-theme gradient-theme mb-4 w-100" value="{{ 'contact.form.receive_info' | t }}">
        </div>
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>
<script>
  $(document).ready(function(){
  $(".btn-waitlist").click(()=>{
    let productVariantTitle = $(".selector-wrapper input:checked").val();
    var productTitle = $(".selector-wrapper input:checked").attr('data-product-title');
    var currentUrl = window.location.href;
    console.log(productVariantTitle);
    console.log(productTitle);
	let orgValue = productTitle +'-'+ productVariantTitle;
	$("form#contact_form-soldout .js-notify-text span").text(orgValue);
    $("form#contact_form-soldout #ContactProductVariant").attr('value',currentUrl)
    $("form#contact_form-soldout #ContactProduct").each(function() {
    $(this).attr('value',orgValue);
	});
});
});
</script>