{%- comment -%}
  Dynamic Delivery Estimate
  Shows next-day delivery (Asia/Dubai timezone), skipping Sunday + admin holidays.
  Params from block.settings:
    label, cutoff_hour, cutoff_label, sub_text, holidays, bg_color, accent_color, deliver_sunday
{%- endcomment -%}

{%- assign uid = 'dde-' | append: block.id | default: 'dde-default' -%}

<div class="dynamic-delivery-estimate" id="{{ uid }}"
     data-cutoff="{{ block.settings.cutoff_hour | default: 16 }}"
     data-holidays="{{ block.settings.holidays }}"
     data-deliver-sunday="{% if block.settings.deliver_sunday %}1{% else %}0{% endif %}"
     style="--dde-bg: {{ block.settings.bg_color | default: '#eaf7ee' }}; --dde-accent: {{ block.settings.accent_color | default: '#1f8a3a' }};">
  <div class="dde-row">
    <span class="dde-icon" aria-hidden="true">🚚</span>
    <div class="dde-content">
      <div class="dde-label">{{ block.settings.label | default: 'ESTIMATED DELIVERY' }}</div>
      <div class="dde-date">
        <span class="dde-date-text">—</span>
        <span class="dde-badge">Next Day Delivery</span>
      </div>
      <div class="dde-sub">{{ block.settings.sub_text | default: 'Order before' }}
        <span class="dde-cutoff">{{ block.settings.cutoff_hour | default: 16 }}:00</span>
        {{ block.settings.cutoff_label | default: 'for fast UAE delivery' }}
      </div>
    </div>
  </div>
</div>

<style>
  .dynamic-delivery-estimate{
    background: var(--dde-bg);
    border: 1px solid color-mix(in srgb, var(--dde-accent) 25%, transparent);
    border-radius: 10px;
    padding: 14px 16px;
    margin: 12px 0;
    font-family: inherit;
  }
  .dynamic-delivery-estimate .dde-row{
    display:flex; align-items:center; gap:12px;
  }
  .dynamic-delivery-estimate .dde-icon{
    font-size: 28px; line-height:1;
  }
  .dynamic-delivery-estimate .dde-label{
    font-size: 11px; letter-spacing: .08em; font-weight: 600;
    color: var(--dde-accent); text-transform: uppercase; margin-bottom: 2px;
  }
  .dynamic-delivery-estimate .dde-date{
    display:flex; align-items:center; flex-wrap:wrap; gap:8px;
    font-size: 15px; font-weight: 700; color:#111;
  }
  .dynamic-delivery-estimate .dde-badge{
    background: var(--dde-accent); color:#fff;
    font-size: 10px; font-weight: 700; letter-spacing:.04em;
    padding: 3px 8px; border-radius: 999px; text-transform: uppercase;
  }
  .dynamic-delivery-estimate .dde-sub{
    font-size: 12px; color:#555; margin-top: 3px;
  }
  .dynamic-delivery-estimate .dde-cutoff{ font-weight: 600; color:#222; }
</style>

<script>
(function(){
  var root = document.getElementById('{{ uid }}');
  if (!root) return;

  var cutoffHour = parseInt(root.getAttribute('data-cutoff'), 10);
  if (isNaN(cutoffHour)) cutoffHour = 16;
  var deliverSunday = root.getAttribute('data-deliver-sunday') === '1';
  var holidaysRaw = (root.getAttribute('data-holidays') || '').trim();
  var holidays = holidaysRaw ? holidaysRaw.split(/[,\s]+/).filter(Boolean) : [];

  // Get current date/time in Asia/Dubai
  function dubaiNow(){
    var s = new Date().toLocaleString('en-US', { timeZone: 'Asia/Dubai' });
    return new Date(s);
  }
  function ymd(d){
    var y = d.getFullYear();
    var m = String(d.getMonth()+1).padStart(2,'0');
    var da = String(d.getDate()).padStart(2,'0');
    return y + '-' + m + '-' + da;
  }
  function isClosed(d){
    if (!deliverSunday && d.getDay() === 0) return true; // 0 = Sunday
    if (holidays.indexOf(ymd(d)) !== -1) return true;
    return false;
  }
  function addDays(d, n){
    var r = new Date(d.getTime());
    r.setDate(r.getDate() + n);
    return r;
  }
  function nextDeliveryDate(now){
    // Cutoff: if past cutoff hour, ship tomorrow → arrives day after tomorrow.
    // Before cutoff: ship today → arrives tomorrow.
    var base = addDays(now, now.getHours() >= cutoffHour ? 2 : 1);
    var safety = 0;
    while (isClosed(base) && safety < 14){
      base = addDays(base, 1);
      safety++;
    }
    return base;
  }

  var now = dubaiNow();
  var delivery = nextDeliveryDate(now);

  var weekdays = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  var isTomorrow = (delivery.toDateString() === addDays(now,1).toDateString());
  var label = (isTomorrow ? 'Tomorrow, ' : '') +
              weekdays[delivery.getDay()] + ', ' +
              months[delivery.getMonth()] + ' ' + delivery.getDate();

  var dateEl = root.querySelector('.dde-date-text');
  if (dateEl) dateEl.textContent = label;

  var badge = root.querySelector('.dde-badge');
  if (badge && !isTomorrow) badge.style.display = 'none';
})();
</script>
