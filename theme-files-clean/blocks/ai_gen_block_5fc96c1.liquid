{% doc %}
  @prompt
    Hero — Product visual (bottles + strawberry burst) now sits in its own pink image zone at the top, with the badge, headline and CTA buttons stacked below it in a clean text zone.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-product-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-hero-product__image-zone-{{ ai_gen_id }} {
    background-color: {{ block.settings.image_zone_bg_color }};
    border-radius: {{ block.settings.image_zone_border_radius }}px;
    padding: {{ block.settings.image_zone_padding }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .ai-hero-product__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
  }

  .ai-hero-product__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-hero-product__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .ai-hero-product__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.5;
  }

  .ai-hero-product__text-zone-{{ ai_gen_id }} {
    padding: {{ block.settings.text_zone_padding }}px 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-hero-product__badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: {{ block.settings.badge_text_transform }};
    margin-bottom: {{ block.settings.badge_spacing }}px;
  }

  .ai-hero-product__headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_font_size }}px;
    font-weight: {{ block.settings.headline_font_weight }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
  }

  .ai-hero-product__subheadline-{{ ai_gen_id }} {
    color: {{ block.settings.subheadline_color }};
    font-size: {{ block.settings.subheadline_font_size }}px;
    line-height: 1.5;
    margin: 0 0 {{ block.settings.subheadline_spacing }}px;
  }

  .ai-hero-product__cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
    flex-wrap: wrap;
  }

  .ai-hero-product__cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
  }

  .ai-hero-product__cta-button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_btn_bg }};
    color: {{ block.settings.primary_btn_text }};
    border-color: {{ block.settings.primary_btn_bg }};
  }

  .ai-hero-product__cta-button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_btn_hover_bg }};
    color: {{ block.settings.primary_btn_hover_text }};
    border-color: {{ block.settings.primary_btn_hover_bg }};
  }

  .ai-hero-product__cta-button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_btn_bg }};
    color: {{ block.settings.secondary_btn_text }};
    border-color: {{ block.settings.secondary_btn_border }};
  }

  .ai-hero-product__cta-button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_btn_hover_bg }};
    color: {{ block.settings.secondary_btn_hover_text }};
    border-color: {{ block.settings.secondary_btn_hover_border }};
  }

  @media screen and (max-width: 749px) {
    .ai-hero-product__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_font_size | times: 0.7 }}px;
    }

    .ai-hero-product__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_font_size | times: 0.9 }}px;
    }

    .ai-hero-product__image-zone-{{ ai_gen_id }} {
      padding: {{ block.settings.image_zone_padding | times: 0.6 }}px;
    }

    .ai-hero-product__text-zone-{{ ai_gen_id }} {
      padding: {{ block.settings.text_zone_padding | times: 0.7 }}px 0;
    }

    .ai-hero-product__cta-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-product__cta-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-product__image-zone-{{ ai_gen_id }}">
    <div class="ai-hero-product__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product_image %}
        <img
          src="{{ block.settings.product_image | image_url: width: 1200 }}"
          alt="{{ block.settings.product_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.product_image.width }}"
          height="{{ block.settings.product_image.height }}"
          class="ai-hero-product__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-hero-product__image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="ai-hero-product__text-zone-{{ ai_gen_id }}">
    {% if block.settings.badge_text != blank %}
      <div class="ai-hero-product__badge-{{ ai_gen_id }}">
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-product__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <div class="ai-hero-product__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </div>
    {% endif %}

    <div class="ai-hero-product__cta-wrapper-{{ ai_gen_id }}">
      {% if block.settings.primary_btn_label != blank %}
        <a
          href="{{ block.settings.primary_btn_link }}"
          class="ai-hero-product__cta-button-{{ ai_gen_id }} ai-hero-product__cta-button--primary-{{ ai_gen_id }}"
        >
          {{ block.settings.primary_btn_label }}
        </a>
      {% endif %}

      {% if block.settings.secondary_btn_label != blank %}
        <a
          href="{{ block.settings.secondary_btn_link }}"
          class="ai-hero-product__cta-button-{{ ai_gen_id }} ai-hero-product__cta-button--secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.secondary_btn_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

