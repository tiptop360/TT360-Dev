{% doc %}
  @prompt
    create table 2 side 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-column-table-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-two-column-table__wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
  }

  .ai-two-column-table__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-two-column-table__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
  }

  .ai-two-column-table__header-cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.header_text_color }};
    font-weight: {{ block.settings.header_font_weight }};
    font-size: {{ block.settings.header_font_size }}px;
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-two-column-table__row-{{ ai_gen_id }} {
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

  .ai-two-column-table__row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  {% if block.settings.enable_striped_rows %}
    .ai-two-column-table__row-{{ ai_gen_id }}:nth-child(even) {
      background-color: {{ block.settings.striped_row_color }};
    }
  {% endif %}

  {% if block.settings.enable_hover %}
    .ai-two-column-table__row-{{ ai_gen_id }}:hover {
      background-color: {{ block.settings.hover_color }};
    }
  {% endif %}

  .ai-two-column-table__cell-{{ ai_gen_id }} {
    padding: {{ block.settings.cell_padding }}px;
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_font_size }}px;
  }

  .ai-two-column-table__cell-{{ ai_gen_id }}:first-child {
    font-weight: {{ block.settings.first_column_font_weight }};
    {% if block.settings.first_column_bg_enable %}
      background-color: {{ block.settings.first_column_bg_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-two-column-table__header-cell-{{ ai_gen_id }},
    .ai-two-column-table__cell-{{ ai_gen_id }} {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.text_font_size | times: 0.9 }}px;
    }

    .ai-two-column-table__header-cell-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<two-column-table-{{ ai_gen_id }}
  class="ai-two-column-table-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-two-column-table__wrapper-{{ ai_gen_id }}">
    <table class="ai-two-column-table__table-{{ ai_gen_id }}">
      {% if block.settings.show_header %}
        <thead class="ai-two-column-table__header-{{ ai_gen_id }}">
          <tr>
            <th class="ai-two-column-table__header-cell-{{ ai_gen_id }}">
              {{ block.settings.header_column_1 }}
            </th>
            <th class="ai-two-column-table__header-cell-{{ ai_gen_id }}">
              {{ block.settings.header_column_2 }}
            </th>
          </tr>
        </thead>
      {% endif %}
      <tbody>
        {% for i in (1..10) %}
          {% liquid
            assign row_label_key = 'row_' | append: i | append: '_label'
            assign row_value_key = 'row_' | append: i | append: '_value'
            assign row_label = block.settings[row_label_key]
            assign row_value = block.settings[row_value_key]
          %}
          {% if row_label != blank or row_value != blank %}
            <tr class="ai-two-column-table__row-{{ ai_gen_id }}">
              <td class="ai-two-column-table__cell-{{ ai_gen_id }}">
                {{ row_label }}
              </td>
              <td class="ai-two-column-table__cell-{{ ai_gen_id }}">
                {{ row_value }}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</two-column-table-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoColumnTable{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('two-column-table-{{ ai_gen_id }}', TwoColumnTable{{ ai_gen_id }});
  })();
</script>

