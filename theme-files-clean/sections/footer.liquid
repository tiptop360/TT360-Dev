                  data-srcset="{{ img_url }}"
                  data-widths="[360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]"
                  data-aspectratio="{{ logo.aspect_ratio }}"
                  data-sizes="auto"
                  loading="lazy"
                  width="{{ logo.width }}"
                  height="{{ logo.height }}"/>
