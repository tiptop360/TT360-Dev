      </div>
    </div>
  </div>
  <style>
    .t360-social-bar{
      background:var(--footer-bg);
      padding:28px 0 20px;
      text-align:center;
      border-bottom:1px solid rgba(255,255,255,.08);
    }
    .t360-social-bar__label{
      color:var(--footer-title);
      font-size:13px;
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.12em;
      margin:0 0 16px;
    }
    .t360-social-bar__icons{
      display:flex;
      justify-content:center;
      flex-wrap:wrap;
      gap:14px;
    }
    .t360-sico{
      display:flex;
      align-items:center;
      justify-content:center;
      width:48px;
      height:48px;
      border-radius:50%;
      color:#fff;
      transition:transform .2s ease, box-shadow .2s ease;
    }
    .t360-sico:hover{
      transform:scale(1.15);
      color:#fff;
    }
    .t360-sico--ig{background:linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888)}
    .t360-sico--tk{background:#010101}
    .t360-sico--fb{background:#1877f2}
    .t360-sico--yt{background:#ff0000}
    .t360-sico--tw{background:#000}
    .t360-sico--sc{background:#fffc00;color:#000}
    .t360-sico--sc:hover{color:#000}
    .t360-sico--pin{background:#e60023}
    .t360-sico:hover{box-shadow:0 4px 16px rgba(0,0,0,.35)}
    @media(max-width:749px){
      .t360-social-bar{padding:24px 16px 16px}
      .t360-sico{width:44px;height:44px}
      .t360-social-bar__icons{gap:12px}
    }
  </style>

  <div class="site-footer--head">
  <div class="{{ section.settings.setwidth }}">
    <div class="row">
      {%- for block in section.blocks -%}
      {%- liquid
        case block.settings.width 
          when '16%' 
          assign block_width = 'col-lg-2 col-md-4' 
          when '20%' 
          assign block_width = 'col-1-5 col-md-6 col-12' 
          when '25%' 
          assign block_width = 'col-lg-3 col-md-6' 
          when '33%' 
          assign block_width = 'col-lg-4 col-md-6' 
          when '50%' 
          assign block_width = 'col-lg-6' 
