              assign enable_image = section.settings.enable_image
              assign enable_name = section.settings.enable_name 
              if section.settings.e_ft_currency and localization.available_countries.size > 1
                render 'localization' id: 'FooterCountryForm', enable_image: enable_image, enable_name: enable_name, idCountryList : 'FooterCountryList'
              endif
            if section.settings.enable_language_selector and localization.available_languages.size > 1 
                render 'localization-language', id : 'FooterLanguageForm', enable_name: enable_name, idlist : 'FooterLanguageList'
              endif
            -%}
