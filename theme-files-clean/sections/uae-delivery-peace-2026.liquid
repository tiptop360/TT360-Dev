{% comment %}
File: sections/uae-delivery-peace-2026.liquid
{% endcomment %}

<section class="uae-delivery-peace-2026" style="background: {{ section.settings.bg_color }};">
  <div class="page-width delivery-inner">
    
    <h2 class="delivery-heading">
      {{ section.settings.heading }}
    </h2>

    <p class="delivery-text">
      {{ section.settings.subtext }}
    </p>

  </div>
</section>

<style>
.uae-delivery-peace-2026 {
  padding: 70px 20px;
  text-align: center;
}

.uae-delivery-peace-2026 .delivery-heading {
  font-size: 30px;
  margin-bottom: 15px;
}

.uae-delivery-peace-2026 .delivery-text {
  font-size: 16px;
  opacity: 0.85;
}

@media (max-width: 768px) {
  .uae-delivery-peace-2026 {
    padding: 50px 15px;
  }

  .uae-delivery-peace-2026 .delivery-heading {
    font-size: 22px;
  }
}
</style>

{% schema %}
{
  "name": "UAE Delivery & Trust",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fast Delivery & Parent Peace of Mind"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Free next-day UAE delivery | Cash on Delivery | Secure Payments"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f6f9"
    }
  ],
  "presets": [
    {
      "name": "UAE Delivery & Trust"
    }
  ]
}
{% endschema %}