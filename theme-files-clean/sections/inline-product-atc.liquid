{%- assign atc_product = all_products[section.settings.product_handle] -%}
{%- if atc_product != empty -%}
  {%- assign atc_variant = atc_product.selected_or_first_available_variant -%}

<section class="inline-product-atc" id="inline-atc-{{ section.id }}"
  style="background: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_vertical }}px 20px;">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <p class="inline-product-atc__heading" style="color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px;">
        {{ section.settings.heading }}
      </p>
    {%- endif -%}

    {%- form 'product', atc_product, id: 'inline-atc-form-{{ section.id }}', class: 'inline-product-atc__form' -%}
      <input type="hidden" name="id" value="{{ atc_variant.id }}">

      <div class="inline-product-atc__controls">
        <div class="inline-product-atc__qty-wrap">
          <button type="button" class="inline-atc__qty-btn inline-atc__qty-minus" aria-label="Decrease quantity">&#8722;</button>
          <input type="number" name="quantity" value="1" min="1" class="inline-atc__qty-input" aria-label="Quantity">
          <button type="button" class="inline-atc__qty-btn inline-atc__qty-plus" aria-label="Increase quantity">&#43;</button>
        </div>

        <button type="submit" name="add" class="inline-atc__add-btn"
          style="background: {{ section.settings.btn_bg_color }}; color: {{ section.settings.btn_text_color }}; border-radius: {{ section.settings.btn_radius }}px;"
          {% unless atc_variant.available %}disabled{% endunless %}>
          {%- if atc_variant.available -%}
            {{ section.settings.btn_label }}
          {%- else -%}
            {{ section.settings.btn_soldout_label }}
          {%- endif -%}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

<style>
  #inline-atc-{{ section.id }} .inline-product-atc__heading {
    font-weight: 600;
    text-align: center;
    margin-bottom: 16px;
  }
  #inline-atc-{{ section.id }} .inline-product-atc__form {
    display: flex;
    justify-content: center;
  }
  #inline-atc-{{ section.id }} .inline-product-atc__controls {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    justify-content: center;
  }
  #inline-atc-{{ section.id }} .inline-product-atc__qty-wrap {
    display: flex;
    align-items: center;
    border: 2px solid {{ section.settings.btn_bg_color }};
    border-radius: 8px;
    overflow: hidden;
  }
  #inline-atc-{{ section.id }} .inline-atc__qty-btn {
    width: 44px;
    height: 48px;
    background: transparent;
    border: none;
    font-size: 20px;
    cursor: pointer;
    color: {{ section.settings.btn_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  #inline-atc-{{ section.id }} .inline-atc__qty-btn:hover {
    background: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_text_color }};
  }
  #inline-atc-{{ section.id }} .inline-atc__qty-input {
    width: 52px;
    height: 48px;
    border: none;
    border-left: 1px solid {{ section.settings.btn_bg_color }};
    border-right: 1px solid {{ section.settings.btn_bg_color }};
    text-align: center;
    font-size: 16px;
    font-weight: 600;
    -moz-appearance: textfield;
    outline: none;
    background: #fff;
  }
  #inline-atc-{{ section.id }} .inline-atc__qty-input::-webkit-inner-spin-button,
  #inline-atc-{{ section.id }} .inline-atc__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #inline-atc-{{ section.id }} .inline-atc__add-btn {
    height: 48px;
    padding: 0 32px;
    border: none;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    letter-spacing: 0.3px;
  }
  #inline-atc-{{ section.id }} .inline-atc__add-btn:hover:not([disabled]) {
    opacity: 0.88;
    transform: translateY(-1px);
  }
  #inline-atc-{{ section.id }} .inline-atc__add-btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }
  @media (max-width: 480px) {
    #inline-atc-{{ section.id }} .inline-product-atc__controls {
      flex-direction: column;
    }
    #inline-atc-{{ section.id }} .inline-atc__add-btn {
      width: 100%;
      max-width: 320px;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('inline-atc-{{ section.id }}');
    if (!section) return;
    section.querySelectorAll('.inline-atc__qty-minus, .inline-atc__qty-plus').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var input = btn.closest('.inline-product-atc__qty-wrap').querySelector('.inline-atc__qty-input');
        var val = parseInt(input.value, 10) || 1;
        if (btn.classList.contains('inline-atc__qty-minus')) {
          if (val > 1) input.value = val - 1;
        } else {
          input.value = val + 1;
        }
      });
    });
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Quantity Selector + Add to Cart",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "product_handle",
      "label": "Product Handle",
      "info": "Enter the product handle (found in the product URL)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (optional)",
      "default": ""
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#202025"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "btn_soldout_label",
      "label": "Sold Out Label",
      "default": "Sold Out"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background",
      "default": "#d63447"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Quantity Selector + Add to Cart"
    }
  ]
}
{% endschema %}
