  /* Swipe down to close (mobile bottom sheet) */
  (function(){
    var dr=document.getElementById('tt360-drawer');
    var startY=0,startT=0,isDragging=false;
    dr.addEventListener('touchstart',function(e){
      if(e.touches.length!==1)return;
      startY=e.touches[0].clientY;startT=Date.now();isDragging=true;
    },{passive:true});
    dr.addEventListener('touchmove',function(e){
      if(!isDragging)return;
      var dy=e.touches[0].clientY-startY;
      if(dy>0){dr.style.transform='translateY('+dy+'px)';dr.style.transition='none';}
    },{passive:true});
    dr.addEventListener('touchend',function(e){
      if(!isDragging)return;isDragging=false;
      var dy=e.changedTouches[0].clientY-startY;
      var dt=Date.now()-startT;
      dr.style.transform='';dr.style.transition='';
      if(dy>80||(dy>40&&dt<250)){window.tt360DrawerClose();}
    },{passive:true});
  })();

  function fetchProd(handle,cb){
    if(!handle){cb(null);return;}
    if(productCache[handle]){cb(productCache[handle]);return;}
    fetch('/products/'+handle+'.js').then(function(r){return r.json();}).then(function(p){productCache[handle]=p;cb(p);}).catch(function(){cb(null);});
  }
  function fmtMoney(cents){return 'AED '+(cents/100).toFixed(0);}

  function updateCartIcon(count){
    var selectors='.cart-count,.cart__count,.cart-count-bubble,.header__cart-count,[data-cart-count],[id*="cart-count"],[class*="cart-count"]';
    document.querySelectorAll(selectors).forEach(function(el){
      if(el.tagName!=='A'&&el.tagName!=='BUTTON'&&el.tagName!=='SVG'){el.textContent=count;el.setAttribute('aria-label',count+' items');}
    });
    /* Try section render for header */
    fetch('/?sections=header').then(function(r){return r.json();}).then(function(d){
      if(!d||!d.header)return;
      var t=document.createElement('div');t.innerHTML=d.header;
      var nw=t.querySelector('.cart-count,.cart-count-bubble,[data-cart-count]');
      var cr=document.querySelector('.cart-count,.cart-count-bubble,[data-cart-count]');
      if(nw&&cr)cr.outerHTML=nw.outerHTML;
    }).catch(function(){});
    document.dispatchEvent(new CustomEvent('cart:updated',{detail:{count:count}}));
    document.dispatchEvent(new CustomEvent('theme:cart:update',{detail:{}}));
  }

  function renderGiftBag(){
    var el=document.getElementById('t-dr-gift');
    if(!el)return;
    var img=giftBagData&&giftBagData.images&&giftBagData.images[0]?
      giftBagData.images[0].src:GIFT_IMG_URL;
    var ctrlHtml=giftQty>0?
      '<div class="t-dr-qty" id="t-drg-stepper">'+
        '<button class="t-dr-q-btn'+(giftQty===1?' danger':'')+'" data-action="dec">'+(giftQty===1?'🗑':'−')+'</button>'+
        '<span class="t-dr-q-num">'+giftQty+'</span>'+
        '<button class="t-dr-q-btn" data-action="inc">+</button>'+
      '</div>':
      '<button class="t-dr-gift-btn" id="t-drg-btn">+ Add</button>';
    el.innerHTML='<div class="t-dr-gift-card'+(giftQty>0?' added':'')+'" id="t-drg-card">'+
      (img?'<img class="t-dr-gift-img" src="'+img+'" alt="TipTop Gift Bag">':'<span style="font-size:32px;flex-shrink:0">🎁</span>')+
      '<div class="t-dr-gift-info"><div class="t-dr-gift-title">🎁 TipTop Gift Box</div>'+
      '<div class="t-dr-gift-sub">AED '+giftBagPriceLbl+' — Make it a special gift!</div></div>'+
      ctrlHtml+'</div>';
    if(giftQty>0){
      var stepper=document.getElementById('t-drg-stepper');
      if(stepper){
        stepper.querySelectorAll('button').forEach(function(btn){
          btn.addEventListener('click',function(){
            var next=btn.dataset.action==='inc'?giftQty+1:giftQty-1;
            changeGiftQty(next);
          });
        });
      }
    }else{
      var addBtn=document.getElementById('t-drg-btn');
      if(addBtn){
        addBtn.addEventListener('click',function(){
          addBtn.textContent='…';addBtn.disabled=true;
          fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:giftBagVarId,quantity:1})})
            .then(function(){giftQty=1;giftBagAdded=true;renderGiftBag();renderAllCartItems();})
            .catch(function(){addBtn.textContent='+ Add';addBtn.disabled=false;});
        });
      }
    }
  }

  function changeGiftQty(newQty){
    var vid=giftBagVarId||GIFT_VAR_ID;
    fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({id:vid,quantity:Math.max(0,newQty)})
    }).then(function(r){return r.json();})
    .then(function(){
      giftQty=Math.max(0,newQty);
      giftBagAdded=giftQty>0;
      renderGiftBag();
      renderAllCartItems();
    })
    .catch(function(){toast('Could not update gift box');});
  }

  /* ── DRAWER STATE ── */
  var drawerQty=selectedQty;
  var upsellQtyMap={}; /* varId → qty in cart */
  var FREE_SHIP_THRESHOLD=10000; /* AED 100 in cents */

  /* ── SHIPPING BAR ── */
  function updateShippingBar(cartTotal){
    var bar=document.getElementById('t-dr-ship');
    var txt=document.getElementById('t-dr-ship-txt');
    var fill=document.getElementById('t-dr-ship-fill');
    if(!bar||!txt||!fill)return;
    if(cartTotal>=FREE_SHIP_THRESHOLD){
      bar.classList.add('done');
      txt.innerHTML='🎉 <strong>Free delivery unlocked!</strong>';
      fill.style.width='100%';
    }else{
      var remaining=fmtMoney(FREE_SHIP_THRESHOLD-cartTotal);
      bar.classList.remove('done');
      txt.innerHTML='Add <strong>'+remaining+'</strong> more for free delivery';
      fill.style.width=Math.min(Math.round(cartTotal/FREE_SHIP_THRESHOLD*100),99)+'%';
    }
  }

  /* ── ITEM COUNT IN HEADER ── */
  function updateItemCount(n){
    var el=document.getElementById('t-dr-count');
    if(el)el.textContent=n;
  }

  /* ── REFRESH TOTAL + SHIPPING BAR + COUNT ── */
  function refreshDrawerTotal(){
    return fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
      var tv=document.getElementById('t-dr-total-val');
      if(tv)tv.textContent=fmtMoney(cart.total_price);
      var co=document.querySelector('.t-dr-checkout');
      if(co)co.innerHTML='🔒 Secure Checkout — '+fmtMoney(cart.total_price);
      updateCartIcon(cart.item_count);
      updateItemCount(cart.item_count);
      updateShippingBar(cart.total_price);
      return cart;
    });
  }

  /* ── ADDED ITEM (main product) ── */
  function renderAddedItem(){
    var added=document.getElementById('t-dr-added');
    if(!added)return;
    var mainImg=document.getElementById('t-main-img');
    var imgSrc=mainImg?mainImg.src:'';
    var unitPrice=Math.round(basePrice*(1-selectedDisc/100));
