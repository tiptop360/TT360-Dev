{% comment %} tt360-product-body.liquid — Universal high-conversion product section {% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_images  = product.images %}
{% assign has_video       = false %}
{% for m in product.media %}
  {% if m.media_type == 'video' or m.media_type == 'external_video' %}{% assign has_video = true %}{% assign hero_video = m %}{% endif %}
{% endfor %}
{%- assign gift_handle  = section.settings.gift_bag_handle | default: 'gift-wrap-1' -%}
{%- assign gift_product = all_products[gift_handle] -%}
{%- if gift_product.featured_image -%}
  {%- assign gift_img_src = gift_product.featured_image | image_url: width: 160 -%}
{%- else -%}
  {%- assign gift_img_src = '' -%}
{%- endif -%}

{%- comment -%} ── PRELOAD HERO IMAGE ── {%- endcomment -%}
{%- if product_images.size > 0 -%}
  {%- assign hero_img = product_images[0] -%}
  <link rel="preload" as="image"
    imagesrcset="{{ hero_img | image_url: width: 400 }} 400w, {{ hero_img | image_url: width: 800 }} 800w, {{ hero_img | image_url: width: 1200 }} 1200w"
    imagesizes="(max-width:768px) 100vw, 50vw"
    href="{{ hero_img | image_url: width: 800 }}">
{%- endif -%}

{%- comment -%} ── SCHEMA: Product + Breadcrumbs (rendered inside section where product is available) ── {%- endcomment -%}
{%- assign v = product.selected_or_first_available_variant -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | strip_newlines | truncatewords: 50 | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  "image": [
    {%- for image in product.images limit: 5 -%}
      "https:{{ image | image_url: width: 1600 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  "sku": {{ v.sku | default: v.id | json }}
  {%- if v.barcode and v.barcode != blank -%}
    {%- assign barcode_len = v.barcode | size -%}
    {%- if barcode_len == 13 -%}
  ,"gtin13": {{ v.barcode | json }}
    {%- elsif barcode_len == 12 -%}
  ,"gtin12": {{ v.barcode | json }}
    {%- elsif barcode_len == 8 -%}
  ,"gtin8": {{ v.barcode | json }}
    {%- endif -%}
  {%- endif -%}
  ,"offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "{{ cart.currency.iso_code | default: 'AED' }}",
    "price": "{{ v.price | divided_by: 100.0 }}",
    "priceValidUntil": "{{ 'now' | date: '%s' | plus: 7776000 | date: '%Y-%m-%d' }}",
    "availability": "https://schema.org/{% if v.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": { "@type": "Organization", "name": "TipTop360" },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": { "@type": "MonetaryAmount", "value": "0", "currency": "AED" },
      "shippingDestination": { "@type": "DefinedRegion", "addressCountry": "AE" },
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": { "@type": "QuantitativeValue", "minValue": 0, "maxValue": 1, "unitCode": "d" },
        "transitTime": { "@type": "QuantitativeValue", "minValue": 1, "maxValue": 3, "unitCode": "d" }
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "AE",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
    {%- if v.compare_at_price > v.price -%}
    ,"priceSpecification": {
      "@type": "PriceSpecification",
      "price": {{ v.price | divided_by: 100.0 | json }},
      "priceCurrency": "{{ cart.currency.iso_code | default: 'AED' }}"
    }
    {%- endif -%}
  }
  {%- assign rating_val = section.settings.rating_value | default: product.metafields.custom.rating -%}
  {%- assign review_cnt = section.settings.review_count | default: product.metafields.custom.review_count -%}
  {%- if rating_val != blank -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ rating_val }}",
    "reviewCount": "{{ review_cnt | default: 1 }}",
    "bestRating": "5",
    "worstRating": "1"
  }
  {%- endif -%}
  {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
  {%- if review_blocks.size > 0 -%}
  ,"review": [
    {%- for block in review_blocks -%}
    {"@type":"Review","author":{"@type":"Person","name":{{ block.settings.name | json }}},"reviewRating":{"@type":"Rating","ratingValue":"{{ block.settings.stars }}"},"reviewBody":{{ block.settings.text | json }},"publisher":{"@type":"Organization","name":"TipTop360"}}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
  {%- endif -%}
  {%- assign spec_blocks = section.blocks | where: 'type', 'spec' -%}
  {%- if spec_blocks.size > 0 -%}
  ,"additionalProperty": [
    {%- for block in spec_blocks -%}
    {"@type":"PropertyValue","name":{{ block.settings.spec_name | json }},"value":{{ block.settings.spec_value | json }}}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
  {%- endif -%}
  {%- assign min_age = section.settings.audience_min_age -%}
  {%- assign max_age = section.settings.audience_max_age -%}
  {%- if min_age == blank and product.tags contains 'kids' -%}
    {%- assign min_age = '2' -%}
    {%- assign max_age = '12' -%}
  {%- endif -%}
  {%- if min_age != blank and max_age != blank -%}
  ,"audience": {
    "@type": "PeopleAudience",
    "suggestedMinAge": "{{ min_age }}",
    "suggestedMaxAge": "{{ max_age }}"
  }
  {%- endif -%}
}
</script>
{%- assign bc_handle = section.settings.collection_handle -%}
{%- assign bc_name = section.settings.collection_name -%}
{%- if bc_handle == blank -%}
  {%- assign bc_col = collection | default: product.collections.first -%}
  {%- if bc_col -%}
    {%- assign bc_handle = bc_col.handle -%}
    {%- assign bc_name = bc_col.title -%}
  {%- endif -%}
{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ shop.url }}" }
    {%- if bc_handle != blank -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ bc_name | json }}, "item": "{{ shop.url }}/collections/{{ bc_handle }}" }
    ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": "{{ shop.url }}{{ product.url }}" }
    {%- else -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": "{{ shop.url }}{{ product.url }}" }
    {%- endif -%}
  ]
}
</script>

{%- assign step_blocks = section.blocks | where: 'type', 'step' -%}
{%- if section.settings.howto_schema_enable and step_blocks.size > 0 -%}
{%- assign ht_name = section.settings.howto_name | default: product.title | append: ' — How It Works' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": {{ ht_name | json }},
  "description": {{ section.settings.howto_desc | default: product.description | strip_html | truncatewords: 40 | json }},
  "totalTime": "{{ section.settings.howto_time | default: 'PT2M' }}",
  "image": "https:{{ product.featured_image | image_url: width: 1200 }}",
  "step": [
    {%- for block in step_blocks -%}
    {
      "@type": "HowToStep",
      "position": {{ forloop.index }},
      "name": {{ block.settings.title | json }},
      "text": {{ block.settings.desc | json }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} ── SCHEMA: VideoObject (auto-generated from video section settings) ── {%- endcomment -%}
{%- if section.settings.video_enable -%}
  {%- assign vurl = section.settings.section_video -%}
  {%- assign vid_id = nil -%}
  {%- assign vid_embed = nil -%}
  {%- if vurl contains 'youtube.com/shorts/' -%}
    {%- assign vid_id = vurl | split: '/shorts/' | last | split: '?' | first -%}
  {%- elsif vurl contains 'youtube.com/watch' -%}
    {%- assign vid_id = vurl | split: 'v=' | last | split: '&' | first -%}
  {%- elsif vurl contains 'youtu.be/' -%}
    {%- assign vid_id = vurl | split: 'youtu.be/' | last | split: '?' | first -%}
  {%- endif -%}
  {%- if vid_id != blank -%}
    {%- assign vid_embed = 'https://www.youtube.com/embed/' | append: vid_id -%}
    {%- assign vid_thumb = 'https://img.youtube.com/vi/' | append: vid_id | append: '/maxresdefault.jpg' -%}
  {%- elsif has_video -%}
    {%- assign vid_thumb = product.featured_image | image_url: width: 1200 | prepend: 'https:' -%}
  {%- endif -%}
  {%- if vid_id != blank or has_video -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": {{ section.settings.video_title | default: product.title | append: ' — Demo' | json }},
  "description": {{ section.settings.video_sub | default: product.description | strip_html | truncatewords: 30 | json }},
  "thumbnailUrl": "{{ vid_thumb }}",
  "uploadDate": "{{ product.published_at | date: '%Y-%m-%d' }}"
  {%- if vid_embed != blank -%}
  ,"embedUrl": "{{ vid_embed }}"
  {%- endif -%}
  ,"publisher": {
    "@type": "Organization",
    "name": "TipTop360",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tiptop360.com/cdn/shop/files/Logo.png?v=1760682550&width=200"
    }
  }
}
</script>
  {%- endif -%}
{%- endif -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

{%- comment -%} ── META INJECTION ── {%- endcomment -%}
<script>
/* Gap removal — definitive walk-up/walk-down approach, no guessing */
(function(){
  function rmGap(){
    var sec=document.getElementById('shopify-section-tt360-product-body');
    if(!sec)return;
    /* Zero the section itself */
    sec.style.setProperty('margin','0','important');
    sec.style.setProperty('padding','0','important');
    /* TOP GAP: walk up all ancestors and zero any that have padding-top or margin-top */
    var el=sec.parentElement;
    while(el&&el!==document.body&&el!==document.documentElement){
      try{
        var cs=window.getComputedStyle(el);
        var pt=parseFloat(cs.paddingTop)||0;
        var mt=parseFloat(cs.marginTop)||0;
        if(pt>0)el.style.setProperty('padding-top','0','important');
        if(mt>0)el.style.setProperty('margin-top','0','important');
      }catch(e){}
      el=el.parentElement;
    }
    /* Previous sibling bottom gap */
    var prev=sec.previousElementSibling;
    if(prev){prev.style.setProperty('margin-bottom','0','important');prev.style.setProperty('padding-bottom','0','important');}
    /* BOTTOM GAP: walk forward through all siblings after section */
    var nxt=sec.nextElementSibling;
    while(nxt){
      nxt.style.setProperty('margin-top','0','important');
      nxt.style.setProperty('padding-top','0','important');
      nxt=nxt.nextElementSibling;
    }
    /* Also zero next siblings of the parent (e.g. footer wrapper) */
    var par=sec.parentElement;
    if(par&&par!==document.body){
      par.style.setProperty('padding-bottom','0','important');
      par.style.setProperty('margin-bottom','0','important');
      var ps=par.nextElementSibling;
      while(ps){
        ps.style.setProperty('margin-top','0','important');
        ps.style.setProperty('padding-top','0','important');
        ps=ps.nextElementSibling;
      }
    }
    /* Footer elements — belt and suspenders */
    document.querySelectorAll('footer,.site-footer,#footer,#shopify-section-footer,[id*="footer"],[class*="site-footer"]').forEach(function(f){
      f.style.setProperty('margin-top','0','important');
      f.style.setProperty('padding-top','0','important');
    });
    /* Mobile: zero body padding-bottom (theme adds it for sticky bar) */
    if(window.innerWidth<=768){
      document.body.style.setProperty('padding-bottom','0','important');
    }
  }
  rmGap();
  if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',rmGap);}
  window.addEventListener('load',function(){rmGap();setTimeout(rmGap,500);});
})();
</script>

