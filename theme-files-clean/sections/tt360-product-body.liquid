      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ═══ VIDEO ═══ -->
{% if section.settings.video_enable %}
<section class="t-vid-sec t-ctr" aria-labelledby="t-vid-title">
  <div class="t-wrap">
    {% if section.settings.video_lbl != blank %}<div class="t-lbl">{{ section.settings.video_lbl }}</div>{% endif %}
    <h2 class="t-h2" id="t-vid-title">{{ section.settings.video_title | default: 'See It in Action' }}</h2>
    <p class="t-sub" style="margin-bottom:28px;color:rgba(255,255,255,.65)">{{ section.settings.video_sub }}</p>
    <div class="t-vid-box">
      {%- if section.settings.section_video != blank -%}
        {%- assign vurl = section.settings.section_video -%}
        {%- assign vid_id = '' -%}
        {%- assign vid_provider = '' -%}
        {%- if vurl contains 'youtube.com/shorts/' -%}
          {%- assign vid_id = vurl | split: '/shorts/' | last | split: '?' | first -%}
          {%- assign vid_provider = 'youtube' -%}
        {%- elsif vurl contains 'youtube.com/watch' -%}
          {%- assign vid_id = vurl | split: 'v=' | last | split: '&' | first -%}
          {%- assign vid_provider = 'youtube' -%}
        {%- elsif vurl contains 'youtu.be/' -%}
          {%- assign vid_id = vurl | split: 'youtu.be/' | last | split: '?' | first -%}
          {%- assign vid_provider = 'youtube' -%}
        {%- elsif vurl contains 'vimeo.com/' -%}
          {%- assign vid_id = vurl | split: 'vimeo.com/' | last | split: '?' | first -%}
          {%- assign vid_provider = 'vimeo' -%}
        {%- endif -%}
        {%- if vid_provider == 'youtube' and vid_id != blank -%}
          <div class="tt360-yt-lite" data-vid="{{ vid_id }}" tabindex="0" role="button" aria-label="Play {{ product.title | escape }} video"
            style="background:url(https://i.ytimg.com/vi/{{ vid_id }}/hqdefault.jpg) center/cover no-repeat;cursor:pointer;position:relative;width:100%;height:100%">
            <svg class="tt360-yt-play" viewBox="0 0 68 48" width="68" height="48" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
          </div>
          <script>
          (function(){var c=document.querySelector('.tt360-yt-lite[data-vid="{{ vid_id }}"]');if(!c)return;function go(){var f=document.createElement('iframe');f.src='https://www.youtube.com/embed/{{ vid_id }}?rel=0&playsinline=1&autoplay=1';f.allow='autoplay;encrypted-media';f.allowFullscreen=true;f.style.cssText='width:100%;height:100%;border:0';c.innerHTML='';c.appendChild(f)}c.addEventListener('click',go,{once:true});c.addEventListener('keydown',function(e){if(e.key==='Enter')go()},{once:true})})();
          </script>
        {%- elsif vid_provider == 'vimeo' and vid_id != blank -%}
          <iframe src="https://player.vimeo.com/video/{{ vid_id }}?dnt=1"
            allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy"
            title="{{ product.title | escape }} video" style="width:100%;height:100%;border:0"></iframe>
        {%- endif -%}
      {%- elsif has_video -%}
        {%- if hero_video.media_type == 'video' -%}
          <video controls preload="metadata" playsinline
            poster="{{ product_images[0] | image_url: width: 800 }}"
            style="width:100%;height:100%;object-fit:cover">
            {%- for src in hero_video.sources -%}
            <source src="{{ src.url }}" type="{{ src.mime_type }}">
            {%- endfor -%}
          </video>
        {%- elsif hero_video.media_type == 'external_video' -%}
          {%- assign ext_vid_id = hero_video.external_id -%}
          <div class="tt360-yt-lite" data-vid="{{ ext_vid_id }}" tabindex="0" role="button" aria-label="Play {{ product.title | escape }} video"
            style="background:url(https://i.ytimg.com/vi/{{ ext_vid_id }}/hqdefault.jpg) center/cover no-repeat;cursor:pointer;position:relative;width:100%;height:100%">
            <svg class="tt360-yt-play" viewBox="0 0 68 48" width="68" height="48" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)"><path d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z" fill="red"/><path d="M45 24L27 14v20" fill="#fff"/></svg>
          </div>
          <script>
          (function(){var c=document.querySelector('.tt360-yt-lite[data-vid="{{ ext_vid_id }}"]');if(!c)return;function go(){var f=document.createElement('iframe');f.src='https://www.youtube.com/embed/{{ ext_vid_id }}?rel=0&playsinline=1&autoplay=1';f.allow='autoplay;encrypted-media';f.allowFullscreen=true;f.style.cssText='width:100%;height:100%;border:0';c.innerHTML='';c.appendChild(f)}c.addEventListener('click',go,{once:true});c.addEventListener('keydown',function(e){if(e.key==='Enter')go()},{once:true})})();
          </script>
        {%- endif -%}
      {%- else -%}
        <div class="t-vid-ph">
          <div class="ring">▶</div>
          <p>{{ section.settings.video_placeholder | default: 'Product video coming soon — check back shortly.' }}</p>
          <p style="font-size:11px;opacity:.5">Add via Theme Editor → Video Section → paste YouTube/Vimeo URL, or upload video to the product in Admin → Products → Media</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
{% endif %}

