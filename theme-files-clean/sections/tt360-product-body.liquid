    if(infoEl){
      [infoEl.querySelector('.t-swatches'),infoEl.querySelector('#t-size-pills')].forEach(function(el){
        if(!el)return;
        el.style.display='none';
        var prev=el.previousElementSibling;
        if(prev&&prev.classList.contains('t-opt-lbl'))prev.style.display='none';
      });
    }
    function setQty(q){
      q=Math.max(1,Math.min(bmsMax,q));
      selectedQty=q;
      if(minusBtn)minusBtn.disabled=q<=1;
      if(plusBtn)plusBtn.disabled=q>=bmsMax;
      bmsItems=[];
      renderBmsItemPickers(q);
      updatePriceDisplay();
    }
    if(minusBtn)minusBtn.addEventListener('click',function(){setQty(selectedQty-1);});
    if(plusBtn)plusBtn.addEventListener('click',function(){setQty(selectedQty+1);});
    setQty(1);
