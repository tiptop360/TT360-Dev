                }
              },
              {
                "@type": "Question",
                "name": "Can I speak to someone if I have a question?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "Email us at info@tiptop360.com or call or WhatsApp +971 58 515 6033. Our team is available daily."
                }
