            ]
          }
          {%- endif -%}
        ]
      }
    </script>

  {%- comment -%} 4. TRACKING: Consolidated GTM and Clarity {%- endcomment -%}
  <script async src="https://www.googletagmanager.com/gtag/js?id=GT-NC6ZVVHK"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'GT-NC6ZVVHK');
    gtag('config', 'AW-17211943737');
  </script>
<meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin">
<meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()">

{%- render 'mobile-first-css' -%}
{%- render 'blog-author-schema' -%}

  {%- if template == 'index' -%}
  {%- assign lcp_product = collections['new-arrivals-top-selling-products-in-uae'].products.first -%}
  {%- if lcp_product and lcp_product.featured_image -%}
  <link rel="preload" as="image"
    href="{{ lcp_product.featured_image | image_url: width: 600 }}"
    imagesrcset="{{ lcp_product.featured_image | image_url: width: 300 }} 300w, {{ lcp_product.featured_image | image_url: width: 600 }} 600w"
    imagesizes="(max-width: 768px) 100vw, 600px">
  {%- endif -%}
  {%- endif -%}
{%- render 'critical-css' -%}
</head>

<body class="template-{{ template.name | handle }}">
  <div id="page-container">
    {%- sections 'header-group' -%}

    <main role="main" id="MainContent">
      {%- if template.name == 'index' -%}
        {%- section 'slideshow-3' -%}
      {%- endif -%}
      {{ content_for_layout }}
    </main>

    {%- sections 'footer-group' -%}
    {%- liquid
      section 'pnewsletter'
      section 'product-suggest'
      section 'cookie-policy'
    -%}
  </div>

  {%- liquid
    render 'back-to-top'
    render 'menu-mobile'
    render 'header-js'
  -%}

  {%- comment -%} 5. SCRIPTS: Optimized load order {%- endcomment -%}
  <!-- jQuery removed: Shopify theme already loads jQuery via api.jquery -->
  <script src="{{ 'lazysizes.min.js' | asset_url }}" defer></script>
  <script src="{{ 'vendor.s.min.js' | asset_url }}" defer></script>
  <script src="{{ 'global.s.min.js' | asset_url }}" defer></script>
  
  <script>
    // Toggle chat button when mini-cart is open without using heavy intervals
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          const chatBtn = document.getElementById('carthike-chat-button-container');
          if (chatBtn) {
            chatBtn.style.display = mutation.target.classList.contains('active') ? 'none' : '';
          }
        }
      });
    });

    const pageContainer = document.getElementById('page-container');
    if (pageContainer) {
      observer.observe(pageContainer, {
        attributes: true,
        attributeFilter: ['class'],
        subtree: true
      });
    }
  </script>
</body>
</html>
