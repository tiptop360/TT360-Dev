{%- comment -%}
  AiVox PDP — Custom Product Section
  Template: product.aivox
  Validated: 83/83 checks · 2026-05-04
  Handles: gallery, info, specs, features, guarantee, reviews, faq, sticky ATC
{%- endcomment -%}

{%- assign product_url = product.url -%}
{%- assign variant    = product.selected_or_first_available_variant -%}
{%- assign price      = product.price | money -%}
{%- assign compare    = product.compare_at_price | money -%}
{%- assign has_sale = false -%}
{%- if product.compare_at_price > product.price -%}{%- assign has_sale = true -%}{%- endif -%}

{{ 'section-aivox-pdp.css' | asset_url | stylesheet_tag }}

<div class="aivox-pdp">

  {%- comment -%} TOP BAR {%- endcomment -%}
  <div class="aivox-topbar">
    Free UAE Delivery · Cash on Delivery · 1 Year Unlimited Transcription Exclusive
  </div>

  {%- comment -%} BREADCRUMB {%- endcomment -%}
  <div class="aivox-crumb">
    <a href="{{ routes.root_url }}">Home</a> ›
    <a href="{{ routes.collections_url }}"> Tech</a> ›
    {{ product.title | truncate: 40 }}
  </div>

  {%- comment -%} GALLERY {%- endcomment -%}
  <div class="aivox-gallery">
    <div class="aivox-stage" id="aivox-stage">
      <button class="aivox-arr aivox-arr-l" onclick="aivoxSlide(-1)" aria-label="Previous image">‹</button>
      <button class="aivox-arr aivox-arr-r" onclick="aivoxSlide(1)"  aria-label="Next image">›</button>
      <span class="aivox-ctr" id="aivox-ctr">1 / {{ product.images.size }}</span>

      {%- for image in product.images -%}
        <div class="aivox-slide{% if forloop.first %} active{% endif %}">
          <img
            src="{{ image | image_url: width: 700 }}"
            alt="{{ image.alt | default: product.title | escape }}"
            {% if forloop.first %}loading="eager"{% else %}loading="lazy"{% endif %}
            width="700" height="700"
          >
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Thumbnail strip — built by JS from Liquid JSON {%- endcomment -%}
    <div class="aivox-thumbs" id="aivox-thumbs"></div>
  </div>

  {%- comment -%} PRODUCT INFO {%- endcomment -%}
  <div class="aivox-info aivox-f1">

    <div class="aivox-cat">AI Voice Recorder · Dubai UAE</div>

    <h1 class="aivox-title">
      GPT-4 AiVox —<br>
      <em>Your meetings, written.</em>
    </h1>

    <div class="aivox-rating">
      <span class="aivox-stars">★★★★★</span>
      <span class="aivox-rtxt">4.9 · 45 reviews</span>
      <span class="aivox-sold">🔥 34 sold today</span>
    </div>

    {%- comment -%} PRICE {%- endcomment -%}
    <div class="aivox-price-block aivox-f2">
      <div>
        <span class="aivox-price-main">{{ product.price | money }}</span>
        {%- if has_sale -%}
          <span class="aivox-price-was">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
      {%- if has_sale -%}
        {%- assign saving_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
        <span class="aivox-price-save">{{ saving_pct }}% OFF · Inclusive of VAT · Free UAE Delivery</span>
      {%- else -%}
        <span class="aivox-price-save">Inclusive of VAT · Free UAE Delivery</span>
      {%- endif -%}
    </div>

    {%- comment -%} EXCLUSIVE DEAL {%- endcomment -%}
    <div class="aivox-deal aivox-f3">
      <div class="aivox-deal-lbl">TipTop360 Exclusive — Only Here</div>
      <div class="aivox-deal-h">
        1 Year Unlimited Transcription<br>
        <em>Then 400 min / month — no extra cost</em>
      </div>
      <div class="aivox-deal-list" style="margin-top:10px;">
        <div class="aivox-deal-pt">Year 1: unlimited transcription — completely free, no limits</div>
        <div class="aivox-deal-pt">After year 1: 400 free minutes every month — no subscription, no charges</div>
        <div class="aivox-deal-pt">64GB local storage built-in — record offline, no cloud required</div>
        <div class="aivox-deal-pt">No other UAE retailer offers this deal</div>
      </div>
    </div>

    {%- comment -%} STOCK URGENCY {%- endcomment -%}
    {%- if variant.inventory_quantity > 0 and variant.inventory_quantity <= 20 -%}
      <div class="aivox-stock aivox-f3">
        <span class="aivox-sdot"></span>
        Only {{ variant.inventory_quantity }} units left in UAE stock · Ships today
      </div>
    {%- elsif variant.available -%}
      <div class="aivox-stock aivox-f3" style="color:var(--teal);">
        <span class="aivox-sdot" style="background:var(--teal);"></span>
        In stock · Ships from UAE today
      </div>
    {%- endif -%}

    {%- comment -%} CTAs {%- endcomment -%}
    <div class="aivox-f4">

      {%- comment -%} Buy Now COD → primary button, goes directly to checkout {%- endcomment -%}
      <form action="{{ routes.cart_add_url }}" method="post" id="aivox-buynow-form">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" class="aivox-btn-cod" style="background:var(--coral);color:#fff;border-color:var(--coral);">
          ⚡ Buy Now · Pay Cash on Delivery
        </button>
      </form>

      {%- comment -%} TT360 unified delivery widgets: smart ETA + cutoff countdown {%- endcomment -%}
      {% render 'tt360-estimated-delivery' %}
      {% render 'tt360-delivery-countdown' %}

      {%- comment -%} Add to Cart → also goes to checkout {%- endcomment -%}
      <form action="{{ routes.cart_add_url }}" method="post" id="aivox-cart-form">
        <input type="hidden" name="id" value="{{ variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="aivox-btn-cart" name="add">
          🛒 Add to Cart — {{ product.price | money }}
        </button>
      </form>

      <a href="https://wa.me/971585156033" class="aivox-btn-wa" target="_blank" rel="noopener">
        <span style="font-size:16px;">💬</span> Questions? WhatsApp +971 58 515 6033
      </a>

      {%- comment -%} TT360 unified payment icons block {%- endcomment -%}
      {% render 'tt360-payment-icons' %}

      <div class="aivox-secure">🔒 SSL encrypted · Secure checkout · Apple Pay · Cards accepted</div>
    </div>
  </div>

  {%- comment -%} TRUST PILLS {%- endcomment -%}
  <div class="aivox-trust aivox-f5">
    <div class="aivox-pill">⚡ Next-Day Delivery</div>
