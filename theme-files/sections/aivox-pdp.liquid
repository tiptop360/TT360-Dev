<script>
(function() {
  'use strict';

  // ── IMAGE DATA FROM LIQUID ──────────────────────────────
  var IMGS = [
    {%- for image in product.images -%}
      {
        src:   '{{ image | image_url: width: 700 }}',
        thumb: '{{ image | image_url: width: 120 }}',
        alt:   '{{ image.alt | default: product.title | escape }}'
      }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  var cur = 0;
  var autoTimer;
  var slides   = document.querySelectorAll('.aivox-slide');
  var ctrEl    = document.getElementById('aivox-ctr');
  var thumbsEl = document.getElementById('aivox-thumbs');

  // Build thumbnail strip
  IMGS.forEach(function(img, i) {
    var t  = document.createElement('div');
    t.className = 'aivox-thumb' + (i === 0 ? ' on' : '');
    var im = document.createElement('img');
    im.src     = img.thumb;
    im.alt     = img.alt;
    im.loading = 'lazy';
    im.width   = 52;
    im.height  = 52;
    t.appendChild(im);
    t.addEventListener('click', function() { aivoxGoTo(i); });
    thumbsEl.appendChild(t);
  });

  window.aivoxGoTo = function(n) {
    slides[cur].classList.remove('active');
    thumbsEl.querySelectorAll('.aivox-thumb')[cur].classList.remove('on');
    cur = ((n % IMGS.length) + IMGS.length) % IMGS.length;
    slides[cur].classList.add('active');
    var newThumb = thumbsEl.querySelectorAll('.aivox-thumb')[cur];
    newThumb.classList.add('on');
    newThumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    if (ctrEl) ctrEl.textContent = (cur + 1) + ' / ' + IMGS.length;
    clearInterval(autoTimer);
    autoTimer = setInterval(function() { window.aivoxSlide(1); }, 4200);
  };

  window.aivoxSlide = function(dir) {
    aivoxGoTo(cur + dir);
  };

  // Touch swipe
  var touchX = 0;
  var stage = document.getElementById('aivox-stage');
  if (stage) {
    stage.addEventListener('touchstart', function(e) {
      touchX = e.touches[0].clientX;
    }, { passive: true });
    stage.addEventListener('touchend', function(e) {
      var dx = touchX - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) window.aivoxSlide(dx > 0 ? 1 : -1);
    }, { passive: true });
  }

  autoTimer = setInterval(function() { window.aivoxSlide(1); }, 4200);

  // ── ADD TO CART → REDIRECT TO CHECKOUT ─────────────────
  var cartForm = document.getElementById('aivox-cart-form');
  if (cartForm) {
    cartForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var id  = cartForm.querySelector('[name="id"]').value;
      var qty = cartForm.querySelector('[name="quantity"]').value || 1;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: parseInt(id), quantity: parseInt(qty) })
      }).then(function() {
        window.location.href = '/checkout';
      }).catch(function() {
        window.location.href = '/checkout';
      });
    });
  }

  // ── FAQ ACCORDION ───────────────────────────────────────
  var FAQS = [
    ['What makes AiVox different from a regular voice recorder?',
     'AiVox uses GPT-4 AI to transcribe at 98% accuracy and auto-generate meeting minutes in under 60 seconds. It has 64GB of local storage so everything stays on the device. A regular recorder only captures raw audio — no transcription, no summaries, no AI.'],
    ['What exactly is the 1-year unlimited + 400 min/month deal?',
     'Your entire first year of transcription is unlimited and completely free — no limits, no charges. After year 1, you get 400 transcription minutes free every month, permanently, at no extra cost. This exclusive deal is only available when you buy from TipTop360.'],
    ['What is the 64GB local storage and do I need cloud?',
     'No cloud required. AiVox has 64GB of built-in local storage — enough for thousands of hours of recordings stored privately on the device. You can also sync to the app if you want cloud access, but it is completely optional.'],
    ['Does AiVox transcribe in Arabic?',
     'Yes. AiVox transcribes in 134 languages including Arabic and English. It handles bilingual UAE meetings — Arabic and English mixed in the same recording — at 98% accuracy.'],
    ['Can I pay Cash on Delivery in UAE?',
     'Yes — across all UAE Emirates including Dubai, Abu Dhabi, Sharjah, Ajman, and Ras Al Khaimah. AED 450. Order before 5pm for next-day delivery.'],
    ['Does it work without internet?',
     'Yes. The device records offline at full audio quality anywhere — basements, remote areas, international travel. All 64GB local storage is available offline. Transcription processes automatically when you next connect to WiFi.'],
    ['What is the 14-day guarantee?',
     'Return AiVox for any reason within 14 days of delivery for a full refund. No questions asked. TipTop360 processes UAE returns within 48 hours.']
  ];

  var faqEl = document.getElementById('aivox-faq');
  if (faqEl) {
    FAQS.forEach(function(pair) {
      var q = pair[0], a = pair[1];
      var item   = document.createElement('div');
      item.className = 'aivox-faq-item';
      var ansEl  = document.createElement('div');
      ansEl.className = 'aivox-faq-a';
      ansEl.textContent = a;
      var icEl   = document.createElement('span');
      icEl.className = 'aivox-faq-ic';
      icEl.textContent = '+';
      var hd     = document.createElement('div');
      hd.className = 'aivox-faq-q';
      hd.setAttribute('role', 'button');
      hd.setAttribute('tabindex', '0');
      hd.setAttribute('aria-expanded', 'false');
      var qt     = document.createElement('span');
      qt.textContent = q;
      hd.appendChild(qt);
      hd.appendChild(icEl);
      item.appendChild(hd);
      item.appendChild(ansEl);
      faqEl.appendChild(item);

      function toggle() {
        var isOpen = item.classList.contains('open');
        faqEl.querySelectorAll('.aivox-faq-item').forEach(function(el) {
          el.classList.remove('open');
          el.querySelector('.aivox-faq-q').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          hd.setAttribute('aria-expanded', 'true');
        }
      }
      hd.addEventListener('click', toggle);
      hd.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
      });
    });
  }

})();
</script>

