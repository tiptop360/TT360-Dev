<!-- STICKY MOBILE ATC -->
<div id="tt360-upsell-sticky">
  <button id="u-sticky-btn">🛒 Add to Cart — {{ current_variant.price | money_without_trailing_zeros }}</button>
</div>

<!-- LIGHTBOX -->
<div id="tt360-upsell-lb" aria-hidden="true">
  <button id="tt360-upsell-lb-close" aria-label="Close">×</button>
  <img src="" alt="">
</div>

<!-- ═══ JAVASCRIPT ═══ -->
<script>
(function(){
  var product = {{ product | json }};
  var variants = product.variants;
  var currentVariant = variants.find(function(v){return v.id === {{ current_variant.id }};}) || variants[0];
  var qty = 1;

  /* Thumbnail gallery */
  var thumbs = document.querySelectorAll('#tt360-upsell .u-thumb');
  var mainImg = document.getElementById('u-main-img');
  thumbs.forEach(function(t){
    t.addEventListener('click',function(){
      thumbs.forEach(function(x){x.classList.remove('active')});
      t.classList.add('active');
      if(mainImg){
        mainImg.src = t.dataset.src;
        mainImg.srcset = t.dataset.srcset || '';
        mainImg.alt = t.dataset.alt || '';
      }
    });
  });

  /* Lightbox */
  if(mainImg){
    mainImg.addEventListener('click',function(){
      var lb = document.getElementById('tt360-upsell-lb');
      var lbImg = lb.querySelector('img');
      lbImg.src = mainImg.src;
      lb.classList.add('open');
      lb.setAttribute('aria-hidden','false');
    });
  }
  var lbClose = document.getElementById('tt360-upsell-lb-close');
  var lb = document.getElementById('tt360-upsell-lb');
  if(lbClose) lbClose.addEventListener('click',function(){lb.classList.remove('open');lb.setAttribute('aria-hidden','true');});
  if(lb) lb.addEventListener('click',function(e){if(e.target===lb){lb.classList.remove('open');lb.setAttribute('aria-hidden','true');}});

  /* Variant pills */
  var pillGroups = document.querySelectorAll('#tt360-upsell .u-size-pills');
  pillGroups.forEach(function(group){
    var pills = group.querySelectorAll('.u-size-pill');
    pills.forEach(function(pill){
      pill.addEventListener('click',function(){
        pills.forEach(function(p){p.classList.remove('active')});
        pill.classList.add('active');
        var idx = parseInt(group.dataset.optionIndex);
        var chosenEl = document.getElementById('u-chosen-'+idx);
        if(chosenEl) chosenEl.textContent = pill.dataset.value;
        selectVariant();
      });
    });
  });

  function selectVariant(){
    var selected = [];
    pillGroups.forEach(function(g){
      var active = g.querySelector('.u-size-pill.active');
      if(active) selected.push(active.dataset.value);
    });
    var match = variants.find(function(v){
      for(var i=0;i<selected.length;i++){
        if(v.options[i] !== selected[i]) return false;
      }
      return true;
    });
    if(match){
      currentVariant = match;
      updatePrice();
    }
  }

  function updatePrice(){
    var priceNow = document.querySelector('#tt360-upsell .u-price-now');
    if(priceNow) priceNow.textContent = formatMoney(currentVariant.price);
    var atcLabel = document.getElementById('u-atc-label');
    if(atcLabel) atcLabel.textContent = '{{ section.settings.atc_text | default: "Add to Cart" }} — ' + formatMoney(currentVariant.price * qty);
    var stickyBtn = document.getElementById('u-sticky-btn');
    if(stickyBtn) stickyBtn.textContent = '🛒 Add to Cart — ' + formatMoney(currentVariant.price * qty);
    var finalBtn = document.getElementById('u-btn-final');
    if(finalBtn) finalBtn.textContent = '🛒 {{ section.settings.atc_text | default: "Add to Cart" }} — ' + formatMoney(currentVariant.price * qty);
  }

  function formatMoney(cents){
    return 'Dhs. ' + (cents/100).toFixed(cents%100===0?0:2);
  }

  /* QTY */
  var minusBtn = document.getElementById('u-qty-minus');
  var plusBtn = document.getElementById('u-qty-plus');
  var qtyVal = document.getElementById('u-qty-val');
  if(plusBtn) plusBtn.addEventListener('click',function(){if(qty<10){qty++;qtyVal.textContent=qty;minusBtn.disabled=false;updatePrice();}});
  if(minusBtn) minusBtn.addEventListener('click',function(){if(qty>1){qty--;qtyVal.textContent=qty;if(qty===1)minusBtn.disabled=true;updatePrice();}});

  /* ATC */
  function addToCart(btn){
    if(!currentVariant||!currentVariant.available)return;
    btn.classList.add('loading');
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({items:[{id:currentVariant.id,quantity:qty}]})
    }).then(function(r){return r.json()}).then(function(){
      btn.classList.remove('loading');
      btn.classList.add('done');
      showToast('✓ Added to cart!');
      setTimeout(function(){btn.classList.remove('done')},2000);
      /* Open cart drawer if available */
      if(window.tt360OpenDrawer) window.tt360OpenDrawer();
    }).catch(function(){
      btn.classList.remove('loading');
      showToast('Error — please try again');
    });
  }

  var atcBtn = document.getElementById('u-atc-btn');
  if(atcBtn) atcBtn.addEventListener('click',function(){addToCart(atcBtn)});
  var stickyBtn2 = document.getElementById('u-sticky-btn');
  if(stickyBtn2) stickyBtn2.addEventListener('click',function(){addToCart(stickyBtn2)});
  var finalBtn2 = document.getElementById('u-btn-final');
  if(finalBtn2) finalBtn2.addEventListener('click',function(){addToCart(finalBtn2)});

  /* Toast */
  function showToast(msg){
    var t=document.getElementById('tt360-upsell-toast');
    if(!t)return;t.textContent=msg;t.classList.add('show');
    setTimeout(function(){t.classList.remove('show')},2800);
  }

  /* Bundle ATC */
  var bundleBtn = document.getElementById('u-btn-bundle');
  if(bundleBtn){
    bundleBtn.addEventListener('click',function(){
      bundleBtn.classList.add('loading');
      var cid = parseInt(bundleBtn.dataset.currentId);
      var hid = parseInt(bundleBtn.dataset.heroId);
      fetch('/cart/add.js',{
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body:JSON.stringify({items:[{id:cid,quantity:1},{id:hid,quantity:1}]})
      }).then(function(r){return r.json()}).then(function(){
        bundleBtn.classList.remove('loading');
        bundleBtn.classList.add('done');
        showToast('✓ Both items added to cart!');
        setTimeout(function(){bundleBtn.classList.remove('done')},2000);
        if(window.tt360OpenDrawer) window.tt360OpenDrawer();
      }).catch(function(){
        bundleBtn.classList.remove('loading');
        showToast('Error — please try again');
      });
    });
  }

  /* FAQ accordion */
  document.querySelectorAll('#tt360-upsell .u-faq-q').forEach(function(q){
    q.addEventListener('click',function(){
      var item=q.parentElement;
      var isOpen=item.classList.contains('open');
      document.querySelectorAll('#tt360-upsell .u-faq-item').forEach(function(x){x.classList.remove('open')});
      if(!isOpen)item.classList.add('open');
      q.setAttribute('aria-expanded',(!isOpen).toString());
    });
  });
})();
</script>

