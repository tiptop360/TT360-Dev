{% comment %}
Updated: sections/screenfree-age-tabs-uae-2026.liquid
Supports single + multiple product layouts
{% endcomment %}

<section class="screenfree-age-tabs-uae-2026">
  <div class="page-width">
    
    <h2 class="section-title">{{ section.settings.heading }}</h2>

    <!-- TAB BUTTONS -->
    <div class="tabs-nav">
      {% for block in section.blocks %}
        <button 
          class="tab-btn {% if forloop.first %}active{% endif %}" 
          data-tab="tab-{{ block.id }}"
        >
          {{ block.settings.tab_title }}
        </button>
      {% endfor %}
    </div>

    <!-- TAB CONTENT -->
    {% for block in section.blocks %}
      {% assign product_count = block.settings.products.count %}
      
      <div 
        id="tab-{{ block.id }}" 
        class="tab-content {% if forloop.first %}active{% endif %}"
      >

        <div class="product-grid {% if product_count == 1 %}single-product{% endif %}">
          
          {% for product in block.settings.products %}
            <div class="product-card">
              
              <a href="{{ product.url }}">
                <img 
                  src="{{ product.featured_image | image_url: width: 800 }}" 
                  alt="{{ product.title }}"
                  loading="lazy"
                >
              </a>

              <div class="product-content">
                <h4>{{ product.title }}</h4>
                
                <div class="price">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="compare-price">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>

                <a href="{{ product.url }}" class="product-btn">
                  View Product
                </a>
              </div>

            </div>
          {% endfor %}

        </div>
      </div>
    {% endfor %}

  </div>
</section>

{{ 'section-screenfree-age-tabs-uae-2026.css' | asset_url | stylesheet_tag }}

<script>
document.addEventListener("DOMContentLoaded", function() {
  const buttons = document.querySelectorAll(".screenfree-age-tabs-uae-2026 .tab-btn");
  const contents = document.querySelectorAll(".screenfree-age-tabs-uae-2026 .tab-content");

  buttons.forEach(btn => {
    btn.addEventListener("click", function() {
      const target = this.getAttribute("data-tab");

      buttons.forEach(b => b.classList.remove("active"));
      contents.forEach(c => c.classList.remove("active"));

      this.classList.add("active");
      document.getElementById(target).classList.add("active");
    });
  });
});
</script>

{% schema %}
{
  "name": "Screen-Free Age Tabs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Best Screen-Free Gifts by Age"
    }
  ],
  "blocks": [
    {
      "type": "age_tab",
      "name": "Age Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab Title",
          "default": "Ages 3–5"
        },
        {
          "type": "product_list",
          "id": "products",
          "label": "Select Products"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Screen-Free Age Tabs"
    }
  ]
}
{% endschema %}