{%- comment -%} ════════ STYLES ════════ {%- endcomment -%}
<style>
#tt360-body *,#tt360-body *::before,#tt360-body *::after{box-sizing:border-box}
#tt360-body{
  --navy:#1A3557;--navy2:#102540;--orange:#FF6B2B;--orange2:#E55A1C;
  --green:#10B981;--bg:#fff;--bg2:#F7FAFD;--text:#0D1B2A;
  --muted:#64748B;--border:#E2E8F0;--gold:#F59E0B;--r:14px;
  --sh:0 4px 20px rgba(26,53,87,.10);--shh:0 10px 40px rgba(26,53,87,.18);
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  -webkit-font-smoothing:antialiased;color:var(--text);line-height:1.5
}
/* ANNOUNCE */
#tt360-body .t360-bar{background:var(--navy);color:#fff;text-align:center;font-size:12px;font-weight:500;padding:8px 12px;line-height:1.4}
#tt360-body .t360-bar strong{color:#FFC97A}
#tt360-body .t360-bar .s{margin:0 10px;opacity:.3}
/* HERO */
#tt360-body .t360-hero{background:linear-gradient(135deg,#F0F7FF 0%,#E8F5EF 60%,#FFF5EE 100%);padding:36px 20px 32px}
#tt360-body .t360-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
#tt360-body .t360-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(16,185,129,.11);color:#059669;border:1px solid rgba(16,185,129,.22);border-radius:99px;padding:5px 14px;font-size:12px;font-weight:700;margin-bottom:16px}
#tt360-body .t360-h1{font-size:clamp(28px,4vw,50px);font-weight:900;color:var(--navy);line-height:1.1;letter-spacing:-1.5px;margin-bottom:14px}
#tt360-body .t360-h1 em{color:var(--orange);font-style:normal}
#tt360-body .t360-sub{font-size:16px;color:var(--muted);line-height:1.65;margin-bottom:28px;max-width:440px}
#tt360-body .t360-ctas{display:flex;gap:12px;flex-wrap:wrap}
#tt360-body .t360-btn-p{background:var(--orange);color:#fff;border:none;border-radius:12px;padding:14px 28px;font-size:14px;font-weight:800;cursor:pointer;display:inline-flex;align-items:center;gap:7px;text-decoration:none;transition:background .2s,transform .2s,box-shadow .2s;box-shadow:0 4px 18px rgba(255,107,43,.38);white-space:nowrap}
#tt360-body .t360-btn-p:hover{background:var(--orange2);transform:translateY(-2px);box-shadow:0 7px 26px rgba(255,107,43,.46)}
#tt360-body .t360-btn-g{background:transparent;color:var(--navy);border:2px solid var(--navy);border-radius:12px;padding:12px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:background .2s,color .2s;white-space:nowrap}
#tt360-body .t360-btn-g:hover{background:var(--navy);color:#fff}
#tt360-body .t360-proof-row{margin-top:22px;display:flex;align-items:center;gap:8px;font-size:12.5px;color:var(--muted);flex-wrap:wrap}
#tt360-body .t360-avstack{display:flex}
#tt360-body .t360-av{width:28px;height:28px;border-radius:50%;border:2px solid #fff;margin-left:-7px;font-size:9px;font-weight:800;color:#fff;display:flex;align-items:center;justify-content:center;flex-shrink:0}
#tt360-body .t360-av:first-child{margin-left:0}
#tt360-body .t360-gold{color:var(--gold)}
/* HERO CARD */
#tt360-body .t360-hcard{background:#fff;border-radius:20px;box-shadow:0 20px 56px rgba(26,53,87,.15);overflow:hidden;position:relative;max-width:380px;width:100%;justify-self:center;contain:layout;text-decoration:none;display:block;color:inherit;transition:box-shadow .2s}
#tt360-body .t360-hcard:hover{box-shadow:0 24px 64px rgba(26,53,87,.22)}
#tt360-body .t360-hcard img{width:100%;height:240px;object-fit:cover;display:block}
#tt360-body .t360-hd-disc{position:absolute;top:14px;left:14px;background:var(--orange);color:#fff;font-size:12px;font-weight:800;border-radius:7px;padding:4px 11px;z-index:1}
#tt360-body .t360-hd-best{position:absolute;top:14px;right:14px;background:var(--navy);color:#fff;font-size:10px;font-weight:700;border-radius:7px;padding:4px 10px;z-index:1}
#tt360-body .t360-hcard-body{padding:18px 20px 20px}
#tt360-body .t360-hcard-name{font-size:15px;font-weight:700;color:var(--navy);margin-bottom:5px}
#tt360-body .t360-hcard-stars{color:var(--gold);font-size:12px;margin-bottom:12px}
#tt360-body .t360-hcard-stars span{color:var(--muted);font-size:11px}
#tt360-body .t360-hcard-ft{display:flex;align-items:center;justify-content:space-between;flex-direction:row-reverse}
#tt360-body .t360-shop-now{background:var(--orange);color:#fff;border:none;border-radius:9px;padding:10px 20px;font-size:13px;font-weight:800;white-space:nowrap;font-family:inherit;transition:background .2s}
#tt360-body .t360-hcard:hover .t360-shop-now{background:var(--orange2)}
#tt360-body .t360-ps{font-size:22px;font-weight:900;color:var(--navy)}
#tt360-body .t360-po{font-size:13px;color:var(--muted);text-decoration:line-through;margin-left:6px}
/* TRUST */
#tt360-body .t360-trust{background:var(--navy);display:flex;flex-wrap:wrap;justify-content:center}
#tt360-body .t360-ti{display:flex;align-items:center;gap:9px;padding:14px 22px;color:#fff;font-size:12.5px;font-weight:500;white-space:nowrap}
#tt360-body .t360-ti:not(:last-child){border-right:1px solid rgba(255,255,255,.14)}
#tt360-body .t360-ticon{width:32px;height:32px;border-radius:8px;background:rgba(255,255,255,.10);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
#tt360-body .t360-ti strong{color:#FFC97A;display:block;font-size:13px}
#tt360-body .t360-ti small{opacity:.6;font-size:11px}
/* SECTIONS */
#tt360-body .t360-sec{padding:40px 20px}
#tt360-body .t360-sec-alt{background:var(--bg2)}
#tt360-body .t360-wrap{max-width:1100px;margin:0 auto}
#tt360-body .t360-lbl{font-size:11px;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;color:var(--orange);margin-bottom:6px}
#tt360-body .t360-h2{font-size:clamp(22px,3.2vw,36px);font-weight:900;color:var(--navy);letter-spacing:-.8px;line-height:1.18;margin-bottom:8px}
#tt360-body .t360-sec-sub{font-size:15px;color:var(--muted);max-width:480px;line-height:1.65;margin-bottom:24px}
/* PRODUCT GRID */
#tt360-body .t360-pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
#tt360-body .t360-pc{background:#fff;border-radius:var(--r);border:1px solid var(--border);overflow:hidden;transition:box-shadow .25s,transform .25s,border-color .25s;display:flex;flex-direction:column;contain:layout;position:relative}
#tt360-body .t360-pc:hover{box-shadow:var(--shh);transform:translateY(-4px);border-color:transparent}
#tt360-body .t360-pc-link{position:absolute;inset:0;z-index:1;display:block}
#tt360-body .t360-pft,#tt360-body .t360-var-row,#tt360-body .t360-vbtn,#tt360-body .t360-atc{position:relative;z-index:2}
#tt360-body .t360-pc.feat{grid-column:span 2;flex-direction:row}
#tt360-body .t360-pc.feat .t360-pimgw{width:48%;flex-shrink:0}
#tt360-body .t360-pc.feat .t360-pimgw img{height:100%;min-height:240px}
#tt360-body .t360-pimgw{position:relative;overflow:hidden}
#tt360-body .t360-pimgw img{width:100%;height:200px;object-fit:cover;display:block;transition:transform .4s ease}
#tt360-body .t360-pc:hover .t360-pimgw img{transform:scale(1.04)}
#tt360-body .t360-b-sale{position:absolute;top:10px;left:10px;background:var(--orange);color:#fff;font-size:11px;font-weight:800;padding:3px 9px;border-radius:6px;z-index:1}
#tt360-body .t360-b-best{position:absolute;top:10px;right:10px;background:var(--navy);color:#fff;font-size:10px;font-weight:700;padding:3px 9px;border-radius:6px;z-index:1}
#tt360-body .t360-pbody{padding:16px 18px 18px;display:flex;flex-direction:column;flex:1}
#tt360-body .t360-pc.feat .t360-pbody{padding:28px 26px;justify-content:center}
#tt360-body .t360-pname{font-size:14.5px;font-weight:700;color:var(--navy);line-height:1.3;margin-bottom:4px}
#tt360-body .t360-pc.feat .t360-pname{font-size:18px;margin-bottom:6px}
#tt360-body .t360-pdesc{font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:16px}
#tt360-body .t360-pstars{color:var(--gold);font-size:12px;margin-bottom:12px}
#tt360-body .t360-pstars span{color:var(--muted);font-size:11px;margin-left:3px}
#tt360-body .t360-pft{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:auto;flex-wrap:wrap}
#tt360-body .t360-pm{font-size:19px;font-weight:900;color:var(--navy)}
#tt360-body .t360-pw{font-size:12.5px;color:var(--muted);text-decoration:line-through;margin-left:5px}
/* VARIANTS */
#tt360-body .t360-var-lbl{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px;margin-top:10px}
#tt360-body .t360-var-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px}
#tt360-body .t360-vbtn{border:1.5px solid var(--border);border-radius:7px;padding:4px 10px;font-size:11.5px;font-weight:600;color:var(--muted);cursor:pointer;background:#fff;transition:border-color .15s,color .15s,background .15s;font-family:inherit}
#tt360-body .t360-vbtn:hover,#tt360-body .t360-vbtn.active{border-color:var(--navy);color:var(--navy);background:var(--bg2)}
/* ATC BUTTONS */
#tt360-body .t360-atc,#tt360-body .t360-atc-hero{background:var(--navy);color:#fff;border:none;border-radius:9px;padding:10px 20px;font-size:13px;font-weight:800;cursor:pointer;transition:background .2s;white-space:nowrap;font-family:inherit}
#tt360-body .t360-atc-hero{background:var(--orange)}
#tt360-body .t360-atc:hover{background:var(--orange)}
#tt360-body .t360-atc-hero:hover{background:var(--orange2)}
#tt360-body .t360-atc.loading,#tt360-body .t360-atc-hero.loading{opacity:.65;pointer-events:none}
#tt360-body .t360-atc.done,#tt360-body .t360-atc-hero.done{background:var(--green) !important}
/* PROOF */
#tt360-body .t360-proof{background:linear-gradient(135deg,var(--navy) 0%,var(--navy2) 100%);padding:40px 20px;text-align:center;color:#fff}
#tt360-body .t360-proof-stars{color:var(--gold);font-size:24px;letter-spacing:3px;margin-bottom:8px}
#tt360-body .t360-proof-num{font-size:clamp(48px,8vw,76px);font-weight:900;letter-spacing:-3px;line-height:1}
#tt360-body .t360-proof-num em{color:var(--orange);font-style:normal}
#tt360-body .t360-proof-lbl{font-size:17px;color:rgba(255,255,255,.6);margin-top:6px;margin-bottom:26px}
#tt360-body .t360-pills{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap}
#tt360-body .t360-pill{background:rgba(255,255,255,.10);border:1px solid rgba(255,255,255,.16);border-radius:9px;padding:8px 16px;font-size:12.5px;color:rgba(255,255,255,.82);font-weight:500}
/* CAROUSEL */
#tt360-body .t360-car-outer{position:relative}
#tt360-body .t360-car-track{display:flex;gap:14px;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding:4px 4px 12px;scrollbar-width:none}
#tt360-body .t360-car-track::-webkit-scrollbar{display:none}
#tt360-body .t360-arr{position:absolute;top:38%;transform:translateY(-50%);width:38px;height:38px;background:#fff;border:1px solid var(--border);border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--navy);box-shadow:var(--sh);z-index:10;transition:background .2s,color .2s,border-color .2s;line-height:1;font-family:inherit}
#tt360-body .t360-arr:hover{background:var(--navy);color:#fff;border-color:var(--navy)}
#tt360-body .t360-arr.prev{left:-19px}
#tt360-body .t360-arr.next{right:-19px}
#tt360-body .t360-mc{flex:0 0 184px;scroll-snap-align:start;background:#fff;border-radius:12px;border:1px solid var(--border);overflow:hidden;transition:box-shadow .2s,transform .2s,border-color .2s;contain:layout;position:relative}
#tt360-body .t360-mc-link{position:absolute;inset:0;z-index:1;display:block}
#tt360-body .t360-mc-ft{display:flex;align-items:center;justify-content:space-between;position:relative;z-index:2}
#tt360-body .t360-mc:hover{box-shadow:var(--sh);transform:translateY(-2px);border-color:transparent}
#tt360-body .t360-mc img{width:100%;height:126px;object-fit:cover;display:block}
#tt360-body .t360-mc-body{padding:10px 12px 12px}
#tt360-body .t360-mc-name{font-size:12.5px;font-weight:600;color:var(--navy);margin-bottom:8px;line-height:1.3}
#tt360-body .t360-mc-price{font-size:14px;font-weight:900;color:var(--navy)}
#tt360-body .t360-mc-atc{background:var(--bg2);color:var(--navy);border:none;border-radius:6px;padding:5px 11px;font-size:11.5px;font-weight:800;cursor:pointer;transition:background .18s,color .18s;font-family:inherit}
