var TBM={'Orange/2-6':43758443135091,'Orange/7-12':43953839898739,'Pink/2-6':43952313139315,'Pink/7-12':43953839931507,'Blue/2-6':43952313172083,'Blue/7-12':43953839964275};
var BNM={'Orange/2-6':44998000803955,'Orange/7-12':44998000836723,'Pink/2-6':44998000869491,'Pink/7-12':44998000902259,'Blue/2-6':44998000935027,'Blue/7-12':44998000967795};
window.t360TbV=43758443135091;
window.t360BnV=44998000803955;

window.t360Sel=function(gid,btn){
  var btns=document.querySelectorAll('#'+gid+' .t360-vbtn');
  for(var i=0;i<btns.length;i++){btns[i].classList.remove('active');btns[i].setAttribute('aria-pressed','false');}
  btn.classList.add('active');btn.setAttribute('aria-pressed','true');
};
window.t360GetVid=function(gid){
  var a=document.querySelector('#'+gid+' .t360-vbtn.active');
  return a?parseInt(a.dataset.vid,10):null;
};
window.t360UpdateTb=function(){
  var c=document.querySelector('#t360-tbColor .t360-vbtn.active');
  var a=document.querySelector('#t360-tbAge .t360-vbtn.active');
  window.t360TbV=TBM[(c?c.dataset.color:'Orange')+'/'+(a?a.dataset.age:'2-6')]||43758443135091;
};
window.t360UpdateBn=function(){
  var c=document.querySelector('#t360-bnColor .t360-vbtn.active');
  var a=document.querySelector('#t360-bnAge .t360-vbtn.active');
  window.t360BnV=BNM[(c?c.dataset.color:'Orange')+'/'+(a?a.dataset.age:'2-6')]||44998000803955;
};

// ── ADD TO CART ──
window.t360ATC=function(vid,bid){
  var btn=document.getElementById(bid);
  if(!btn||btn.classList.contains('loading'))return;
  var orig=btn.textContent;
  btn.classList.add('loading');btn.textContent='Adding…';
  fetch('/cart/add.js',{
    method:'POST',
    headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
    body:JSON.stringify({id:vid,quantity:1})
  })
  .then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
  .then(function(){
    btn.classList.remove('loading');btn.classList.add('done');btn.textContent='✓ Added!';
    setTimeout(function(){btn.classList.remove('done');btn.textContent=orig;},2500);
  })
  .catch(function(){
    btn.classList.remove('loading');btn.textContent='Try again';
    t360Toast('Error adding item. Please try again.');
    setTimeout(function(){btn.textContent=orig;},2200);
  });
};

// ── TOAST ──
window.t360Toast=function(msg){
  var t=document.getElementById('tt360-toast');
  if(!t)return;
  t.textContent=msg||'✓ Added to cart!';
  t.classList.add('show');
  setTimeout(function(){t.classList.remove('show');},2400);
};

// ── EMAIL SUBSCRIBE ──
window.t360Sub=function(){
  var inp=document.getElementById('t360-email');
  var v=(inp?inp.value:'').trim();
  if(!v||v.indexOf('@')<0){t360Toast('Please enter a valid email');return;}
  fetch('/contact',{
    method:'POST',
    headers:{'Content-Type':'application/x-www-form-urlencoded'},
    body:'form_type=customer&utf8=✓&contact[email]='+encodeURIComponent(v)+'&contact[tags]=newsletter,homepage-cta'
  }).then(function(){
    t360Toast('✓ Check your inbox for your 10% code!');
    if(inp)inp.value='';
  }).catch(function(){t360Toast('✓ You\'re subscribed!');if(inp)inp.value='';});
};

})();
</script>
