{%- comment -%} ── PERFORMANCE: preconnect + preload hero image ── {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
<link rel="preload" as="image"
  imagesrcset="{{ hero_img | image_url: width: 400 }} 400w, {{ hero_img | image_url: width: 800 }} 800w, {{ hero_img | image_url: width: 1200 }} 1200w"
  imagesizes="(max-width: 768px) 100vw, 380px"
  href="{{ hero_img | image_url: width: 800 }}">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

{%- comment -%} META: title, description, OG, Twitter now handled server-side in theme.liquid + social-meta-tags.liquid {%- endcomment -%}

