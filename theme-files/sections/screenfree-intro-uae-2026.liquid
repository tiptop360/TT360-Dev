{% comment %}
File: sections/screenfree-intro-uae-2026.liquid
{% endcomment %}

<section class="screenfree-intro-uae-2026">
  <div class="page-width intro-wrapper {% if section.settings.image_position == 'right' %}reverse{% endif %}">
    
    <div class="intro-image">
      {% if section.settings.image != blank %}
	        <img
	          src="{{ section.settings.image | image_url: width: 1000 }}"
	          alt="{{ section.settings.heading | escape }}"
	          width="{{ section.settings.image.width }}"
	          height="{{ section.settings.image.height }}"
	          loading="lazy"
	        >
      {% endif %}
    </div>

    <div class="intro-content">
      <h2>{{ section.settings.heading }}</h2>
      <div class="intro-text">
        {{ section.settings.description }}
      </div>
    </div>

  </div>
</section>

<style>
.screenfree-intro-uae-2026 {
  padding: 80px 0;
}

.screenfree-intro-uae-2026 .intro-wrapper {
  display: flex;
  align-items: center;
  gap: 60px;
}

.screenfree-intro-uae-2026 .intro-wrapper.reverse {
  flex-direction: row-reverse;
}

.screenfree-intro-uae-2026 .intro-image {
  width: 50%;
}

.screenfree-intro-uae-2026 .intro-image img {
  width: 100%;
  border-radius: 20px;
  box-shadow: 0 15px 35px rgba(0,0,0,0.08);
}

.screenfree-intro-uae-2026 .intro-content {
  width: 50%;
}

.screenfree-intro-uae-2026 h2 {
  font-size: 32px;
  margin-bottom: 20px;
}

.screenfree-intro-uae-2026 .intro-text {
  font-size: 16px;
  line-height: 1.7;
}

/* Responsive */
@media (max-width: 768px) {
  .screenfree-intro-uae-2026 .intro-wrapper {
    flex-direction: column;
  }

  .screenfree-intro-uae-2026 .intro-image,
  .screenfree-intro-uae-2026 .intro-content {
    width: 100%;
  }

  .screenfree-intro-uae-2026 h2 {
    font-size: 24px;
  }
}
</style>

{% schema %}
{
  "name": "Screen-Free Intro UAE",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Intro Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meaningful Screen-Free Gifts"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Looking for meaningful gifts that keep your child engaged without screens? These UAE parent-approved picks combine creativity, fun, and practical value.</p>"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "default": "left",
      "options": [
        { "value": "left", "label": "Image Left" },
        { "value": "right", "label": "Image Right" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Screen-Free Intro UAE"
    }
  ]
}
{% endschema %}
