{%- comment -%}
  tt360-about-page.liquid
  Full About page — SEO + GEO optimized, all content editable via theme editor
  JSON-LD: Organization + AboutPage + BreadcrumbList + FAQPage (auto-generated)
{%- endcomment -%}

{%- assign s = section.settings -%}

{%- comment -%} ── JSON-LD STRUCTURED DATA ── {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": {{ s.seo_title | default: "About TipTop360 UAE" | json }},
  "description": {{ s.meta_description | default: "Learn about TipTop360 — a UAE-based store curating practical kids products for UAE families." | json }},
  "url": "{{ shop.url }}/pages/about-tiptop360",
  "mainEntity": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "alternateName": "TipTop360 UAE",
    "url": {{ shop.url | json }},
    "logo": "{{ shop.url }}{{ s.logo | default: shop.brand.logo | image_url: width: 500 }}",
    "description": {{ s.org_description | default: "UAE-based online store curating practical kids products, oral care essentials, STEM educational toys, and parenting solutions for UAE families." | json }},
    "foundingLocation": { "@type": "Place", "name": {{ s.founding_location | default: "Ras Al Khaimah, UAE" | json }} },
    "areaServed": { "@type": "Country", "name": "United Arab Emirates" },
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "AE",
      "addressRegion": {{ s.address_region | default: "Ras Al Khaimah" | json }}
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "Customer Support",
      "availableLanguage": ["English", "Arabic"],
      "contactOption": "WhatsApp"
    },
    "sameAs": [
      {%- if s.instagram_url != blank %}"{{ s.instagram_url }}"{% endif -%}
      {%- if s.facebook_url != blank %},  "{{ s.facebook_url }}"{% endif -%}
      {%- if s.tiktok_url != blank %},  "{{ s.tiktok_url }}"{% endif -%}
      {%- if s.pinterest_url != blank %},  "{{ s.pinterest_url }}"{% endif -%}
    ],
    "knowsAbout": ["Kids Oral Care UAE","STEM Toys UAE","Educational Toys UAE","Screen-Free Toys UAE","Kids Gifts UAE","Parenting Products UAE"],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Kids Products UAE",
      "itemListElement": [
        {"@type":"Offer","itemOffered":{"@type":"Product","name":"Kids Oral Care Products UAE"}},
        {"@type":"Offer","itemOffered":{"@type":"Product","name":"STEM Educational Toys UAE"}},
        {"@type":"Offer","itemOffered":{"@type":"Product","name":"Screen-Free Creative Toys UAE"}},
        {"@type":"Offer","itemOffered":{"@type":"Product","name":"Kids Gifts UAE"}}
      ]
    }
  }
}
</script>

{%- comment -%} BreadcrumbList now handled by schema-controller in theme.liquid {%- endcomment -%}

{%- comment -%} FAQ Schema — auto-generated from FAQ blocks {%- endcomment -%}
{%- assign faq_blocks = section.blocks | where: "type", "faq_item" -%}
{%- if faq_blocks.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in faq_blocks -%}
    {
      "@type": "Question",
      "name": {{ block.settings.question | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ block.settings.answer | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}

<style>
/* ── VARIABLES & RESET ─────────────────────────────── */
.tt360-about *{box-sizing:border-box;margin:0;padding:0}
.tt360-about{
  --ink:#0e1c2a;--ink2:rgba(14,28,42,.55);--ink3:rgba(14,28,42,.25);
  --navy:#12395e;--mint:#ff6f2e;--teal:#439b94;--coral:#ff6f2e;
  --cream:#faf8f4;--white:#fff;--border:rgba(14,28,42,.08);
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  color:var(--ink);line-height:1.65;
  -webkit-font-smoothing:antialiased;
}
.tt360-about a{color:var(--teal);text-decoration:none;transition:color .2s}
.tt360-about a:hover{color:var(--coral)}

/* ── LAYOUT ────────────────────────────────────────── */
.tt360-about__wrap{max-width:960px;margin:0 auto;padding:0 20px}
.tt360-about__section{padding:56px 0}
.tt360-about__section:nth-child(even){background:var(--cream)}
.tt360-about__section:nth-child(odd){background:var(--white)}
.tt360-about__section--navy{background:var(--navy)!important;color:var(--white)}
.tt360-about__section--navy h2{color:#fff}
.tt360-about__section--navy p{color:rgba(255,255,255,.85)}
.tt360-about__section--navy a{color:var(--mint)}
.tt360-about__section--navy a:hover{color:var(--white)}

/* ── TYPOGRAPHY ────────────────────────────────────── */
.tt360-about h1{font-size:clamp(26px,5vw,38px);font-weight:700;letter-spacing:-.02em;line-height:1.2;margin-bottom:16px}
.tt360-about h2{font-size:clamp(22px,4vw,30px);font-weight:700;letter-spacing:-.01em;line-height:1.25;margin-bottom:16px}
.tt360-about h3{font-size:clamp(18px,3.5vw,22px);font-weight:600;line-height:1.3;margin-bottom:12px}
.tt360-about p{margin-bottom:16px;font-size:15px}
.tt360-about ul,.tt360-about ol{margin:0 0 20px 20px;font-size:15px}
.tt360-about li{margin-bottom:8px}
.tt360-about strong{font-weight:600}

/* ── HERO ──────────────────────────────────────────── */
.tt360-about__hero{
  background:var(--navy);color:var(--white);
  padding:72px 0 56px;text-align:center;position:relative;overflow:hidden;
}
.tt360-about__hero::before{
  content:'';position:absolute;top:-50%;right:-30%;
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(84,232,204,.08),transparent 70%);
  pointer-events:none;
}
.tt360-about__hero h1{color:var(--white);margin-bottom:8px}
.tt360-about__hero-sub{
  font-size:clamp(14px,2.5vw,17px);color:rgba(255,255,255,.75);
  max-width:680px;margin:0 auto 32px;line-height:1.65;
}

/* ── TRUST BAR ─────────────────────────────────────── */
.tt360-about__trust{
  display:flex;flex-wrap:wrap;justify-content:center;gap:12px;
  margin-top:8px;
}
.tt360-about__trust-item{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);
  border-radius:8px;padding:10px 18px;font-size:13px;font-weight:500;
  display:flex;align-items:center;gap:8px;
  backdrop-filter:blur(8px);
}
.tt360-about__trust-item svg{flex-shrink:0;width:18px;height:18px}

/* ── PROBLEM BLOCKS ────────────────────────────────── */
.tt360-about__problems{display:grid;gap:20px;margin-top:24px}
.tt360-about__problem{
  background:var(--white);border:1px solid var(--border);
  border-radius:12px;padding:24px;
}
.tt360-about__problem h4{font-size:16px;font-weight:600;margin-bottom:8px;color:var(--navy)}

/* ── CATEGORY CARDS ────────────────────────────────── */
.tt360-about__cats{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:24px;margin-top:24px}
.tt360-about__cat{
  background:var(--white);border:1px solid var(--border);
  border-radius:16px;padding:32px 24px;transition:transform .2s,box-shadow .2s;
}
.tt360-about__cat:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(14,28,42,.08)}
.tt360-about__cat h3{color:var(--navy)}
.tt360-about__cat-cta{
  display:inline-flex;align-items:center;gap:6px;
  color:var(--teal);font-weight:600;font-size:14px;margin-top:12px;
}
.tt360-about__cat-cta:hover{color:var(--coral)}
.tt360-about__cat-cta::after{content:'\2192'}

/* ── CURATION STEPS ────────────────────────────────── */
.tt360-about__steps{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:20px;margin-top:28px;counter-reset:step;
}
.tt360-about__step{
  background:var(--white);border:1px solid var(--border);
  border-radius:12px;padding:24px 20px;text-align:center;
  counter-increment:step;position:relative;
}
.tt360-about__step::before{
  content:counter(step);display:flex;align-items:center;justify-content:center;
  width:36px;height:36px;border-radius:50%;background:var(--mint);
  color:var(--navy);font-weight:700;font-size:15px;
  margin:0 auto 12px;
}
.tt360-about__step h4{font-size:14px;font-weight:600;margin-bottom:6px}
.tt360-about__step p{font-size:13px;color:var(--ink2);margin:0}

/* ── PROMISES ──────────────────────────────────────── */
.tt360-about__promises{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;margin-top:24px}
.tt360-about__promise{
  display:flex;gap:14px;align-items:flex-start;
  padding:20px;background:var(--white);border:1px solid var(--border);
  border-radius:12px;
}
.tt360-about__promise-icon{
  flex-shrink:0;width:40px;height:40px;border-radius:10px;
  background:rgba(255,111,46,.12);display:flex;align-items:center;justify-content:center;
}
.tt360-about__promise-icon svg{width:20px;height:20px;color:var(--teal)}
.tt360-about__promise h4{font-size:15px;font-weight:600;margin-bottom:4px}
.tt360-about__promise p{font-size:13px;color:var(--ink2);margin:0}

/* ── DELIVERY ──────────────────────────────────────── */
.tt360-about__delivery-grid{
  display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
  gap:16px;margin-top:24px;
}
.tt360-about__delivery-item{
  text-align:center;padding:24px 16px;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);
  border-radius:12px;
}
.tt360-about__delivery-item strong{display:block;font-size:15px;margin-bottom:4px;color:#fff}
.tt360-about__delivery-item span{font-size:13px;color:rgba(255,255,255,.7)}

/* ── TESTIMONIALS ──────────────────────────────────── */
.tt360-about__reviews{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:24px}
.tt360-about__review{
  background:var(--white);border:1px solid var(--border);
  border-radius:14px;padding:28px 24px;position:relative;
}
.tt360-about__review::before{
  content:'\201C';font-size:48px;line-height:1;color:var(--mint);
  position:absolute;top:16px;left:20px;font-family:Georgia,serif;
}
.tt360-about__review blockquote{
  font-size:14px;line-height:1.7;font-style:italic;
  margin:0 0 16px;padding-top:24px;border:none;
}
.tt360-about__review-author{font-size:13px;font-weight:600}
.tt360-about__review-product{font-size:12px;color:var(--ink2)}
.tt360-about__review-stars{color:var(--coral);font-size:14px;margin-bottom:8px}

/* ── VALUES ────────────────────────────────────────── */
.tt360-about__values{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;margin-top:24px}
.tt360-about__value{padding:24px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:12px}
.tt360-about__value h4{font-size:15px;font-weight:600;margin-bottom:6px;color:var(--mint)}
.tt360-about__value p{font-size:14px;color:rgba(255,255,255,.8);margin:0}

/* ── FAQ ───────────────────────────────────────────── */
.tt360-about__faq-list{margin-top:24px}
.tt360-about__faq{
  border-bottom:1px solid var(--border);
}
.tt360-about__faq:first-child{border-top:1px solid var(--border)}
.tt360-about__faq-q{
  width:100%;background:none;border:none;text-align:left;
  padding:20px 44px 20px 0;cursor:pointer;position:relative;
  font-family:inherit;font-size:15px;font-weight:600;color:var(--ink);
  line-height:1.4;
}
.tt360-about__faq-q::after{
  content:'+';position:absolute;right:0;top:50%;transform:translateY(-50%);
  font-size:22px;font-weight:300;color:var(--ink3);transition:transform .2s;
}
.tt360-about__faq-q[aria-expanded="true"]::after{content:'\2212'}
.tt360-about__faq-a{
  max-height:0;overflow:hidden;transition:max-height .3s ease;
}
.tt360-about__faq-a-inner{padding:0 0 20px;font-size:14px;line-height:1.7;color:var(--ink2)}

/* ── COLLECTIONS GRID ──────────────────────────────── */
.tt360-about__colls{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:24px}
.tt360-about__coll{
  background:var(--navy);color:var(--white);border-radius:14px;
  padding:28px 20px;text-align:center;text-decoration:none;
  transition:transform .2s,box-shadow .2s;display:block;
}
.tt360-about__coll:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(14,28,42,.15);color:var(--white)}
.tt360-about__coll-emoji{font-size:32px;margin-bottom:10px;display:block}
.tt360-about__coll-title{font-size:15px;font-weight:600;margin-bottom:6px}
.tt360-about__coll-desc{font-size:12px;color:rgba(255,255,255,.75)}

/* ── FOOTER TRUST ──────────────────────────────────── */
.tt360-about__footer-trust{
  display:flex;flex-wrap:wrap;justify-content:center;gap:20px;
  margin-top:24px;
}
.tt360-about__footer-trust-item{font-size:13px;font-weight:500;display:flex;align-items:center;gap:6px}
.tt360-about__footer-trust-item svg{width:16px;height:16px;color:var(--mint)}

/* ── RESPONSIVE ────────────────────────────────────── */
@media(max-width:600px){
  .tt360-about__section{padding:40px 0}
  .tt360-about__hero{padding:56px 0 40px}
  .tt360-about__trust{gap:8px}
  .tt360-about__trust-item{padding:8px 12px;font-size:12px}
  .tt360-about__steps{grid-template-columns:repeat(2,1fr)}
  .tt360-about__cats{grid-template-columns:1fr}
  .tt360-about__delivery-grid{grid-template-columns:repeat(2,1fr)}
  .tt360-about__colls{grid-template-columns:repeat(2,1fr)}
}
</style>

<div class="tt360-about">

  {%- comment -%} ═══ HERO ═══ {%- endcomment -%}
  <div class="tt360-about__hero">
    <div class="tt360-about__wrap">
      <h1>{{ s.hero_heading | default: "About TipTop360 — Kids Products Curated for UAE Parents" }}</h1>
      <p class="tt360-about__hero-sub">{{ s.hero_subheading | default: "TipTop360 is a UAE-based online store built by parents, for parents. We curate practical kids oral care, STEM educational toys, screen-free creative products, and useful parenting essentials delivered free across Dubai, Abu Dhabi, Sharjah, and all UAE emirates." }}</p>

      <div class="tt360-about__trust">
        {%- assign trust_blocks = section.blocks | where: "type", "trust_badge" -%}
        {%- if trust_blocks.size > 0 -%}
          {%- for block in trust_blocks -%}
            <div class="tt360-about__trust-item" {{ block.shopify_attributes }}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {{ block.settings.text }}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="tt360-about__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Free Next-Day Delivery UAE
          </div>
          <div class="tt360-about__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Cash on Delivery
          </div>
          <div class="tt360-about__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            14-Day Returns
          </div>
          <div class="tt360-about__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Dubai Municipality Approved
          </div>
          <div class="tt360-about__trust-item">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            WhatsApp Support
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ═══ SECTION 1: WHO WE ARE ═══ {%- endcomment -%}
  <div class="tt360-about__section">
    <div class="tt360-about__wrap">
      <h2>{{ s.who_heading | default: "Who We Are" }}</h2>
      <div>{{ s.who_content | default: "<p>At <strong>TipTop360</strong>, we don't just sell products — we solve real parenting problems faced by families across the UAE.</p><p>We are a <strong>UAE-registered company</strong> (Sylo Commerce FZ-LLC, Trade License No. 45009298, Ras Al Khaimah Economic Zone) built on one simple belief: parents deserve better than endless scrolling through generic marketplaces.</p><p>Every product in our store is <strong>handpicked, tested, and parent-approved</strong>. From kids oral care that makes brushing easier to STEM toys that replace screen time with creative play, we only stock items that genuinely improve daily life for UAE families.</p>" }}</div>
    </div>
  </div>

  {%- comment -%} ═══ SECTION 2: WHY WE CREATED ═══ {%- endcomment -%}
  <div class="tt360-about__section">
    <div class="tt360-about__wrap">
      <h2>{{ s.why_heading | default: "Why We Created TipTop360" }}</h2>
      <p>{{ s.why_intro | default: "We started TipTop360 because we were tired of the same problem every UAE parent faces: finding useful kids products that actually work. Most online stores in the UAE are cluttered with random trends, overpriced gadgets, and products that look good in photos but disappoint in real life." }}</p>

      <h3>{{ s.problems_heading | default: "The problems we set out to solve:" }}</h3>
      <div class="tt360-about__problems">
        {%- assign problem_blocks = section.blocks | where: "type", "problem" -%}
        {%- if problem_blocks.size > 0 -%}
          {%- for block in problem_blocks -%}
            <div class="tt360-about__problem" {{ block.shopify_attributes }}>
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.description }}</p>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="tt360-about__problem">
            <h4>Brushing battles</h4>
            <p>Kids who refuse to brush, parents who lose patience. Our kids oral care collection — U-shaped toothbrushes, strawberry foam toothpaste, and complete dental bundles — turns brushing from a fight into a fun routine.</p>
          </div>
          <div class="tt360-about__problem">
            <h4>Screen time overload</h4>
            <p>Tablets and phones dominate childhood. Our screen-free STEM toys and educational drawing robots give kids creative, engaging play without Wi-Fi or apps.</p>
          </div>
          <div class="tt360-about__problem">
            <h4>Gift anxiety</h4>
            <p>Birthday parties, Eid celebrations, back-to-school — finding meaningful kids gifts in UAE shouldn't be stressful. We curate gifts children actually use and parents appreciate.</p>
          </div>
          <div class="tt360-about__problem">
            <h4>Delivery uncertainty</h4>
            <p>Waiting weeks for products, paying hidden fees, dealing with unreliable shipping. We offer free next-day delivery across all UAE emirates with Cash on Delivery for complete peace of mind.</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ═══ SECTION 3: PRODUCT CATEGORIES ═══ {%- endcomment -%}
  <div class="tt360-about__section">
    <div class="tt360-about__wrap">
      <h2>{{ s.cats_heading | default: "What Products We Curate for UAE Families" }}</h2>

      <div class="tt360-about__cats">
        {%- assign cat_blocks = section.blocks | where: "type", "category" -%}
        {%- if cat_blocks.size > 0 -%}
          {%- for block in cat_blocks -%}
            <div class="tt360-about__cat" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.description }}</p>
              {%- if block.settings.link_url != blank -%}
                <a href="{{ block.settings.link_url }}" class="tt360-about__cat-cta">{{ block.settings.link_text | default: "Shop Now" }}</a>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="tt360-about__cat">
            <h3>Kids Oral Care UAE</h3>
            <p>U-shaped toothbrushes that clean all teeth in 2 minutes, strawberry foam toothpaste kids actually want to use, and complete dental care bundles. Every product Dubai Municipality approved, BPA-free, and non-toxic.</p>
            <a href="/collections/kids-oral-care-uae" class="tt360-about__cat-cta">Shop Kids Oral Care</a>
          </div>
          <div class="tt360-about__cat">
            <h3>STEM & Educational Toys UAE</h3>
            <p>Screen-free, teacher-approved learning toys. Our Kids STEM Drawing Robot guides children through 100+ templates, developing fine motor skills and creative confidence — all without Wi-Fi or apps.</p>
            <a href="/collections/stem-toys-uae" class="tt360-about__cat-cta">Explore STEM Toys</a>
          </div>
          <div class="tt360-about__cat">
            <h3>Screen-Free Creative Play UAE</h3>
            <p>From the Smoke Bubble Machine creating 500+ magical bubbles per minute to creative learning tools that keep kids focused for hours. UAE safety certified and mess-free.</p>
            <a href="/collections/screen-free-toys-uae" class="tt360-about__cat-cta">Shop Screen-Free Toys</a>
          </div>
          <div class="tt360-about__cat">
            <h3>Kids Gifts UAE</h3>
            <p>Educational gifts, creative presents, and practical essentials children use daily. Perfect for birthdays, Eid celebrations, and back-to-school in Dubai, Abu Dhabi, and Sharjah.</p>
            <a href="/collections/kids-gifts-uae" class="tt360-about__cat-cta">Find Kids Gifts</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ═══ SECTION 4: CURATION PROCESS ═══ {%- endcomment -%}
  <div class="tt360-about__section">
    <div class="tt360-about__wrap">
      <h2>{{ s.curation_heading | default: "Our Curation Process: Why TipTop360 Products Are Different" }}</h2>
      <p>{{ s.curation_intro | default: "Every product in our store passes a 5-step vetting process:" }}</p>

      <div class="tt360-about__steps">
        {%- assign step_blocks = section.blocks | where: "type", "curation_step" -%}
        {%- if step_blocks.size > 0 -%}
          {%- for block in step_blocks -%}
            <div class="tt360-about__step" {{ block.shopify_attributes }}>
