<script>
(function(){
  var s=document.getElementById('faq-search');
  if(!s)return;
  var items=document.querySelectorAll('.faq-item');
  var cats=document.querySelectorAll('.faq-category');
  var nr=document.getElementById('faq-no-results');
  var cta=document.getElementById('faq-cta');
  s.addEventListener('input',function(){
    var q=this.value.toLowerCase().trim();
    if(!q){
      items.forEach(function(i){i.style.display='';i.open=false});
      cats.forEach(function(c){c.style.display=''});
      nr.classList.remove('visible');
      if(cta)cta.style.display='';
      return;
    }
    var visible=0;
    var visCats={};
    items.forEach(function(i){
      var txt=i.textContent.toLowerCase();
      var kw=i.dataset.keywords||'';
      var match=txt.indexOf(q)>-1||kw.indexOf(q)>-1;
      i.style.display=match?'':'none';
      if(match){i.open=true;visible++;var cat=i.closest('.faq-category');if(cat)visCats[cat.id]=true}
      else{i.open=false}
    });
    cats.forEach(function(c){c.style.display=visCats[c.id]?'':'none'});
    nr.classList.toggle('visible',visible===0);
    if(cta)cta.style.display=visible===0?'none':'';
  });
})();
</script>

