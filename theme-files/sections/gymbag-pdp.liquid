<script>
(function(){
'use strict';
var UNIT = {{ product.price | divided_by: 100.0 }};
var VARIANTS = {
  black: { id: {% if black_v %}{{ black_v.id }}{% else %}43786158735475{% endif %}, max: {% if black_v %}{{ black_v.inventory_quantity }}{% else %}62{% endif %} },
  gray:  { id: {% if gray_v %}{{ gray_v.id }}{% else %}43786158768243{% endif %},  max: {% if gray_v %}{{ gray_v.inventory_quantity }}{% else %}94{% endif %} }
};
var qtys = { black: 1, gray: 0 };
function fmt(n){ return 'AED ' + Math.round(n); }
function gbUpdateTotals(){
  var total = qtys.black + qtys.gray, price = total * UNIT;
  document.getElementById('gb-row-black').className = 'gb-variant-row' + (qtys.black > 0 ? ' has-qty' : '');
  document.getElementById('gb-row-gray').className  = 'gb-variant-row' + (qtys.gray  > 0 ? ' has-qty' : '');
  document.getElementById('gb-qty-black').textContent = qtys.black;
  document.getElementById('gb-qty-gray').textContent  = qtys.gray;
  document.getElementById('gb-qty-total').textContent = total;
  document.getElementById('gb-price-total').textContent = fmt(total > 0 ? price : UNIT);
  var bp = document.getElementById('gb-btn-price');
  if(bp) bp.textContent = fmt(total > 0 ? price : UNIT);
  var sp = document.getElementById('gb-sticky-price');
  if(sp) sp.textContent = fmt(total > 0 ? price : UNIT) + (total > 1 ? ' x'+total : '');
}
window.gbChangeQty = function(color, delta){
  var v = VARIANTS[color], n = Math.min(Math.max(qtys[color] + delta, 0), v.max);
  qtys[color] = n;
  if(delta > 0 && n === 1){
    var lbl = color === 'black' ? 'Black' : 'Gray';
    var idx = Array.from(slides).findIndex(function(s){ return s.dataset && s.dataset.color === lbl; });
    if(idx >= 0) gbGoTo(idx, true);
  }
  gbUpdateTotals();
};
window.gbAddToCart = function(toCheckout){
  var items = [];
  if(qtys.black > 0) items.push({ id: VARIANTS.black.id, quantity: qtys.black });
  if(qtys.gray  > 0) items.push({ id: VARIANTS.gray.id,  quantity: qtys.gray  });
  if(!items.length) items = [{ id: VARIANTS.black.id, quantity: 1 }];
  fetch('/cart/add.js', {
    method:'POST', headers:{'Content-Type':'application/json'},
    body: JSON.stringify({ items: items })
  }).then(function(){ window.location.href = toCheckout ? '/checkout' : '/cart'; })
    .catch(function(){ window.location.href = toCheckout ? '/checkout' : '/cart'; });
};
var slides = document.querySelectorAll('.gb-slide');
var tc = document.getElementById('gb-thumbs'), ctrEl = document.getElementById('gb-ctr');
var cur = 0, timer;
Array.from(slides).forEach(function(sl, i){
  var img = sl.querySelector('img'), t = document.createElement('div');
  t.className = 'gb-thumb' + (i === 0 ? ' on' : '');
  var ti = document.createElement('img');
  ti.src = img.src.replace('width=700','width=120'); ti.alt = img.alt; ti.loading = 'lazy'; ti.width = 54; ti.height = 54;
  t.appendChild(ti); t.addEventListener('click', function(){ gbGoTo(i, true); }); tc.appendChild(t);
});
function gbGoTo(n, manual){
  slides[cur].classList.remove('active'); tc.querySelectorAll('.gb-thumb')[cur].classList.remove('on');
  cur = ((n % slides.length) + slides.length) % slides.length;
  slides[cur].classList.add('active');
  var nt = tc.querySelectorAll('.gb-thumb')[cur]; nt.classList.add('on');
  if(manual) nt.scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
  if(ctrEl) ctrEl.textContent = (cur+1)+' / '+slides.length;
  clearInterval(timer); timer = setInterval(function(){ gbGoTo(cur+1,false); }, 4200);
}
window.gbSlide = function(d,m){ gbGoTo(cur+d,m); };
timer = setInterval(function(){ gbGoTo(cur+1,false); }, 4200);
var tx = 0, stage = document.getElementById('gb-stage');
stage.addEventListener('touchstart',function(e){ tx=e.touches[0].clientX; },{passive:true});
stage.addEventListener('touchend',function(e){ var dx=tx-e.changedTouches[0].clientX; if(Math.abs(dx)>40) window.gbSlide(dx>0?1:-1,true); },{passive:true});
document.querySelectorAll('.gb-faq-q').forEach(function(hd){
  var item = hd.parentElement, ans = item.querySelector('.gb-faq-a');
  function toggle(){
    var o = item.classList.contains('open');
    document.querySelectorAll('.gb-faq-item').forEach(function(el){ el.classList.remove('open'); el.querySelector('.gb-faq-q').setAttribute('aria-expanded','false'); });
    if(!o){ item.classList.add('open'); hd.setAttribute('aria-expanded','true'); }
  }
  hd.addEventListener('click',toggle);
  hd.addEventListener('keydown',function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); toggle(); } });
});
})();
</script>


