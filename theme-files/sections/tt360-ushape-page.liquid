<!-- ── JS: FAQ accordion + sticky scroll logic ── -->
<script>
(function(){
  document.querySelectorAll('.ushp-faq-q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.ushp-faq-item');
      var wasOpen=item.classList.contains('open');
      document.querySelectorAll('.ushp-faq-item.open').forEach(function(o){o.classList.remove('open');o.querySelector('.ushp-faq-q').setAttribute('aria-expanded','false')});
      if(!wasOpen){item.classList.add('open');this.setAttribute('aria-expanded','true')}
    });
  });
  var sticky=document.getElementById('ushp-sticky');
  if(sticky&&window.innerWidth<=768){
    var shown=false;
    window.addEventListener('scroll',function(){
      if(window.scrollY>600&&!shown){sticky.style.display='block';shown=true}
      else if(window.scrollY<=600&&shown){sticky.style.display='none';shown=false}
    },{passive:true});
  }
})();
</script>

