{%- comment -%} ── STYLES ── {%- endcomment -%}
<style>
.ushp *,.ushp *::before,.ushp *::after{box-sizing:border-box}
.ushp{
  --navy:#12395e;--navy-d:#0d2a47;--orange:#ff6f2e;--orange-d:#e55f20;
  --mint:#b8f4d4;--mint-bg:#e8faf0;--coral-bg:#fcebeb;
  --bg:#fff;--bg2:#f7fafd;--text:#202025;--muted:#64748b;
  --border:#e2e8f0;--gold:#f59e0b;--r:14px;
  --sh:0 4px 20px rgba(18,57,94,.10);--shh:0 10px 40px rgba(18,57,94,.18);
  font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  -webkit-font-smoothing:antialiased;color:var(--text);line-height:1.6
}
.ushp a{color:inherit;text-decoration:none}
.ushp img{max-width:100%;height:auto;display:block}

/* ── HERO ── */
.ushp-hero{background:linear-gradient(135deg,var(--navy) 0%,#1a4a7a 60%,#1e5a8a 100%);padding:48px 20px 56px;position:relative;overflow:hidden}
.ushp-hero::after{content:'';position:absolute;top:-50%;right:-20%;width:60%;height:200%;background:radial-gradient(ellipse,rgba(255,111,46,.08) 0%,transparent 70%);pointer-events:none}
.ushp-hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.ushp-breadcrumb{font-size:12px;color:rgba(255,255,255,.6);margin-bottom:16px}
.ushp-breadcrumb a{color:rgba(255,255,255,.6);text-decoration:underline}
.ushp-breadcrumb a:hover{color:#fff}
.ushp-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(184,244,212,.15);color:var(--mint);border:1px solid rgba(184,244,212,.3);border-radius:99px;padding:5px 14px;font-size:12px;font-weight:700;margin-bottom:16px}
.ushp h1{font-size:clamp(28px,4vw,46px);font-weight:900;color:#fff;line-height:1.1;letter-spacing:-1.2px;margin:0 0 14px}
.ushp h1 em{color:var(--orange);font-style:normal}
.ushp-sub{font-size:16px;color:rgba(255,255,255,.75);line-height:1.65;margin-bottom:28px;max-width:440px}
.ushp-ctas{display:flex;gap:12px;flex-wrap:wrap}
.ushp-btn{background:var(--orange);color:#fff;border:none;border-radius:12px;padding:14px 28px;font-size:15px;font-weight:800;cursor:pointer;display:inline-flex;align-items:center;gap:7px;text-decoration:none;transition:background .2s,transform .2s,box-shadow .2s;box-shadow:0 4px 18px rgba(255,111,46,.38);white-space:nowrap}
.ushp-btn:hover{background:var(--orange-d);transform:translateY(-2px);box-shadow:0 7px 26px rgba(255,111,46,.46)}
.ushp-btn-o{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.4);border-radius:12px;padding:12px 22px;font-size:14px;font-weight:700;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:background .2s,border-color .2s}
.ushp-btn-o:hover{background:rgba(255,255,255,.1);border-color:#fff}
.ushp-proof{margin-top:22px;display:flex;align-items:center;gap:8px;font-size:12px;color:rgba(255,255,255,.6)}
.ushp-proof .stars{color:var(--gold)}
.ushp-hero-img{position:relative;justify-self:center;max-width:420px;width:100%}
.ushp-hero-img img{border-radius:20px;box-shadow:0 20px 56px rgba(0,0,0,.25)}
.ushp-hero-badge{position:absolute;background:#fff;color:var(--navy);font-size:14px;font-weight:700;padding:8px 16px;border-radius:12px;box-shadow:var(--sh)}
.ushp-hero-badge.b1{top:15%;right:-10px}
.ushp-hero-badge.b2{bottom:20%;left:-10px}

/* ── TRUST BAR ── */
.ushp-trust{background:var(--navy-d);display:flex;flex-wrap:wrap;justify-content:center}
.ushp-ti{display:flex;align-items:center;gap:9px;padding:14px 24px;color:#fff;font-size:13px;font-weight:500;white-space:nowrap}
.ushp-ti:not(:last-child){border-right:1px solid rgba(255,255,255,.12)}
.ushp-ti strong{color:#ffc97a;display:block;font-size:14px}
.ushp-ti-icon{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}

/* ── SECTIONS ── */
.ushp-sec{padding:48px 20px}
.ushp-sec-alt{background:var(--bg2)}
.ushp-wrap{max-width:1000px;margin:0 auto}
.ushp-lbl{font-size:11px;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;color:var(--orange);margin-bottom:6px}
.ushp-h2{font-size:clamp(22px,3.2vw,34px);font-weight:900;color:var(--navy);letter-spacing:-.6px;line-height:1.18;margin:0 0 10px}
.ushp-desc{font-size:15px;color:var(--muted);max-width:600px;line-height:1.65;margin-bottom:24px}
.ushp-desc.center{margin-left:auto;margin-right:auto;text-align:center}
.ushp-h2.center,.ushp-lbl.center{text-align:center}

/* ── STAT BAR ── */
.ushp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:32px}
.ushp-stat{background:var(--navy);border-radius:var(--r);padding:24px 16px;text-align:center;color:#fff}
.ushp-stat-val{font-size:28px;font-weight:900;color:var(--orange);margin-bottom:4px}
.ushp-stat-lbl{font-size:13px;color:rgba(255,255,255,.75);font-weight:500}

/* ── PROBLEM / SOLUTION ── */
.ushp-ps{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px}
.ushp-ps-card{border-radius:var(--r);padding:32px 28px;border:1px solid var(--border)}
.ushp-ps-card.problem{background:var(--coral-bg);border-color:#f5c6c6}
.ushp-ps-card.solution{background:var(--mint-bg);border-color:#a3e8c4}
.ushp-ps-card h3{font-size:20px;font-weight:800;margin:0 0 16px;color:var(--navy)}
.ushp-ps-card ul{list-style:none;padding:0;margin:0}
.ushp-ps-card li{padding:8px 0;font-size:14px;line-height:1.5;display:flex;align-items:flex-start;gap:8px}
.ushp-ps-card li::before{flex-shrink:0;font-size:16px;line-height:1.3}
.ushp-ps-card.problem li::before{content:'✗';color:#dc2626;font-weight:700}
.ushp-ps-card.solution li::before{content:'✓';color:#059669;font-weight:700}

/* ── BEFORE / AFTER TABLE ── */
.ushp-table{width:100%;border-collapse:collapse;border-radius:var(--r);overflow:hidden;margin-top:24px;box-shadow:var(--sh)}
.ushp-table thead{background:var(--navy)}
.ushp-table th{color:#fff;font-size:15px;font-weight:700;padding:14px 20px;text-align:center}
.ushp-table td{padding:14px 20px;font-size:14px;line-height:1.5;border-bottom:1px solid var(--border);text-align:center}
.ushp-table tr:nth-child(even) td{background:#f8fbfe}
.ushp-table td:first-child{background:var(--coral-bg);color:#7f1d1d;font-weight:500}
.ushp-table td:last-child{background:var(--mint-bg);color:#065f46;font-weight:500}

/* ── FEATURES GRID ── */
.ushp-fgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;margin-top:24px}
.ushp-fcard{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:28px 24px;transition:box-shadow .25s,transform .25s}
.ushp-fcard:hover{box-shadow:var(--shh);transform:translateY(-3px)}
.ushp-fcard-icon{width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,var(--navy),#1a4a7a);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:16px;color:#fff}
.ushp-fcard h3{font-size:18px;font-weight:800;color:var(--navy);margin:0 0 8px}
.ushp-fcard p{font-size:14px;color:var(--muted);line-height:1.6;margin:0}
.ushp-fcard ul{list-style:none;padding:0;margin:8px 0 0}
.ushp-fcard li{font-size:14px;color:var(--text);padding:4px 0;display:flex;align-items:center;gap:6px}
.ushp-fcard li::before{content:'✓';color:var(--orange);font-weight:700;font-size:13px}

/* ── BENEFITS ── */
.ushp-benefits{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:24px}
.ushp-ben{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:28px 24px}
.ushp-ben h3{font-size:18px;font-weight:800;color:var(--navy);margin:0 0 12px}
.ushp-ben ul{list-style:none;padding:0;margin:0}
.ushp-ben li{font-size:14px;color:var(--text);padding:6px 0;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.ushp-ben li::before{content:'✓';color:var(--orange);font-weight:700;flex-shrink:0}

/* ── IMAGE + TEXT ── */
.ushp-split{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center;margin-top:24px}
.ushp-split img{border-radius:var(--r);box-shadow:var(--sh)}
.ushp-split-text h3{font-size:22px;font-weight:800;color:var(--navy);margin:0 0 12px}
.ushp-split-text p{font-size:15px;color:var(--text);line-height:1.7;margin:0 0 16px}
.ushp-split-text ul{list-style:none;padding:0;margin:0}
.ushp-split-text li{font-size:14px;padding:5px 0;display:flex;align-items:center;gap:8px}
.ushp-split-text li::before{content:'✓';color:var(--orange);font-weight:700}

/* ── BUNDLE CTA ── */
.ushp-bundle{background:var(--navy);border-radius:20px;padding:48px 40px;display:grid;grid-template-columns:1fr auto;gap:40px;align-items:center;margin-top:32px}
.ushp-bundle-badge{display:inline-block;background:var(--orange);color:#fff;font-size:12px;font-weight:800;padding:6px 16px;border-radius:20px;margin-bottom:16px}
.ushp-bundle h3{font-size:28px;font-weight:900;color:#fff;margin:0 0 8px}
.ushp-bundle-desc{font-size:15px;color:rgba(255,255,255,.7);margin-bottom:16px}
.ushp-bundle-list{list-style:none;padding:0;margin:0 0 20px}
.ushp-bundle-list li{color:#fff;font-size:15px;padding:4px 0;display:flex;align-items:center;gap:8px}
.ushp-bundle-list li::before{content:'✓';color:var(--mint);font-weight:700}
.ushp-bundle-cta .ushp-btn{font-size:16px;padding:16px 32px}
.ushp-bundle-price{text-align:right}
.ushp-bundle-orig{font-size:14px;color:rgba(255,255,255,.5);text-decoration:line-through}
.ushp-bundle-now{font-size:48px;font-weight:900;color:#fff;line-height:1}
.ushp-bundle-save{display:inline-block;background:var(--orange);color:#fff;font-size:13px;font-weight:700;padding:6px 16px;border-radius:20px;margin-top:8px}
.ushp-bundle-ship{font-size:13px;color:rgba(255,255,255,.6);margin-top:8px}

/* ── FAQ ── */
.ushp-faq{margin-top:24px}
.ushp-faq-item{border-bottom:1px solid var(--border)}
.ushp-faq-q{width:100%;background:none;border:none;padding:20px 40px 20px 0;font-size:16px;font-weight:700;color:var(--navy);text-align:left;cursor:pointer;position:relative;font-family:inherit;line-height:1.4}
.ushp-faq-q::after{content:'+';position:absolute;right:0;top:50%;transform:translateY(-50%);font-size:22px;font-weight:300;color:var(--muted);transition:transform .2s}
.ushp-faq-item.open .ushp-faq-q::after{transform:translateY(-50%) rotate(45deg)}
.ushp-faq-a{max-height:0;overflow:hidden;transition:max-height .3s ease;padding:0 0 0 0}
.ushp-faq-item.open .ushp-faq-a{max-height:300px;padding-bottom:20px}
.ushp-faq-a p{font-size:14px;color:var(--muted);line-height:1.7;margin:0}

/* ── CTA BOTTOM ── */
.ushp-cta-bottom{background:linear-gradient(135deg,var(--navy) 0%,#1a4a7a 100%);padding:56px 20px;text-align:center}
.ushp-cta-bottom h2{font-size:clamp(24px,3.5vw,38px);font-weight:900;color:#fff;margin:0 0 12px;letter-spacing:-.6px}
.ushp-cta-bottom p{font-size:16px;color:rgba(255,255,255,.7);max-width:500px;margin:0 auto 28px;line-height:1.6}
.ushp-cta-bottom .ushp-btn{font-size:16px;padding:16px 36px}

/* ── INTERNAL LINKS ── */
.ushp-ilinks{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:24px}
.ushp-ilink{display:inline-flex;align-items:center;gap:6px;background:#fff;border:1px solid var(--border);border-radius:10px;padding:10px 18px;font-size:13px;font-weight:600;color:var(--navy);transition:box-shadow .2s,border-color .2s}
.ushp-ilink:hover{box-shadow:var(--sh);border-color:var(--navy)}

/* ── STICKY MOBILE CTA ── */
.ushp-sticky{display:none;position:fixed;bottom:0;left:0;right:0;z-index:999;background:#fff;padding:12px 16px;box-shadow:0 -4px 20px rgba(0,0,0,.12);border-top:1px solid var(--border)}
.ushp-sticky-inner{display:flex;align-items:center;justify-content:space-between;max-width:600px;margin:0 auto;gap:12px}
.ushp-sticky-info{font-size:13px;font-weight:700;color:var(--navy);line-height:1.3}
.ushp-sticky-price{font-size:11px;color:var(--muted);font-weight:500}
.ushp-sticky .ushp-btn{padding:12px 24px;font-size:14px;flex-shrink:0}

/* ── MOBILE ── */
@media(max-width:768px){
  .ushp-hero{padding:32px 16px 40px}
  .ushp-hero-inner{grid-template-columns:1fr;gap:28px;text-align:center}
  .ushp-sub{margin-left:auto;margin-right:auto}
  .ushp-ctas{justify-content:center}
  .ushp-proof{justify-content:center}
  .ushp-hero-img{max-width:280px;margin:0 auto}
  .ushp-hero-badge{display:none}
  .ushp-trust{flex-direction:column;align-items:stretch}
  .ushp-ti{justify-content:center;padding:10px 16px;font-size:12px}
  .ushp-ti:not(:last-child){border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}
  .ushp-stats{grid-template-columns:repeat(2,1fr);gap:10px}
  .ushp-stat{padding:18px 12px}
  .ushp-stat-val{font-size:22px}
  .ushp-ps{grid-template-columns:1fr;gap:16px}
  .ushp-ps-card{padding:24px 20px}
  .ushp-table{font-size:12px}
  .ushp-table th,.ushp-table td{padding:10px 12px}
  .ushp-fgrid{grid-template-columns:1fr}
  .ushp-benefits{grid-template-columns:1fr}
