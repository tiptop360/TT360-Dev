{% assign hero_img   = toothbrush.featured_image %}

{%- comment -%} ── META INJECTION ── {%- endcomment -%}
<script>
(function(){
  var t='Kids U-Shaped Electric Toothbrush UAE | 60-Second Clean | TipTop360';
  var d='Best U-shaped kids electric toothbrush in Dubai & UAE. 360° clean in 60 seconds — soft silicone, BPA-free, ages 2-12. Free next-day delivery across UAE. Shop TipTop360.';
  document.title=t;
  function setM(n,c){var m=document.querySelector('meta['+n+']');if(m)m.setAttribute('content',c);else{m=document.createElement('meta');var p=n.split('=');m.setAttribute(p[0].replace(/"/g,''),p[1]?p[1].replace(/"/g,''):c);if(!p[1])m.setAttribute('content',c);document.head.appendChild(m)}}
  setM('name="description"',d);
  setM('property="og:title"',t);
  setM('property="og:description"',d);
  setM('property="og:type"','website');
  setM('property="og:url"','https://tiptop360.com/pages/u-shaped-toothbrush');
  setM('name="twitter:title"',t);
  setM('name="twitter:description"',d);
})();
</script>

