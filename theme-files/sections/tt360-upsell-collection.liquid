<script>
(function(){
'use strict';
var FREE=20000;
function fmt(c){return 'AED '+Math.round(c/100);}
function toast(msg){var t=document.getElementById('t3u-toast');if(!t)return;t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2400);}
function setCount(n){
  var b=document.getElementById('t3u-drcnt');if(b)b.textContent=n;
  ['[data-cart-count]','[data-cart-item-count]','.cart-count','#CartCount','.cart__count','.site-header__cart-count','.cart-icon__bubble','.cart-count-bubble'].forEach(function(s){document.querySelectorAll(s).forEach(function(e){e.textContent=n;e.style.display=n>0?'':'none';});});
  document.dispatchEvent(new CustomEvent('cart:updated',{detail:{cartCount:n}}));
}
function shipBar(total){
  var bar=document.getElementById('t3u-ship');
  var txt=document.getElementById('t3u-ship-txt');
  var fill=document.getElementById('t3u-ship-fill');
  if(!bar)return;
  if(total>=FREE){bar.classList.add('done');txt.innerHTML='<strong>Free delivery unlocked!</strong>';fill.style.width='100%';}
  else{var rem=Math.round((FREE-total)/100);bar.classList.remove('done');txt.innerHTML='Add <strong>AED '+rem+'</strong> more for free delivery';fill.style.width=Math.min(Math.round(total/FREE*100),99)+'%';}
}
function renderCart(cart){
  var body=document.getElementById('t3u-drbody');
  var foot=document.getElementById('t3u-drfoot');
  var tot=document.getElementById('t3u-total');
  var co=document.getElementById('t3u-co');
  if(!body)return;
  setCount(cart.item_count);
  shipBar(cart.total_price);
  if(!cart.items||!cart.items.length){body.innerHTML='<p class="t3u-drempty">Your cart is empty</p>';if(foot)foot.style.display='none';return;}
  if(foot)foot.style.display='block';
  if(tot)tot.textContent=fmt(cart.total_price);
  if(co)co.innerHTML='Checkout &mdash; '+fmt(cart.total_price);
  var h='';
  cart.items.forEach(function(it){
    h+='<div class="t3u-dritem"><img src="'+it.image+'" alt="'+it.product_title+'" width="64" height="64" loading="lazy">';
    h+='<div class="t3u-drinfo"><p class="t3u-driname">'+it.product_title+'</p>';
    if(it.variant_title&&it.variant_title!=='Default Title')h+='<p class="t3u-drivar">'+it.variant_title+'</p>';
    h+='<div class="t3u-drirow"><span class="t3u-drip">'+fmt(it.final_line_price)+'</span>';
    h+='<div class="t3u-drqty">';
    h+='<button class="t3u-drqb'+(it.quantity===1?' danger':'')+'" onclick="t3uQty(\''+it.key+'\','+(it.quantity-1)+')">'+(it.quantity===1?'&#128465;':'&minus;')+'</button>';
    h+='<span class="t3u-drqn">'+it.quantity+'</span>';
    h+='<button class="t3u-drqb" onclick="t3uQty(\''+it.key+'\','+(it.quantity+1)+')">+</button>';
    h+='</div></div></div></div>';
  });
  body.innerHTML=h;
}
function fetchCart(){return fetch('/cart.js',{headers:{'X-Requested-With':'XMLHttpRequest'}}).then(function(r){return r.json();}).then(function(c){renderCart(c);return c;});}
window.t3uOpenCart=function(){document.getElementById('t3u-ov').classList.add('open');document.getElementById('t3u-dr').classList.add('open');document.body.style.overflow='hidden';fetchCart();};
window.t3uCloseCart=function(){document.getElementById('t3u-ov').classList.remove('open');document.getElementById('t3u-dr').classList.remove('open');document.body.style.overflow='';};
window.t3uQty=function(key,qty){fetch('/cart/change.js',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify({id:key,quantity:qty})}).then(function(r){return r.json();}).then(renderCart);};
window.t3uATC=function(vid,btn){
  if(!btn||btn.classList.contains('loading'))return;
  var orig=btn.textContent;
  btn.classList.add('loading');btn.textContent='Adding...';
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},body:JSON.stringify({id:vid,quantity:1})})
  .then(function(r){if(!r.ok)throw new Error(r.status);return r.json();})
  .then(function(){btn.classList.remove('loading');btn.classList.add('done');btn.textContent='Added!';fetchCart().then(function(){t3uOpenCart();});setTimeout(function(){btn.classList.remove('done');btn.textContent=orig;},2500);})
  .catch(function(){btn.classList.remove('loading');btn.textContent='Try again';toast('Error adding item. Please try again.');setTimeout(function(){btn.textContent=orig;},2200);});
};
(function(){
  var dr=document.getElementById('t3u-dr');if(!dr)return;
  var sY=0,sT=0;
  dr.addEventListener('touchstart',function(e){sY=e.touches[0].clientY;sT=Date.now();},{passive:true});
  dr.addEventListener('touchend',function(e){var dy=e.changedTouches[0].clientY-sY;var dt=Date.now()-sT;if(dy>80||(dy>40&&dt<250))t3uCloseCart();},{passive:true});
})();
document.addEventListener('keydown',function(e){if(e.key==='Escape')t3uCloseCart();});
fetchCart();
})();
</script>

