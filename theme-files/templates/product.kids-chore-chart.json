        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "Is the Kids Routine Chore Chart safe for children under 3?",
            "answer": "<p>Designed for ages 3 and up. Toddlers under 3 may lack the fine motor control for the sliding checklist. With direct parental guidance, younger children can still benefit, but it works best from age 3 onwards.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "How is this different from a regular printed chore chart?",
            "answer": "<p>Unlike static printed charts that fade and need marker rewrites, this features a wipeable, reusable sliding system. Children physically interact with the checklist — sliding tokens — which keeps them engaged through tactile feedback.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
          "settings": {
            "question": "Is this suitable for a 10-year-old?",
            "answer": "<p>Yes. While younger children (3-6) enjoy the tactile sliding element, children aged 7-10 benefit from the independence and responsibility it fosters. Older kids appreciate managing their own routine without parental prompting.</p>"
          }
        },
