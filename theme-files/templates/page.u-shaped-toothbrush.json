          "type": "faq",
          "settings": {
            "faq_title": "Is it safe for kids with sensitive gums?",
            "faq_des": "<p>Yes. The soft silicone bristles and gentle vibration mode are specifically designed to be kind to sensitive gums and young enamel. There's no hard scrubbing — just even, gentle vibration across all surfaces.<br/><br/></p>"
          }
        },
        "faq_iHLNRF": {
