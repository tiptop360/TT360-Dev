          "type": "faq",
          "settings": {
            "faq_title": "What age is this toothbrush suitable for?",
            "faq_des": "<p>This toothbrush is designed for children aged 2 to 12. It's available in different size variants to fit toddler and older child mouth sizes comfortably.<br/><br/></p>"
          }
        },
