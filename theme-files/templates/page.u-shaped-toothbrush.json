        "faq_FBNJBG": {
          "type": "faq",
          "settings": {
            "faq_title": "Is this toothbrush BPA-free?",
            "faq_des": "<p>Yes. All materials — including the silicone brush head and handle — are 100% BPA-free and certified safe for children.<br/><br/></p>"
          }
        },
