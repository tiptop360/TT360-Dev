        "faq_safety": {
          "type": "faq",
          "settings": {
            "question": "Will the magnets damage my phone, credit cards, or electronics?",
            "answer": "<p><strong>No.</strong> GymGear uses shielded neodymium magnets with a directionally focused magnetic field. They are strong enough to hold 5+ kg against metal surfaces but completely safe for all smartphones, credit cards, hotel key cards, Apple Watch, AirPods, and other electronics stored inside the bag. The shielded design ensures no magnetic interference with your belongings.</p>"
          }
        },
        "faq_strength": {
          "type": "faq",
          "settings": {
            "question": "How strong is the magnetic hold — will my bag fall off?",
            "answer": "<p>GymGear's neodymium magnets are rated for <strong>5+ kg of hold strength</strong>. That means your loaded gym bag stays locked to squat racks, cable machines, and metal lockers through your entire workout. The magnets grip any ferromagnetic metal surface — steel, iron, nickel-coated equipment. One pull detaches it cleanly when you're done.</p>"
          }
        },
        "faq_1": {
          "type": "faq",
          "settings": {
            "question": "What is a magnetic gym bag and how does GymGear work?",
            "answer": "<p>GymGear has powerful neodymium magnets built into the back panel that snap securely to any metal gym rack, machine, or locker. Your bag stays off dirty floors and at perfect grab height while you train — no hooks, no straps, no setup.</p>"
          }
        },
        "faq_2": {
          "type": "faq",
          "settings": {
            "question": "Is GymGear only for the gym, or can I use it outdoors?",
            "answer": "<p>GymGear is built for multi-purpose use — gym, outdoor training, pool, office runs, school pickup. The weatherproof shell handles UAE rain, humidity, and sweat without a second thought.</p>"
          }
        },
        "faq_3": {
          "type": "faq",
