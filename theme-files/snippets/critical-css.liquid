{%- comment -%} Critical CSS — above-fold only, prevents FOUT/CLS {%- endcomment -%}
<style>
/* BASE */
*,*::before,*::after{box-sizing:border-box}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;font-size:16px;line-height:1.5;color:#1a1a1a;background:#fff}
img{max-width:100%;height:auto;display:block}
a{color:inherit;text-decoration:none}

/* FONT DISPLAY — prevent invisible text flash */
@font-face{font-display:swap}

/* CLS PREVENTION — reserve height for hero images */
.aivox-stage,.gb-stage,.product-single__photos{min-height:300px;background:#f5f5f5}
@media(min-width:768px){.aivox-stage,.gb-stage,.product-single__photos{min-height:500px}}

/* HEADER SKELETON */
header,.site-header,.header-wrapper{min-height:60px}
@media(min-width:990px){header,.site-header,.header-wrapper{min-height:72px}}

/* PRODUCT TITLE */
.aivox-title,.gb-title,h1.product__title,h1{font-size:24px;line-height:1.25;font-weight:700;margin:0 0 12px}
@media(min-width:768px){.aivox-title,.gb-title,h1.product__title,h1{font-size:32px}}

/* PRICE */
.aivox-price-main,.gb-price,.product-single__price{font-size:26px;font-weight:700;color:#12395e}
.aivox-price-was,.gb-price-was{font-size:16px;color:#888;text-decoration:line-through;margin-left:8px}

/* ADD TO CART */
.product-form__cart-submit,.aivox-atc-btn,.gb-atc-btn,button[name="add"]{
  display:block;width:100%;background:#12395e;color:#fff5e6;
  font-size:17px;font-weight:700;min-height:56px;padding:0 24px;
  border:none;border-radius:10px;cursor:pointer;letter-spacing:.02em;
  -webkit-tap-highlight-color:transparent;
}

/* TRUST BAND */
.cro-trust-band,[class*="trust-band"]{display:flex;flex-wrap:wrap;gap:8px;padding:12px 16px;background:#f8f9fa;border-radius:8px;font-size:13px}

/* STICKY ATC */
.sticky-atc,[class*="sticky-atc"]{position:fixed;bottom:0;left:0;right:0;z-index:200;background:rgba(255,255,255,.96);box-shadow:0 -2px 12px rgba(0,0,0,.08);padding:10px 16px}

/* MOBILE */
@media(max-width:768px){
  html,body{overflow-x:clip;max-width:100vw}
  .container,.wrapper,section,header,footer,main{max-width:100%}
  h1,.aivox-title,.gb-title{font-size:24px}
  h2{font-size:20px}
  .product-form__cart-submit,.aivox-atc-btn,.gb-atc-btn{font-size:17px;min-height:56px}
}
@media(max-width:380px){
  h1,.aivox-title,.gb-title{font-size:21px}
  .product-form__cart-submit,.aivox-atc-btn,.gb-atc-btn{font-size:16px}
}
</style>