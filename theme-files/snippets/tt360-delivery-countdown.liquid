{%- comment -%}
  TT360 delivery-cutoff countdown — v2 (Dubai-timezone-aware)
  Shows "Order within Xh Ym for next-day delivery".
  Cutoff and Sunday-no-delivery logic evaluated against Asia/Dubai (UTC+4),
  not the visitor's local clock.

  Usage:
    {% render 'tt360-delivery-countdown' %}
    {% render 'tt360-delivery-countdown', cutoff_hour: 18 %}
{%- endcomment -%}

{%- assign tt360_cutoff = cutoff_hour | default: 20 -%}

<div class="tt360-delivery-countdown" data-cutoff="{{ tt360_cutoff }}" role="status" aria-live="polite">
  <span class="tt360-delivery-countdown__icon" aria-hidden="true">&#9201;</span>
  <span class="tt360-delivery-countdown__text">
    Order within <strong class="tt360-delivery-countdown__time">--h --m</strong> for next-day delivery
  </span>
</div>

<style>
  .tt360-delivery-countdown {
    display: flex; align-items: center; gap: 8px;
    background: #E8F5E9; border: 1px solid #C8E6C9; border-radius: 8px;
    padding: 10px 14px; margin: 8px 0 12px;
    font-size: 13px; color: #2E7D32;
  }
  .tt360-delivery-countdown__icon { font-size: 16px; line-height: 1; }
  .tt360-delivery-countdown__text strong { color: #1B5E20; font-weight: 700; }
</style>

<script>
(function () {
  /* Locate this widget — fall back to last .tt360-delivery-countdown on page */
  var el = document.currentScript && document.currentScript.previousElementSibling &&
           document.currentScript.previousElementSibling.previousElementSibling;
  if (!el || !el.classList || !el.classList.contains('tt360-delivery-countdown')) {
    var all = document.querySelectorAll('.tt360-delivery-countdown');
    el = all[all.length - 1];
  }
  if (!el) return;

  var cutoffHour = parseInt(el.getAttribute('data-cutoff') || '20', 10);
  var timeEl = el.querySelector('.tt360-delivery-countdown__time');

  /* Returns a Date whose local accessors (.getHours, .getDay …) reflect
     the current wall-clock time in Asia/Dubai (UTC+4). */
  function dubaiNow() {
    try {
      var parts = {};
      new Intl.DateTimeFormat('en-US', {
        timeZone: 'Asia/Dubai',
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
      }).formatToParts(new Date()).forEach(function (p) {
        parts[p.type] = parseInt(p.value, 10) || 0;
      });
      return new Date(
        parts.year, parts.month - 1, parts.day,
        parts.hour % 24, parts.minute, parts.second
      );
    } catch (e) {
      /* Fallback: shift UTC by +4 h, read via UTC accessors */
      var d = new Date(Date.now() + 4 * 3600000);
      return new Date(
        d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate(),
        d.getUTCHours(), d.getUTCMinutes(), d.getUTCSeconds()
      );
    }
  }

  function tick() {
    var now = dubaiNow();
    /* Sunday (0) — no delivery, hide the widget */
    if (now.getDay() === 0) {
      el.style.display = 'none';
      return;
    }
    /* Deadline = today at cutoff hour in Dubai time */
    var deadline = new Date(
      now.getFullYear(), now.getMonth(), now.getDate(), cutoffHour, 0, 0
    );
    /* Past today’s cutoff — count to tomorrow’s cutoff */
    if (now >= deadline) deadline.setDate(deadline.getDate() + 1);
    var diff = Math.max(deadline - now, 0);
    var hrs  = Math.floor(diff / 3600000);
    var mins = Math.floor((diff % 3600000) / 60000);
    if (timeEl) timeEl.textContent = hrs + 'h ' + mins + 'm';
  }

  tick();
  setInterval(tick, 60000);
})();
</script>
