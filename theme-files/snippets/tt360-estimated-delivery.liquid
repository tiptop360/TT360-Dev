{%- comment -%}
  TT360 Estimated Delivery widget — v2
  Always evaluates the 20:00 cutoff in Asia/Dubai time (UTC+4),
  regardless of the visitor's local timezone or CDN cache.

  Rules (locked 2026-05-28):
    - Delivery days : Mon–Sat (Sunday = no delivery)
    - Same-day cutoff : 20:00 UAE
    - Before cutoff on a delivery day  → next calendar day (tomorrow)
    - After cutoff on a delivery day   → skip +2 days, then next delivery day
    - Non-delivery day today           → next delivery day (cutoff ignored)

  Per-render overrides:
    {% render 'tt360-estimated-delivery', cutoff_hour: 18, label: 'Delivered by' %}

  Holidays: set theme setting `tt360_delivery_holidays` (comma/newline YYYY-MM-DD)
  or pass `holidays` param per render.
{%- endcomment -%}

{%- assign tt360_cutoff  = cutoff_hour | default: 20 -%}
{%- assign tt360_label   = label       | default: 'Get it by' -%}
{%- assign tt360_holidays = holidays   | default: settings.tt360_delivery_holidays | default: '' -%}

<div class="tt360-eta"
     data-cutoff="{{ tt360_cutoff }}"
     data-delivery-days="1,2,3,4,5,6"
     data-holidays="{{ tt360_holidays | escape }}"
     data-label="{{ tt360_label | escape }}"
     role="status" aria-live="polite">
  <span class="tt360-eta__icon" aria-hidden="true">&#128666;</span>
  <span class="tt360-eta__copy">
    <span class="tt360-eta__label">{{ tt360_label }}</span>
    <strong class="tt360-eta__date">&hellip;</strong>
    <span class="tt360-eta__note"></span>
  </span>
</div>

<style>
  .tt360-eta {
    display: flex; align-items: center; gap: 10px;
    background: #E8F5E9; border: 1px solid #C8E6C9; border-radius: 8px;
    padding: 10px 14px; margin: 8px 0 12px;
    font-size: 13px; color: #1B5E20; line-height: 1.4;
  }
  .tt360-eta__icon  { font-size: 18px; line-height: 1; }
  .tt360-eta__copy  { display: flex; flex-wrap: wrap; align-items: baseline; gap: 4px 6px; }
  .tt360-eta__label { color: #2E7D32; }
  .tt360-eta__date  { color: #1B5E20; font-weight: 700; }
  .tt360-eta__note  { color: #2E7D32; opacity: .85; font-size: 12px; }
</style>

<script>
(function () {
  var nodes = document.querySelectorAll('.tt360-eta');
  var el = nodes[nodes.length - 1];
  if (!el) return;

  var cutoffHour  = parseInt(el.getAttribute('data-cutoff') || '20', 10);
  var deliveryDays = (el.getAttribute('data-delivery-days') || '1,2,3,4,5,6')
    .split(',').map(function (s) { return parseInt(s, 10); });
  var holidays = (el.getAttribute('data-holidays') || '')
    .split(/[,\s]+/).filter(Boolean);

  var dateEl = el.querySelector('.tt360-eta__date');
  var noteEl = el.querySelector('.tt360-eta__note');

  /* Returns a Date whose .getFullYear/.getMonth/.getDate/.getDay/.getHours
     reflect the current wall-clock time in Asia/Dubai (UTC+4),
     independent of the visitor's local timezone. */
  function dubaiNow() {
    try {
      var parts = {};
      new Intl.DateTimeFormat('en-US', {
        timeZone: 'Asia/Dubai',
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit', hour12: false
      }).formatToParts(new Date()).forEach(function (p) {
        parts[p.type] = parseInt(p.value, 10) || 0;
      });
      /* hour12:false can return 24 for midnight — normalise */
      return new Date(
        parts.year, parts.month - 1, parts.day,
        parts.hour % 24, parts.minute
      );
    } catch (e) {
      /* Fallback: shift UTC by +4 h, read via UTC accessors */
      var d = new Date(Date.now() + 4 * 3600000);
      return new Date(
        d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate(),
        d.getUTCHours(), d.getUTCMinutes()
      );
    }
  }

  function ymd(d) {
    return d.getFullYear() + '-' +
      String(d.getMonth() + 1).padStart(2, '0') + '-' +
      String(d.getDate()).padStart(2, '0');
  }

  function isClosed(d) {
    if (deliveryDays.indexOf(d.getDay()) === -1) return true;
    if (holidays.indexOf(ymd(d)) !== -1) return true;
    return false;
  }

  function compute() {
    var now         = dubaiNow();
    var todayClosed = isClosed(now);
    /* After cutoff on an open day: need +2 days before the next delivery day */
    var advance = (!todayClosed && now.getHours() >= cutoffHour) ? 2 : 1;
    var d = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    d.setDate(d.getDate() + advance);
    /* Walk forward past any closed days (max 21 steps avoids infinite loop) */
    for (var guard = 0; isClosed(d) && guard < 21; guard++) {
      d.setDate(d.getDate() + 1);
    }

    var weekday  = d.toLocaleDateString('en-US', { weekday: 'long' });
    var monthDay = d.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });

    var nowMid = new Date(now.getFullYear(), now.getMonth(), now.getDate());
    var diff   = Math.round((d - nowMid) / 86400000);
    var note   = diff === 1 ? '(tomorrow)' : diff === 2 ? '(in 2 days)' : '';

    if (dateEl) dateEl.textContent = weekday + ', ' + monthDay;
    if (noteEl) noteEl.textContent = note;
  }

  compute();
  /* Re-run every minute so a long-open PDP stays accurate past cutoff */
  setInterval(compute, 60000);
})();
</script>
