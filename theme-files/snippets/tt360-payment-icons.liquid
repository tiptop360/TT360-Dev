{%- comment -%}
  TT360 unified payment icons block. Renders Shopify's enabled payment icons
  plus a "Cash on Delivery" pill that is specific to the UAE market.

  Usage:
    {% render 'tt360-payment-icons' %}
{%- endcomment -%}
<div class="tt360-payment" aria-label="Accepted payment methods">
  <p class="tt360-payment__label">Guaranteed safe checkout</p>
  <div class="tt360-payment__row">
    {%- if shop.enabled_payment_types != empty -%}
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'tt360-payment__icon' }}
      {%- endfor -%}
    {%- endif -%}
    <span class="tt360-payment__cod">Cash on Delivery</span>
  </div>
</div>
<style>
  .tt360-payment{margin-top:12px;padding-top:12px;border-top:1px solid #eee;}
  .tt360-payment__label{font-size:11px;color:#888;text-transform:uppercase;letter-spacing:.5px;margin:0 0 8px;}
  .tt360-payment__row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
  .tt360-payment__row .tt360-payment__icon,
  .tt360-payment__row svg{height:24px;width:auto;opacity:.85;}
  .tt360-payment__cod{font-size:12px;color:#12395e;background:#eaf4ee;border:1px solid #cfe8d8;border-radius:4px;padding:3px 8px;font-weight:600;}
</style>
