{%- liquid
  if template.name == 'product'
    assign og_title = page_title | default: product.title | strip_html
    assign og_description = page_description | default: product.description | strip_html | truncate: 200
    assign og_image = product.featured_image | image_url: width: 1200
    assign og_type = 'product'
  elsif template.name == 'collection'
    assign og_title = collection.title | append: ' Collection | TipTop360'
    assign og_description = collection.description | strip_html | truncate: 200 | default: 'Shop at TipTop360. Feel-Good Finds, Delivered Fast across UAE.'
    assign og_image = collection.image | image_url: width: 1200
    assign og_type = 'website'
  elsif template.name == 'article'
    assign og_title = article.title | strip_html
    assign og_description = article.excerpt_or_content | strip_html | truncate: 200
    assign og_image = article.image | image_url: width: 1200
    assign og_type = 'article'
  else
    assign og_title = page_title | append: ' | TipTop360'
    assign og_description = page_description | default: 'Feel-Good Finds, Delivered Fast across UAE'
    assign og_image = settings.share_image | image_url: width: 1200
    assign og_type = 'website'
  endif
-%}

<meta property="og:site_name" content="TipTop360">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:description" content="{{ og_description | escape }}">
{%- if og_image -%}<meta property="og:image" content="https:{{ og_image }}">{%- endif -%}
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:locale" content="en_AE">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@tiptop360_online">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image -%}<meta name="twitter:image" content="https:{{ og_image }}">{%- endif -%}

{%- if template.name == 'product' -%}
<meta property="product:price:amount" content="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}">
<meta property="product:price:currency" content="{{ cart.currency.iso_code | default: 'AED' }}">
<meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
{%- endif -%}
