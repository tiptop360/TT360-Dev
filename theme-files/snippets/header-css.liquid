{{ 'tt360-bootstrap.css' | asset_url | stylesheet_tag }}

{%- render 'font-icon' -%}
{%- if settings.font_family_custom -%}
  {%- render 'font-custom' -%}
{%- endif -%}
<style>
  {%- if settings.font_family_custom -%}
    {%- liquid
      assign fontname = 'BaselClassic'
      assign font_family_1 = fontname
      assign font_family_1 = fontname
    -%}
    {%- if settings.font_family_custom_body -%}
      {%- if settings.font_family2_google == blank -%}
        {%- assign font2 = settings.font_family2 -%}
        {{ font2 | font_face: font_display: 'swap' }}
        {%- liquid
          assign font2_bold = font2 | font_modify: 'weight', '700'
          assign font2_semi = font2 | font_modify: 'weight', '600'
          assign font2_medium = font2 | font_modify: 'weight', '500'
          assign font2_italic = font2 | font_modify: 'style', 'italic'
          assign font2_bold_italic = font2_bold | font_modify: 'style', 'italic'
        -%}
        {{ font2_bold | font_face: font_display: 'swap' }}
        {{ font2_medium | font_face: font_display: 'swap' }}
        {{ font2_semi | font_face: font_display: 'swap' }}
        {{ font2_italic | font_face: font_display: 'swap' }}
        {{ font2_bold_italic | font_face: font_display: 'swap' }}
        {%- capture font_family_2 -%}{{ font2.family }},{{ font2.fallback_families }}{%- endcapture -%}
        {%- else -%}
          @import url('https://fonts.googleapis.com/css?family={{ settings.font_family2_google | replace: ' ', '+' }}:300,400,500,600,700&display=swap');
        {%- liquid
          assign font_family_2 = settings.font_family2_google
        -%}
      {%- endif -%}
    {%- else -%}
      {%- liquid
        assign font_family_2 = fontname
      -%}
    {%- endif -%}
  {%- else -%}
    {%- if settings.font_family_google == blank -%}
      {%- liquid
        assign font1 = settings.font_family
      -%}
    {{ font1 | font_face: font_display: 'swap' }}
    {%- liquid
      assign font1_bold = font1 | font_modify: 'weight', '700'
      assign font1_semi = font1 | font_modify: 'weight', '600'
      assign font1_medium = font1 | font_modify: 'weight', '500'
      assign font1_italic = font1 | font_modify: 'style', 'italic'
      assign font1_bold_italic = font1_bold | font_modify: 'style', 'italic'
    -%}
    {{ font1_bold | font_face: font_display: 'swap' }}
    {{ font1_medium | font_face: font_display: 'swap' }}
    {{ font1_semi | font_face: font_display: 'swap' }}
    {{ font1_italic | font_face: font_display: 'swap' }}
    {{ font1_bold_italic | font_face: font_display: 'swap' }}
    {%- capture font_family_1 -%}{{ font1.family }},{{ font1.fallback_families }}{%- endcapture -%}
    {%- else -%}
    @import url('https://fonts.googleapis.com/css?family={{ settings.font_family_google | replace: ' ', '+' }}:300,400,500,600,700&display=swap');
    {%- liquid
      assign font_family_1 = settings.font_family_google
    -%}
    {%- endif -%}
    {%- if settings.font_family2_google == blank -%}
    
    {%- liquid
      assign font2 = settings.font_family2
      if font2 != settings.font_family 
        echo font2 | font_face: font_display: 'swap'
        assign font2_bold = font2 | font_modify: 'weight', '700'
        assign font2_semi = font2 | font_modify: 'weight', '600'
        assign font2_medium = font2 | font_modify: 'weight', '500'
        assign font2_italic = font2 | font_modify: 'style', 'italic'
        assign font2_bold_italic = font2_bold | font_modify: 'style', 'italic'

        echo font2_bold | font_face: font_display: 'swap' 
        echo font2_medium | font_face: font_display: 'swap' 
        echo font2_semi | font_face: font_display: 'swap' 
        echo font2_italic | font_face: font_display: 'swap' 
      endif
    -%}
    {%- capture font_family_2 -%}{{ font2.family }},{{ font2.fallback_families }}{%- endcapture -%}
    {%- else -%}
      @import url('https://fonts.googleapis.com/css?family={{ settings.font_family2_google | replace: ' ', '+' }}:300,400,500,600,700&display=swap');
    {%- assign font_family_2 = settings.font_family2_google -%}
    {%- endif -%}
  {%- endif -%} 
  {%-liquid
    assign enable_button_shadow = settings.enable_button_shadow
    -%}
  :root {
    
      --duration-short: .1s;
      --duration-default: .2s;
      --duration-long: .5s;

      --g-font-1: {{ font_family_1 }};
      --g-font-2: {{ font_family_2 }};
      --g-font-3: Blackseas;
      --g-font-size: {{ settings.base_size }}px;
      
      --g-main: {{ settings.color_primary }};
      --g-main-2: {{ settings.color_secondary }};
      --g-color-heading: {{ settings.color_body_headings }};
      --g-color-heading-rgb:{{ settings.color_body_headings.red }}, {{ settings.color_body_headings.green }}, {{ settings.color_body_headings.blue }};
      --g-cta-button: {{ settings.color_cta }};
      --g-cta-text:{{ settings.color_button_text }};
      --g-color-carousel:{{ settings.color_body_headings }};
      --g-container: {{ settings.container }}px;
      --g-gutter: {{ settings.gutter }}px;
      --g-hgutter: {{ settings.gutter | divided_by: 2 }}px;
      
      

      --g-alert: {{ settings.alert_text }};
      --g-alert-bg: {{ settings.alert_bg }};
      --g-alert-bd: {{ settings.alert_bd }};
      --g-font-weight-body:{{ settings.font_weight_body }};
      --g-body-lineheight :{{ settings.body_font_lineheight }};
      --g-font-color-subtop:{{ settings.color_sub }};
      --g-font-size-subtop:{{ settings.base_size_sup }}px;
      --g-font-weight-subtop:{{ settings.font_weight_sub }};
      --g-font-spacing-subtop:{{ settings.letter_spacing_sub }}em;

      /*size image*/
      --g-object :cover;

      --g-radius-label : {{ settings.radius_label }}px;
      --g-pos-top-label :{{ settings.top_label }}px;
      --g-pos-left-label :{{ settings.left_label }}px;
      --g-font-topbar :{{ settings.font_family_topbar }};
      --g-bg-sale :{{ settings.sale_label_bg }};
      --g-cl-sale :{{ settings.sale_label_cl }};

      --g-label-size: {{ settings.menu_label_size }}px;
      --g-label-space : {{ settings.menu_label_space }}em;
      
      --g-font-family_btn : {%- if settings.font_family_button == '--g-font-1' -%}{{ font_family_1 }}{%- else -%}{{ font_family_2 }}{%- endif -%};
      --g-font-weight-btn : {{ settings.font_weight_button }};
      --g-font-size-btn : {{ settings.base_size_button }}px;
      --g-font-spacing-btn : {{ settings.letter_spacing_button }}em;
      --g-font-radius-btn : {{ settings.border_radius_btn }}px;
      --g-font-border-bottom-btn : {{ settings.height_border_btn }}px;
      --g-text-transform-btn : {{ settings.text_transform_btn }};
      --g-padding-ver-btn : {{ settings.padding_vertical_btn }}px;
      --g-padding-hoz-btn : {{ settings.padding_hoz_btn }}px;
      --g-height-border-btnline: {{ settings.height_border_btn }}px;

      --g-input-bg:{{ settings.input_bg }};
      --g-input-border:{{ settings.input_border }};
      --g-input-height:{{ settings.input_height }}px;
      --g-input-radius:{{ settings.input_round }}px;

      --g-h1-font-size: {{ settings.h1_font_size }}px;
      --g-h1-font-size-mobile: {{ settings.h1_font_size_mobile }}px;
      --g-h1-font-weight: {{ settings.h1_font_weight }};
      --g-h1-font-spacing: {{ settings.h1_font_spacing }}em;
      --g-h1-font-lineheight: {{ settings.h1_font_lineheight }};
      --g-h1-font-transform: {{ settings.h1_font_transform }};

      --g-h2-font-size: {{ settings.h2_font_size }}px;
      --g-h2-font-size-mobile: {{ settings.h2_font_size_mobile }}px;
      --g-h2-font-weight: {{ settings.h2_font_weight }};
      --g-h2-font-spacing: {{ settings.h2_font_spacing }}em;
      --g-h2-font-lineheight: {{ settings.h2_font_lineheight }};
      --g-h2-font-transform: {{ settings.h2_font_transform }};

      --g-h3-font-size: {{ settings.h3_font_size }}px;
      --g-h3-font-size-mobile: {{ settings.h3_font_size_mobile }}px;
      --g-h3-font-weight: {{ settings.h3_font_weight }};
      --g-h3-font-spacing: {{ settings.h3_font_spacing }}em;
      --g-h3-font-lineheight: {{ settings.h3_font_lineheight }};
      --g-h3-font-transform: {{ settings.h3_font_transform }};

      --g-h4-font-size: {{ settings.h4_font_size }}px;
      --g-h4-font-size-mobile: {{ settings.h4_font_size_mobile }}px;
      --g-h4-font-weight: {{ settings.h4_font_weight }};
      --g-h4-font-spacing: {{ settings.h4_font_spacing }}em;
      --g-h4-font-lineheight: {{ settings.h4_font_lineheight }};
      --g-h4-font-transform: {{ settings.h4_font_transform }};

      --g-h5-font-size: {{ settings.h5_font_size }}px;
      --g-h5-font-size-mobile: {{ settings.h5_font_size_mobile }}px;
      --g-h5-font-weight: {{ settings.h5_font_weight }};
      --g-h5-font-spacing: {{ settings.h5_font_spacing }}em;
      --g-h5-font-lineheight: {{ settings.h5_font_lineheight }};
      --g-h5-font-transform: {{ settings.h5_font_transform }};

      --g-h6-font-size: {{ settings.h6_font_size }}px;
      --g-h6-font-size_mobile: {{ settings.h6_font_size_mobile }}px;
      --g-h6-font-weight: {{ settings.h6_font_weight }};
      --g-h6-font-spacing: {{ settings.h6_font_spacing }}em;
      --g-h6-font-lineheight: {{ settings.h6_font_lineheight }};
      --g-h6-font-transform: {{ settings.h6_font_transform }};


      --g-slide-font-size: {{ settings.slide_font_size }}px;
      --g-slide-font-size-mobile: {{ settings.slide_font_size_mobile }}px;
      --g-slide-font-weight: {{ settings.slide_font_weight }};
      --g-slide-font-spacing: {{ settings.slide_font_spacing }}em;
      --g-slide-font-lineheight: {{ settings.slide_font_lineheight }};
      --g-slide-font-transform: {{ settings.slide_font_transform }};

      --g-p-font_family : var({{ settings.font_family_product }});
      --g-p-font-size: {{ settings.font_size_product }}px;
      --g-p-font-weight: {{ settings.font_weight_product }};
      --g-p-font-spacing: {{ settings.letter_spacing_product }}em;
      --g-p-font-lineheight: {{ settings.font_lineheight_product }};
      --g-p-font-transform: {{ settings.font_transform_product }};

      --color-foreground:{{ settings.color_body_text.red }}, {{ settings.color_body_text.green }}, {{ settings.color_body_text.blue }};

     /* General colors*/
      --color-body-text: {{ settings.color_body_text }};
      --color-body-text-rgb: {{ settings.color_body_text.red }}, {{ settings.color_body_text.green }}, {{ settings.color_body_text.blue }};
      --color-original-rgb: {{ settings.color_body_text.red }}, {{ settings.color_body_text.green }}, {{ settings.color_body_text.blue }};
      --color-body: {{ settings.color_body_bg }} ;
      --color-content:{{ settings.color_content_bg }};
      --color-background: {{ settings.color_body_bg.red }}, {{  settings.color_body_bg.green }}, {{  settings.color_body_bg.blue }};
      --color-accent: {{ settings.color_primary }};

     /*form*/
     --color-form: #f4f4f4;
      --color-form-text: #333;
      --color-disabled: {{ '#f4f4f4' | color_darken: 12 }};
      --color-disabled-border: {{ '#f4f4f4' | color_darken: 15 }};
      --color-disabled-text: rgba(0, 0, 0, 0.4);
      --color-error: #ec523e;
      --color-error-bg: #ec523e;
      --color-drawer-text: {{ settings.color_body_text | color_darken: 25 }};
      --height-announbar: 0px;
      --color-border:233, 233, 233;

      --anim-transition: cubic-bezier(.785,.135,.15,.86);

      /*Height Image*/
      --g-img-portrait:130%;
      --g-img-square:100%;
      --g-img-wide:60%;
      --g-img-landscape:75%;

      /**/
      --g-btn-outline-color: {{ settings.btn_color_outline }};
      --g-btn-hover-color: {{ settings.btn_hover_color }};
      {%- if enable_button_shadow -%}
        --g-btn-shawdow: {{ settings.btn_shadow_color.red }},{{ settings.btn_shadow_color.green }},{{ settings.btn_shadow_color.blue }};
      {%- endif -%}
      --height-announcementbar:0px;
      
      /*Tooltip*/ 
      --g-bg-tooltip:  {{ settings.color_body_headings }};
      --g-color-tooltip: white;
    }
    @media all and (max-width: 749px) {
        :root{
          --g-gutter: 20px;
          --g-hgutter: 10px;
        }  
      
      }
</style>
{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-predictive-search.aio.min.css' | asset_url }}" media="print" onload="this.media='all'">
