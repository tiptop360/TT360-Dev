{% doc %}
  @prompt
    generate a plceholder for image banner that i can upload and control adding buttons or text and full contrle on the size and deisgn , give me the control to select the size of the image, full or conatner also optimize for mobile first
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-banner__wrapper-{{ ai_gen_id }} {
    {% if block.settings.banner_width == 'container' %}
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 15px;
    {% endif %}
  }

  .ai-image-banner__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height_mobile }}px;
  }

  .ai-image-banner__image-wrapper-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .ai-image-banner__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: {{ block.settings.image_position }};
  }

  .ai-image-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-image-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-image-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: {{ block.settings.content_padding_mobile }}px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 2;
  }

  .ai-image-banner__text-wrapper-{{ ai_gen_id }} {
    max-width: 100%;
  }

  .ai-image-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size_mobile }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-image-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size_mobile }}px;
    margin: 0 0 {{ block.settings.subheading_spacing }}px 0;
    line-height: 1.4;
  }

  .ai-image-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size_mobile }}px;
    margin: 0 0 {{ block.settings.text_spacing }}px 0;
    line-height: 1.6;
  }

  .ai-image-banner__buttons-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_spacing }}px;
    flex-direction: column;
    width: 100%;
    {% if block.settings.text_alignment == 'center' %}
      align-items: center;
    {% elsif block.settings.text_alignment == 'right' %}
      align-items: flex-end;
    {% else %}
      align-items: flex-start;
    {% endif %}
  }

  .ai-image-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    width: 100%;
    max-width: 300px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-align: center;
  }

  .ai-image-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_background_hover }};
    color: {{ block.settings.button_text_color_hover }};
    border-color: {{ block.settings.button_border_color_hover }};
  }

  .ai-image-banner__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_background }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border_color }};
  }

  .ai-image-banner__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_background_hover }};
    color: {{ block.settings.button_secondary_text_color_hover }};
    border-color: {{ block.settings.button_secondary_border_color_hover }};
  }

  @media screen and (min-width: 750px) {
    .ai-image-banner__container-{{ ai_gen_id }} {
      height: {{ block.settings.banner_height }}px;
    }

    .ai-image-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
    }

    .ai-image-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size }}px;
    }

    .ai-image-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size }}px;
    }

    .ai-image-banner__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding }}px;
    }

    .ai-image-banner__text-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.content_max_width }}px;
    }

    .ai-image-banner__buttons-{{ ai_gen_id }} {
      flex-direction: row;
      width: auto;
      {% if block.settings.text_alignment == 'center' %}
        justify-content: center;
      {% elsif block.settings.text_alignment == 'right' %}
        justify-content: flex-end;
      {% else %}
        justify-content: flex-start;
      {% endif %}
    }

    .ai-image-banner__button-{{ ai_gen_id }} {
      width: auto;
    }

    .ai-image-banner__placeholder-{{ ai_gen_id }} svg {
      max-width: 500px;
      max-height: 500px;
    }
  }
{% endstyle %}

<div class="ai-image-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-banner__wrapper-{{ ai_gen_id }}">
    <div class="ai-image-banner__container-{{ ai_gen_id }}">
      <div class="ai-image-banner__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.banner_image %}
          <img
            src="{{ block.settings.banner_image | image_url: width: 2000 }}"
            alt="{{ block.settings.banner_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.banner_image.width }}"
            height="{{ block.settings.banner_image.height }}"
            class="ai-image-banner__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-banner__placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-image-banner__empty-state-{{ ai_gen_id }}">
              Upload your banner image to get started
            </div>
          </div>
        {% endif %}
      </div>

      {% if block.settings.show_overlay %}
        <div class="ai-image-banner__overlay-{{ ai_gen_id }}"></div>
      {% endif %}

      <div class="ai-image-banner__content-{{ ai_gen_id }}">
        <div class="ai-image-banner__text-wrapper-{{ ai_gen_id }}">
          {% if block.settings.subheading != blank %}
            <div class="ai-image-banner__subheading-{{ ai_gen_id }}">
              {{ block.settings.subheading }}
            </div>
          {% endif %}

          {% if block.settings.heading != blank %}
            <h2 class="ai-image-banner__heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="ai-image-banner__text-{{ ai_gen_id }}">
              {{ block.settings.text }}
            </div>
          {% endif %}

          {% if block.settings.show_buttons %}
            <div class="ai-image-banner__buttons-{{ ai_gen_id }}">
              {% if block.settings.button_text != blank %}
                <a
                  href="{{ block.settings.button_link }}"
                  class="ai-image-banner__button-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_text }}
                </a>
              {% endif %}

              {% if block.settings.button_secondary_text != blank %}
                <a
                  href="{{ block.settings.button_secondary_link }}"
                  class="ai-image-banner__button-{{ ai_gen_id }} ai-image-banner__button--secondary-{{ ai_gen_id }}"
                >
                  {{ block.settings.button_secondary_text }}
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

