{% doc %}
  @prompt
    2 BUTTON URL LINK TO PAGES 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-buttons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dual-buttons__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    flex-wrap: wrap;
  }

  .ai-dual-buttons__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
    text-transform: {{ block.settings.button_text_transform }};
  }

  .ai-dual-buttons__button-{{ ai_gen_id }}--primary {
    background-color: {{ block.settings.button_1_bg_color }};
    color: {{ block.settings.button_1_text_color }};
    border-color: {{ block.settings.button_1_bg_color }};
  }

  .ai-dual-buttons__button-{{ ai_gen_id }}--primary:hover {
    background-color: {{ block.settings.button_1_hover_bg_color }};
    color: {{ block.settings.button_1_hover_text_color }};
    border-color: {{ block.settings.button_1_hover_bg_color }};
  }

  .ai-dual-buttons__button-{{ ai_gen_id }}--secondary {
    background-color: {{ block.settings.button_2_bg_color }};
    color: {{ block.settings.button_2_text_color }};
    border-color: {{ block.settings.button_2_bg_color }};
  }

  .ai-dual-buttons__button-{{ ai_gen_id }}--secondary:hover {
    background-color: {{ block.settings.button_2_hover_bg_color }};
    color: {{ block.settings.button_2_hover_text_color }};
    border-color: {{ block.settings.button_2_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-buttons__container-{{ ai_gen_id }} {
      {% if block.settings.stack_on_mobile %}
        flex-direction: column;
        width: 100%;
      {% endif %}
    }

    {% if block.settings.stack_on_mobile %}
      .ai-dual-buttons__button-{{ ai_gen_id }} {
        width: 100%;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-dual-buttons-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-buttons__container-{{ ai_gen_id }}">
    {% if block.settings.button_1_text != blank and block.settings.button_1_link != blank %}
      <a
        href="{{ block.settings.button_1_link }}"
        class="ai-dual-buttons__button-{{ ai_gen_id }} ai-dual-buttons__button-{{ ai_gen_id }}--primary"
      >
        {{ block.settings.button_1_text }}
      </a>
    {% endif %}

    {% if block.settings.button_2_text != blank and block.settings.button_2_link != blank %}
      <a
        href="{{ block.settings.button_2_link }}"
        class="ai-dual-buttons__button-{{ ai_gen_id }} ai-dual-buttons__button-{{ ai_gen_id }}--secondary"
      >
        {{ block.settings.button_2_text }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Dual button links",
  "settings": [
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "button_1_bg_color",
      "label": "Background color",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_1_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_1_hover_bg_color",
      "label": "Hover background color",
      "default": "#f9655d"
    },
    {
      "type": "color",
      "id": "button_1_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "button_2_bg_color",
      "label": "Background color",
      "default": "#f9655d"
    },
    {
      "type": "color",
      "id": "button_2_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_2_hover_bg_color",
      "label": "Hover background color",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "button_2_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "Space between buttons",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "checkbox",
      "id": "stack_on_mobile",
      "label": "Stack buttons on mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "select",
      "id": "button_text_transform",
      "label": "Text transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 16,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 28
    }
  ],
  "presets": [
    {
      "name": "Dual button links"
    }
  ],
  "tag": null
}
{% endschema %}