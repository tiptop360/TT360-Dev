{% doc %}
  @prompt
    Real authentic timer for urgency
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign now = 'now' | date: '%s' | times: 1 %}
{% assign end_time = block.settings.end_date | date: '%s' | times: 1 %}

{% style %}
  .ai-urgency-timer-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-urgency-timer__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
  }

  .ai-urgency-timer__subtext-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subtext_spacing }}px 0;
    color: {{ block.settings.subtext_color }};
    font-size: {{ block.settings.subtext_size }}px;
  }

  .ai-urgency-timer__countdown-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.timer_gap }}px;
    flex-wrap: wrap;
  }

  .ai-urgency-timer__unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_width }}px;
  }

  .ai-urgency-timer__value-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.box_size }}px;
    height: {{ block.settings.box_size }}px;
    background-color: {{ block.settings.box_background }};
    color: {{ block.settings.number_color }};
    font-size: {{ block.settings.number_size }}px;
    font-weight: {{ block.settings.number_weight }};
    border-radius: {{ block.settings.box_radius }}px;
    border: {{ block.settings.box_border_width }}px solid {{ block.settings.box_border_color }};
  }

  .ai-urgency-timer__label-{{ ai_gen_id }} {
    margin-top: {{ block.settings.label_spacing }}px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    text-transform: {{ block.settings.label_transform }};
  }

  .ai-urgency-timer__expired-{{ ai_gen_id }} {
    display: none;
    color: {{ block.settings.expired_color }};
    font-size: {{ block.settings.expired_size }}px;
    font-weight: {{ block.settings.expired_weight }};
  }

  .ai-urgency-timer__expired-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-urgency-timer__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-urgency-timer__subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-urgency-timer__value-{{ ai_gen_id }} {
      width: {{ block.settings.box_size | times: 0.8 }}px;
      height: {{ block.settings.box_size | times: 0.8 }}px;
      font-size: {{ block.settings.number_size | times: 0.8 }}px;
    }

    .ai-urgency-timer__unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_width | times: 0.8 }}px;
    }
  }
{% endstyle %}

<urgency-timer-{{ ai_gen_id }}
  class="ai-urgency-timer-{{ ai_gen_id }}"
  data-end-time="{{ end_time }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h3 class="ai-urgency-timer__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  {% if block.settings.subtext != blank %}
    <div class="ai-urgency-timer__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</div>
  {% endif %}

  <div class="ai-urgency-timer__countdown-{{ ai_gen_id }}">
    {% if block.settings.show_days %}
      <div class="ai-urgency-timer__unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer__value-{{ ai_gen_id }}" data-unit="days">00</div>
        <div class="ai-urgency-timer__label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_hours %}
      <div class="ai-urgency-timer__unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer__value-{{ ai_gen_id }}" data-unit="hours">00</div>
        <div class="ai-urgency-timer__label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_minutes %}
      <div class="ai-urgency-timer__unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer__value-{{ ai_gen_id }}" data-unit="minutes">00</div>
        <div class="ai-urgency-timer__label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_seconds %}
      <div class="ai-urgency-timer__unit-{{ ai_gen_id }}">
        <div class="ai-urgency-timer__value-{{ ai_gen_id }}" data-unit="seconds">00</div>
        <div class="ai-urgency-timer__label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
      </div>
    {% endif %}
  </div>

  <div class="ai-urgency-timer__expired-{{ ai_gen_id }}">
    {{ block.settings.expired_message }}
  </div>
</urgency-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class UrgencyTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endTime = parseInt(this.dataset.endTime, 10);
        this.countdown = this.querySelector('.ai-urgency-timer__countdown-{{ ai_gen_id }}');
        this.expiredMessage = this.querySelector('.ai-urgency-timer__expired-{{ ai_gen_id }}');
        this.daysEl = this.querySelector('[data-unit="days"]');
        this.hoursEl = this.querySelector('[data-unit="hours"]');
        this.minutesEl = this.querySelector('[data-unit="minutes"]');
        this.secondsEl = this.querySelector('[data-unit="seconds"]');
        this.interval = null;
      }

      connectedCallback() {
        this.updateTimer();
        this.interval = setInterval(() => this.updateTimer(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateTimer() {
        const now = Math.floor(Date.now() / 1000);
        const timeLeft = this.endTime - now;

        if (timeLeft <= 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(timeLeft / 86400);
        const hours = Math.floor((timeLeft % 86400) / 3600);
        const minutes = Math.floor((timeLeft % 3600) / 60);
        const seconds = timeLeft % 60;

        if (this.daysEl) {
          this.daysEl.textContent = this.pad(days);
        }
        if (this.hoursEl) {
          this.hoursEl.textContent = this.pad(hours);
        }
        if (this.minutesEl) {
          this.minutesEl.textContent = this.pad(minutes);
        }
        if (this.secondsEl) {
          this.secondsEl.textContent = this.pad(seconds);
        }
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        this.countdown.style.display = 'none';
        this.expiredMessage.classList.add('active');
      }

      pad(num) {
        return num.toString().padStart(2, '0');
      }
    }

    customElements.define('urgency-timer-{{ ai_gen_id }}', UrgencyTimer{{ ai_gen_id }});
  })();
</script>

