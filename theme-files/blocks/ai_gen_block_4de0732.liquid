{% doc %}
  @prompt
    2 TITLES BOTH SIDE  URL LINk 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-titles-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dual-titles__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-dual-titles__item-{{ ai_gen_id }} {
    flex: 1;
    text-align: center;
  }

  .ai-dual-titles__link-{{ ai_gen_id }} {
    display: inline-block;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-dual-titles__link-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
  }

  .ai-dual-titles__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    transition: color 0.3s ease;
  }

  .ai-dual-titles__link-{{ ai_gen_id }}:hover .ai-dual-titles__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-titles__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-dual-titles__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }
{% endstyle %}

<dual-titles-{{ ai_gen_id }} class="ai-dual-titles-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-dual-titles__container-{{ ai_gen_id }}">
    <div class="ai-dual-titles__item-{{ ai_gen_id }}">
      {% if block.settings.title_1_link != blank %}
        <a href="{{ block.settings.title_1_link }}" class="ai-dual-titles__link-{{ ai_gen_id }}">
          <h2 class="ai-dual-titles__title-{{ ai_gen_id }}">{{ block.settings.title_1 }}</h2>
        </a>
      {% else %}
        <h2 class="ai-dual-titles__title-{{ ai_gen_id }}">{{ block.settings.title_1 }}</h2>
      {% endif %}
    </div>

    <div class="ai-dual-titles__item-{{ ai_gen_id }}">
      {% if block.settings.title_2_link != blank %}
        <a href="{{ block.settings.title_2_link }}" class="ai-dual-titles__link-{{ ai_gen_id }}">
          <h2 class="ai-dual-titles__title-{{ ai_gen_id }}">{{ block.settings.title_2 }}</h2>
        </a>
      {% else %}
        <h2 class="ai-dual-titles__title-{{ ai_gen_id }}">{{ block.settings.title_2 }}</h2>
      {% endif %}
    </div>
  </div>
</dual-titles-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Dual titles with links",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Title 1"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Title 1",
      "default": "First Title"
    },
    {
      "type": "url",
      "id": "title_1_link",
      "label": "Title 1 link"
    },
    {
      "type": "header",
      "content": "Title 2"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Title 2",
      "default": "Second Title"
    },
    {
      "type": "url",
      "id": "title_2_link",
      "label": "Title 2 link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size mobile",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#12395e"
    },
    {
      "type": "color",
      "id": "title_hover_color",
      "label": "Title hover color",
      "default": "#f9655d"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between titles",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Gap mobile",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Padding vertical",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Dual titles with links"
    }
  ]
}
{% endschema %}