{% doc %}
  @prompt
    bundle-wrapper (dark bg container)
    │
    └── bundle-card (mint green rounded card)
        │
        ├── bundle-left (flex: 1)
        │   ├── badge          → "BEST VALUE — 51% OFF"
        │   ├── h2 title       → "Complete Kids Dental Care Bundle"
        │   ├── description    → paragraph text
        │   ├── ul items       → 4 bullet points
        │   └── button         → "Get the Bundle — AED 150"
        │
        └── bundle-right (fixed width: 180px)
            ├── original price → strikethrough "Value: AED 307"
            ├── sale price     → "AED 150" (large)
            ├── savings badge  → "You save AED 157"
            └── delivery note  → "🚚 Next-day delivery across the UAE"
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bundle-wrapper-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.wrapper_bg_color }};
    padding: {{ block.settings.wrapper_padding }}px;
    border-radius: {{ block.settings.wrapper_border_radius }}px;
  }

  .ai-bundle-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    gap: {{ block.settings.card_gap }}px;
    align-items: stretch;
  }

  .ai-bundle-left-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-bundle-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
  }

  .ai-bundle-title-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: 1.3;
  }

  .ai-bundle-description-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_font_size }}px;
    line-height: 1.6;
  }

  .ai-bundle-items-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.items_gap }}px;
  }

  .ai-bundle-items-{{ ai_gen_id }} li {
    color: {{ block.settings.items_color }};
    font-size: {{ block.settings.items_font_size }}px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .ai-bundle-items-{{ ai_gen_id }} li::before {
    content: "{{ block.settings.bullet_icon }}";
    flex-shrink: 0;
    font-size: {{ block.settings.items_font_size }}px;
  }

  .ai-bundle-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    width: fit-content;
  }

  .ai-bundle-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-bundle-right-{{ ai_gen_id }} {
    width: {{ block.settings.price_section_width }}px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.price_gap }}px;
    align-items: flex-end;
    justify-content: center;
  }

  .ai-bundle-original-price-{{ ai_gen_id }} {
    color: {{ block.settings.original_price_color }};
    font-size: {{ block.settings.original_price_font_size }}px;
    text-decoration: line-through;
    margin: 0;
  }

  .ai-bundle-sale-price-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
    font-size: {{ block.settings.sale_price_font_size }}px;
    font-weight: {{ block.settings.sale_price_font_weight }};
    margin: 0;
    line-height: 1;
  }

  .ai-bundle-savings-{{ ai_gen_id }} {
    background-color: {{ block.settings.savings_bg_color }};
    color: {{ block.settings.savings_text_color }};
    padding: {{ block.settings.savings_padding_vertical }}px {{ block.settings.savings_padding_horizontal }}px;
    border-radius: {{ block.settings.savings_border_radius }}px;
    font-size: {{ block.settings.savings_font_size }}px;
    font-weight: {{ block.settings.savings_font_weight }};
    text-align: center;
  }

  .ai-bundle-delivery-{{ ai_gen_id }} {
    color: {{ block.settings.delivery_color }};
    font-size: {{ block.settings.delivery_font_size }}px;
    margin: 0;
    text-align: right;
  }

  @media screen and (max-width: 768px) {
    .ai-bundle-card-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.card_gap | times: 1.5 }}px;
    }

    .ai-bundle-right-{{ ai_gen_id }} {
      width: 100%;
      align-items: flex-start;
    }

    .ai-bundle-delivery-{{ ai_gen_id }} {
      text-align: left;
    }

    .ai-bundle-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.8 }}px;
    }

    .ai-bundle-sale-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.sale_price_font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-bundle-wrapper-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bundle-card-{{ ai_gen_id }}">
    <div class="ai-bundle-left-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <div class="ai-bundle-badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      {% if block.settings.title != blank %}
        <h2 class="ai-bundle-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <p class="ai-bundle-description-{{ ai_gen_id }}">
          {{ block.settings.description }}
        </p>
      {% endif %}

      <ul class="ai-bundle-items-{{ ai_gen_id }}">
        {% if block.settings.item_1 != blank %}
          <li>{{ block.settings.item_1 }}</li>
        {% endif %}
        {% if block.settings.item_2 != blank %}
          <li>{{ block.settings.item_2 }}</li>
        {% endif %}
        {% if block.settings.item_3 != blank %}
          <li>{{ block.settings.item_3 }}</li>
        {% endif %}
        {% if block.settings.item_4 != blank %}
          <li>{{ block.settings.item_4 }}</li>
        {% endif %}
      </ul>

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-bundle-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-bundle-right-{{ ai_gen_id }}">
      {% if block.settings.original_price_text != blank %}
        <p class="ai-bundle-original-price-{{ ai_gen_id }}">
          {{ block.settings.original_price_text }}
        </p>
      {% endif %}

      {% if block.settings.sale_price_text != blank %}
        <p class="ai-bundle-sale-price-{{ ai_gen_id }}">
          {{ block.settings.sale_price_text }}
        </p>
      {% endif %}

      {% if block.settings.savings_text != blank %}
        <div class="ai-bundle-savings-{{ ai_gen_id }}">
          {{ block.settings.savings_text }}
        </div>
      {% endif %}

      {% if block.settings.delivery_text != blank %}
        <p class="ai-bundle-delivery-{{ ai_gen_id }}">
          {{ block.settings.delivery_text }}
        </p>
      {% endif %}
    </div>
  </div>
</div>

